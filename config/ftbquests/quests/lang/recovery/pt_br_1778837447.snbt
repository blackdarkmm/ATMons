	"chapters/relics.snbt": {
		quest.730130CCF1CF5119.quest_desc: {
			new: ["Estas relíquias podem ser encontradas na &2Superfície&r!"]
			old: ["Estas relíquias podem ser encontradas no &2Mundo Superior&r!"]
		}
		quest.6B40AF49F505A551.quest_desc: {
			new: [" Escondido nas vastas extensões da &2Superfície&r, os &cPatins&r aguardam o ousado &2aventureiro&r. Uma vez calçados, cada passo &cpuxa&r o portador para frente, transformando o movimento em um &cmomento imparável&r. \\n\\n- Possui 1 habilidade: \\n\\n &bAceleração&r: \\n Ao &ccorrer continuamente&r, o portador ganha gradualmente &bvelocidade de movimento&r, atingindo o &cbônus máximo&r após alguns &2segundos&r. Quanto mais rápido você vai, mais &2escorregadias&r as superfícies se tornam, adicionando tanto &cempolgação&r quanto &crisco&r. \\n\\n- Uma &6relíquia&r de &cvelocidade&r e &6momento&r… onde cada &apasso&r deixa um rastro de &cfogo&r para trás."]
			old: [" Escondido nas vastas extensões do &2Mundo Superior&r, os &cPatins&r aguardam o ousado &2aventureiro&r. Uma vez calçados, cada passo &cpuxa&r o portador para frente, transformando o movimento em um &cmomento imparável&r. \\n\\n- Possui 1 habilidade: \\n\\n &bAceleração&r: \\n Ao &ccorrer continuamente&r, o portador ganha gradualmente &bvelocidade de movimento&r, atingindo o &cbônus máximo&r após alguns &2segundos&r. Quanto mais rápido você vai, mais &2escorregadias&r as superfícies se tornam, adicionando tanto &cempolgação&r quanto &crisco&r. \\n\\n- Uma &6relíquia&r de &cvelocidade&r e &6momento&r… onde cada &apasso&r deixa um rastro de &cfogo&r para trás."]
		}
