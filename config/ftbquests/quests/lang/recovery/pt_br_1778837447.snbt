		quest.2A559D527BC88DEC.quest_desc: {
			new: ["Jogue um &9Ovo Gerador de Abelha Espacial&r e um &8Bloco de Aço do Céu&r na &6lava&r, espere alguns ticks e voilà, você terá um Ovo Gerador de Abelha de Aço do Céu."]
			old: ["Jogue um &9Ovo de Gerador de Abelha Espacial&r e um &8Bloco de Aço do Céu&r na &6lava&r, espere alguns ticks e voilà, você terá um Ovo de Gerador de Abelha de Aço do Céu."]
