		quest.6ADE6F9E004055F7.quest_desc: {
			new: [
				"Os Cristais de Tempo são um novo material adicionado por JDT. Eles crescem em Blocos de Drusa Cristal de Tempo, que são criados ao espalhar goo em Blocos de Drusa de Ametista ou Blocos de Cristal de Tempo.\\n\\nNO ENTANTO, o Bloco de Drusa de Cristal de Tempo deve coletar tempo da &9Superfície&r, do &6Nether&r, e do &aEnd&r para poder crescer Agregados de Cristal de Tempo. Você NÃO PODE quebrar ou usar toque suave no Bloco de Drusa de Cristal de Tempo. Você deve usar um Trocador, Caixa de Papelão, ou Gadget de Cortar e Colar para movê-los.\\n\\nDepois de um tempo, o Bloco de Drusa de Cristal de Tempo vai &2ficar sem energia&r, e deverá fazer outra viagem para a &9Superfície&r, &6Nether&r, e &aEnd&r."
				"{@pagebreak}"
				"Para automatizar esse processo, veja o vídeo linkado na imagem acima desta missão.\\n\\nE se a &2codificação de &zcores&r na página anterior não foi suficiente, adicionei uma imagem para ajudar você a identificar em qual estágio está cada Bloco de Drusa de Cristal de Tempo."
				""
				"{image:atm:textures/questpics/justdirethings/budding_time_crystal_reference.png width:250 height:125 align:center}"
			]
			old: [
				"Os Cristais de Tempo são um novo material adicionado por JDT. Eles crescem em Blocos de Drusa Cristal de Tempo, que são criados ao espalhar goo em Blocos de Drusa de Ametista ou Blocos de Cristal de Tempo.\\n\\nNO ENTANTO, o Bloco de Drusa de Cristal de Tempo deve coletar tempo do &9Mundo Superior&r, do &6Nether&r, e do &aEnd&r para poder crescer Agregados de Cristal de Tempo. Você NÃO PODE quebrar ou usar toque suave no Bloco de Drusa de Cristal de Tempo. Você deve usar um Trocador, Caixa de Papelão, ou Gadget de Cortar e Colar para movê-los.\\n\\nDepois de um tempo, o Bloco de Drusa de Cristal de Tempo vai &2ficar sem energia&r, e deverá fazer outra viagem para o &9Mundo Superior&r, &6Nether&r, e &aEnd&r."
				"{@pagebreak}"
				"Para automatizar esse processo, veja o vídeo linkado na imagem acima desta missão.\\n\\nE se a &2codificação de &zcores&r na página anterior não foi suficiente, adicionei uma imagem para ajudar você a identificar em qual estágio está cada Bloco de Drusa de Cristal de Tempo."
				""
				"{image:atm:textures/questpics/justdirethings/budding_time_crystal_reference.png width:250 height:125 align:center}"
			]
		}
	}
	"chapters/railcraft.snbt": {
		quest.21693C4DE6531D73.quest_desc: {
			new: [
				"O Triturador é exatamente como o nome sugere. Ele pode triturar blocos para obter os materiais de criação, como tijolos de uma escada de tijolos, ou pó de lingotes. \\n\\nEle precisa de energia para funcionar! \\n\\nPara construir um, são 3x2x2 de blocos de Triturador."
				"{image:atm:textures/questpics/railcraft/rail_crusher.png width:100 height:100 align:center}"
			]
			old: [
				"O Triturador é exatamente como o nome sugere. Ele pode triturar blocos para obter os materiais de criação, como tijolos de uma escada de tijolos, ou pós de barras. \\n\\nEle precisa de energia para funcionar! \\n\\nPara construir um, são 3x2x2 de blocos de Triturador."
				"{image:atm:textures/questpics/railcraft/rail_crusher.png width:100 height:100 align:center}"
			]
		}
	}
	"chapters/cataclysm.snbt": {
		quest.17CA9D80D8EC3EF7.quest_desc: {
			new: [
				"&4&lO Arauto&r se inspira muito no que o fortalece, a Estrela do Nether. \\n\\nEle tem 4,680 &4Corações&r e atacará todos os Mobs e Jogadores que vir que não aparecem na &4Fábrica Ancestral&r. \\n\\nEle voará por aí e até mesmo investirá contra você. Como &0O Wither&r, &l&4O Arauto&r quebrará quase todos os Blocos em seu caminho. \\n\\nPara atacar, ele pode atirar &4Mísseis Wither&r em você, que podem lhe dar &0Efeito Wither&r, ou atirar &4Bomba de Wither&r de suas costas, que dispararão em todas as direções. \\n\\nEle também tem &4Lasers&r que pode atirar em você, &4Gatlings de Laser&r e um &4grande raio da boca&r. \\n\\nEle tem uma grande fraqueza, como as outras máquinas vivas, ele é fraco aos &4EMPs&r! Se você usá-los nele, ele ficará atordoado, incapaz de se mover ou lutar por alguns segundos."
				"{image:atm:textures/questpics/cataclysm/cataclysm_harbinger.png width:100 height:100 align:center}"
			]
			old: [
				"&4&lO Arauto&r se inspira muito no que o fortalece, a Estrela do Nether. \\n\\nEle tem 4,680 &4Corações&r e atacará todos os Mobs e Jogadores que vir que não aparecem na &4Fábrica Ancestral&r. \\n\\nEle voará por aí e até mesmo investirá contra você. Como &0O Wither&r, &l&4O Arauto&r quebrará quase todos os Blocos em seu caminho. \\n\\nPara atacar, ele pode atirar &4Mísseis Wither&r em você, que podem lhe dar &0Efeito Wither&r, ou atirar &4Howitzers Wither&r de suas costas, que dispararão em todas as direções. \\n\\nEle também tem &4Lasers&r que pode atirar em você, &4Gatlings de Laser&r e um &4grande raio da boca&r. \\n\\nEle tem uma grande fraqueza, como as outras máquinas vivas, ele é fraco aos &4EMPs&r! Se você usá-los nele, ele ficará atordoado, incapaz de se mover ou lutar por alguns segundos."
				"{image:atm:textures/questpics/cataclysm/cataclysm_harbinger.png width:100 height:100 align:center}"
			]
		}
		quest.69439426534EBDC4.title: {
			new: "&bPunhos Blazing"
			old: "&bPunhos Flamejantes"
		}
		quest.21A0FD474FBB49F7.quest_desc: {
			new: [
				"Outra estrutura para cobrir a aridez do &5End&r, a &dCidadela em Ruínas&r. \\n\\nA &dCidadela em Ruínas&r é um palácio de &5Obsidiana&r, Pedra do End e &dPúrpura&r. \\n\\nNo palácio, você encontrará Baús, Caixas de Shulker, Shulkers e até a única &dPedra do Vazio&r! \\n\\nSó tome cuidado com os já mencionados Shulkers, &dEndermaptera&r e &dGolems do End&r."
				"{image:atm:textures/questpics/cataclysm/cataclysm_citadel.png width:200 height:100 align:center}"
			]
			old: [
				"Outra estrutura para cobrir a aridez do &5End&r, a &dCidadela em Ruínas&r. \\n\\nA &dCidadela em Ruínas&r é um palácio de &5Obsidiana&r, Pedra do End e &dPurpur&r. \\n\\nNo palácio, você encontrará Baús, Caixas de Shulker, Shulkers e até a única &dPedra do Vazio&r! \\n\\nSó tome cuidado com os já mencionados Shulkers, &dEndermaptera&r e &dGolems do End&r."
				"{image:atm:textures/questpics/cataclysm/cataclysm_citadel.png width:200 height:100 align:center}"
			]
		}
		quest.0496E8E786262464.title: {
			new: "&2Superfície&r: Terra de &m3, 4, 5&r chefes"
			old: "&2Mundo Superior&r: Terra de &m3 4&r 5 chefes"
		}
		quest.74ACCEB6DC9EF6F7.quest_desc: {
			new: ["A &dArma de Assalto de Wither do Vazio &4(A.D.A.D.W.D.V.)&r é como a versão do Wither, mas melhor! \\n\\nAgora ela só dispara &dBomba do Vazio&r que causarão mais Dano e farão &dRunas do Vazio&r saírem do chão, na área que a &4Bomba&r atingiu. \\n\\nSó ao custo do longo tempo de recarga, mas temos tempo para esperar. \\n\\nPode ser criada combinando o &4A.D.A.D.W.D.V.&r e um &dNúcleo do Vazio&r na &4Bigorna de Infusão Mecânica&r."]
			old: ["A &dArma de Ombro de Assalto do Vazio &4(A.&4O.A.V.)&r é como a versão do Wither, mas melhor! \\n\\nAgora ela só dispara &dHowitzers do Vazio&r que causarão mais Dano e farão &dRunas do Vazio&r saírem do chão, na área que o &4Howitzer&r atingiu. \\n\\nSó ao custo do longo tempo de recarga, mas temos tempo para esperar. \\n\\nPode ser criada combinando o &4A.O.A.V.&r e um &dNúcleo do Vazio&r na &4Bigorna de Infusão Mecânica&r."]
		}
		quest.7AED8FD7FB023AD8.quest_subtitle: {
			new: "Energizando O Wither Robô-Mecânico"
			old: "Energizando O Harbinger"
		}
		quest.74ACCEB6DC9EF6F7.title: {
			new: "&dA.D.A.D.W.D.V. (&cArma de Assalto de Wither do Vazio&d)"
			old: "&dA.&4O.A.V. &d(Arma de Ombro de Assalto do &4Vazio)"
		}
		quest.775AB10F8196F27B.quest_desc: {
			new: ["O &4Olho de Mec&r o levará à &4Fábrica Ancestral&r para lutar contra o &4&lWither Robô-Mecânico&r."]
			old: ["O &4Olho de Mec&r o levará à &4Fábrica Ancestral&r para lutar contra o &4&lPresságio (The Harbinger)&r."]
		}
		quest.7AED8FD7FB023AD8.quest_desc: {
			new: ["Para energizar &4&lO Wither Robô-Mecânico&r, você precisará de uma Estrela do Nether, que você obtém ao matar o Wither. \\n\\nÉ uma mecânica &2&lVanilla&r que eu não deveria ter que explicar. \\n\\nAlém disso, está no Capítulo 1."]
			old: ["Para energizar &4&lO Harbinger&r, você precisará de uma Estrela do Nether, que você obtém ao matar o Wither. \\n\\nÉ uma mecânica &2&lVanilla&r que eu não deveria ter que explicar. \\n\\nAlém disso, está no Capítulo 1."]
		}
		quest.0496E8E786262464.quest_desc: {
			new: ["Eu realmente preciso te explicar a &2Superfície&r?"]
			old: ["Eu realmente preciso te explicar o &2Mundo Superior&r?"]
		}
		quest.04B40BB107F14330.title: {
			new: "&4Triturador"
			old: "&4Meat Shredder"
		}
		quest.445C9117198936B6.quest_desc: {
			new: ["A &4Arma de Assalto de Wither (A.D.A.D.W.)&r é a última arma que você pode fazer com &4Witherita&r. \\n\\nEla tem 2 projéteis diferentes que pode disparar: &4Míssil de Wither&r e &4Bomba de Wither&r. \\n\\nOs &4Míssil de Wither&r são disparados apenas segurando o botão direito do mouse e danificarão qualquer coisa que for atingida por eles, com baixo tempo de recarga. \\n\\nOs &4Bomba de Wither&r são disparados quando você segura Shift e o botão direito do mouse, eles danificam uma área maior e deixam uma área de Efeito Wither, que danifica qualquer coisa que entre nela. Eles têm um tempo de recarga muito maior, no entanto."]
			old: ["A &4Wither Assault Shoulder Weapon (W.A.S.W.)&r é a última arma que você pode fazer com &4Witherite&r. \\n\\nEla tem 2 projéteis diferentes que pode disparar: &4Wither Missiles&r e &4Wither Howitzers&r. \\n\\nOs &4Wither Missiles&r são disparados apenas segurando o botão direito do mouse e danificarão qualquer coisa que for atingida por eles, com baixo tempo de recarga. \\n\\nOs &4Wither Howitzers&r são disparados quando você segura Shift e o botão direito do mouse, eles danificam uma área maior e deixam uma área de Efeito Wither, que danifica qualquer coisa que entre nela. Eles têm um tempo de recarga muito maior, no entanto."]
		}
		quest.445C9117198936B6.title: {
			new: "&4A.D.A.D.W. (Arma de Assalto de Wither)"
			old: "&4W.A.S.W. (Wither Assault Shoulder Weapon)"
		}
		quest.6ED61438A8A1EAA4.quest_desc: {
			new: ["Witherita é um drop do &4O Presságio&r, ele sempre dropará 1 bloco que pode ser transformado em 9 Barras. \\n\\nWitherita é usado para criar 3 Armas e a &4Bigorna de Fusão Mecânica&r, que pode ser usada para combinar Itens do &4&lCataclysm&r!"]
			old: ["Witherite é um drop do &4O Presságio&r, ele sempre dropará 1 bloco que pode ser transformado em 9 Barras. \\n\\nWitherite é usado para criar 3 Armas e a &4Bigorna de Fusão Mecânica&r, que pode ser usada para combinar Itens do &4&lCataclysm&r!"]
		}
		quest.6ED61438A8A1EAA4.quest_subtitle: {
			new: "= Witherita"
			old: "= Witherite"
		}
		quest.04B40BB107F14330.quest_desc: {
			new: ["O &4Triturador&r é uma arma corpo a corpo que você pode fazer de &4Witherita&r.\\n\\nEle tem dois ataques, usando o Clique Esquerdo ou o Clique Direito.\\n\\nQuando você Clica com o Esquerdo, ele usará o &4Triturador&r como um Machado, acertando-os uma vez de uma distância razoável.\\n\\nQuando você Clica com o Direito, ele irá triturá-los repetidamente com sua Serra, causando Dano muito mais rápido de perto."]
			old: ["O &4Meat Shredder&r é uma arma corpo a corpo que você pode fazer de &4Witherita&r.\\n\\nEle tem dois ataques, usando o Clique Esquerdo ou o Clique Direito.\\n\\nQuando você Clica com o Esquerdo, ele usará o &4Meat Shredder&r como um Machado, acertando-os uma vez de uma distância razoável.\\n\\nQuando você Clica com o Direito, ele irá triturá-los repetidamente com sua Serra, causando Dano muito mais rápido de perto."]
		}
		quest.50C9CB8FB16E453D.quest_desc: {
			new: [
				"A &bArena Ardente&r é uma arena gigante, estilo Coliseu, dentro do &4Nether&r. \\nVocê chegará ao primeiro andar, pacífico, mas quente. No segundo andar, encontrará &bFantasma Incendiado&r, que você precisará matar para obter &bCinzas Ardentes&r. \\n\\nQue podem ser usadas no terceiro andar, no Altar para invocar o &b&lIgnis&r! \\n\\nAh, e se estiver procurando por Tesouros, olhe acima do terceiro andar!"
				"{image:atm:textures/questpics/cataclysm/cataclysm_arena.png width:200 height:100 align:center}"
			]
			old: [
				"A &bArena Ardente&r é uma arena gigante, estilo Coliseu, dentro do &4Nether&r. \\nVocê chegará ao primeiro andar, pacífico, mas quente. No segundo andar, encontrará &bRevenants Incendiados&r, que você precisará matar para obter &bCinzas Ardentes&r. \\n\\nQue podem ser usadas no terceiro andar, no Altar para invocar o &b&lIgnis&r! \\n\\nAh, e se estiver procurando por Tesouros, olhe acima do terceiro andar!"
				"{image:atm:textures/questpics/cataclysm/cataclysm_arena.png width:200 height:100 align:center}"
			]
		}
		quest.747B62A955D0C629.title: {
			new: "&4Fábrica Ancestral&r: Lar do &4&lWither Robô-Mecânico&r"
			old: "&4Fábrica Ancestral&r: Lar do &4&lPresságio (The Harbinger)&r"
		}
		quest.2B115519A21F9CB7.quest_desc: {
			new: [
				"O &d&lGuardião do Ender&r é uma besta colossal de Pedra do End, &dPúrpura&r e &5Obsidiana&r que aguarda dentro do &dAltar do Vazio&r. \\nEle tem 6,660 &4Corações&r e cuidado para não chegar muito perto ou você pode ser puxado para mais perto dele! \\n\\nEle tem uma tonelada de ataques e habilidades, um sendo um soco muito simples para aqueles que estão muito perto de seu espaço pessoal, ou uma pancada que o jogará para trás. \\n\\nSe você estiver mais longe dele, ele pode fechar a distância avançando e colidindo com você. Ou ele pode pisar e produzir &dRunas do Vazio&r para atingi-lo! Ele também pode enviar &dBolas de Shulker&r em uma fileira. \\n\\nE lembra quando eu disse que ele pode te puxar para mais perto dele? Sim, ele faz isso com uma coisa chamada &dTufão do Vazio&r, que ele também pode invocar aos seus Pés para te prender. Depois que você fica lá por muito tempo, ele explode, muito provavelmente te danificando no processo. \\n\\nQuando você o leva à metade da &4Vida&r, sua Máscara se quebra revelando sua verdadeira Cabeça! Com raiva, ele destruirá o chão da arena, levando vocês dois para o nível inferior. \\n\\nAgora ele vai te sugar mais, enviar mais &dRunas do Vazio&r atrás de você e atacar mais rápido e mais forte!"
				"{image:atm:textures/questpics/cataclysm/cataclysm_guardiuan.png width:100 height:100 align:center}"
			]
			old: [
				"O &d&lGuardião do Ender&r é uma besta colossal de Endstone, &dPurpur&r e &5Obsidiana&r que aguarda dentro do &dAltar do Vazio&r. \\nEle tem 6,660 &4Corações&r e cuidado para não chegar muito perto ou você pode ser puxado para mais perto dele! \\n\\nEle tem uma tonelada de ataques e habilidades, um sendo um soco muito simples para aqueles que estão muito perto de seu espaço pessoal, ou uma pancada que o jogará para trás. \\n\\nSe você estiver mais longe dele, ele pode fechar a distância avançando e colidindo com você. Ou ele pode pisar e produzir &dRunas do Vazio&r para atingi-lo! Ele também pode enviar &dBolas de Shulker&r em uma fileira. \\n\\nE lembra quando eu disse que ele pode te puxar para mais perto dele? Sim, ele faz isso com uma coisa chamada &dTufão do Vazio&r, que ele também pode invocar aos seus Pés para te prender. Depois que você fica lá por muito tempo, ele explode, muito provavelmente te danificando no processo. \\n\\nQuando você o leva à metade da &4Vida&r, sua Máscara se quebra revelando sua verdadeira Cabeça! Com raiva, ele destruirá o chão da arena, levando vocês dois para o nível inferior. \\n\\nAgora ele vai te sugar mais, enviar mais &dRunas do Vazio&r atrás de você e atacar mais rápido e mais forte!"
				"{image:atm:textures/questpics/cataclysm/cataclysm_guardiuan.png width:100 height:100 align:center}"
			]
		}
		quest.62089E9E6D596DA7.quest_desc: {
			new: ["&3O &bImolador&r é um &3Aniquilador&r aprimorado com um &bLingote de Ignítio&r dentro da &4Bigorna de Fusão Mecânica&r. \\n\\nEstes causam mais dano a Mobs com &bMarca Ardente&r afligida neles, então as &bLuvas Ardentes&r funcionam muito bem com ele! \\n\\nSe você tiver &3O &bImolador&r em cada mão, pode segurar o botão direito para invocar um &bGolpe Blazing&r sob você. Isso causará dano a todos os Mobs nele e explodirá quando terminar, como uma despedida final!"]
			old: ["&3O &bImolador&r é um &3Aniquilador&r aprimorado com um &bLingote de Ignítio&r dentro da &4Bigorna de Fusão Mecânica&r. \\n\\nEstes causam mais dano a Mobs com &bMarca Ardente&r afligida neles, então as &bLuvas Ardentes&r funcionam muito bem com ele! \\n\\nSe você tiver &3O &bImolador&r em cada mão, pode segurar o botão direito para invocar um &bGolpe Flamejante&r sob você. Isso causará dano a todos os Mobs nele e explodirá quando terminar, como uma despedida final!"]
		}
		quest.5EDB5A2D744CE415.quest_desc: {
			new: ["A &4Laser Gatling&r é uma arma que você pode fazer com &4Witherita&r. \\n\\nUsando Redstone em seu inventário, você pode atirar Lasers que iniciam incêndios e causam 3 corações e meio de dano. \\n\\nEla dispara 50 Lasers por 1 redstone, o que eu acho um bom negócio."]
			old: ["A &4Laser Gatling&r é uma arma que você pode fazer com &4Witherite&r. \\n\\nUsando Redstone em seu inventário, você pode atirar Lasers que iniciam incêndios e causam 3 corações e meio de dano. \\n\\nEla dispara 50 Lasers por 1 redstone, o que eu acho um bom negócio."]
		}
		quest.236EA8D18ECD5FE8.quest_desc: {
			new: ["Este é bem único em seu aparecimento! Depois que você mata o &b&lIgnis&r, há uma chance de &bBerserkers Incendiados&r aparecerem em Fortalezas do Nether. \\n\\nEles são como &bFantasma Incendiado&r, só que em vez de Escudos, eles têm Espadas! Suas Espadas não protegem contra danos como os Escudos, em vez disso, causam mais dano. \\n\\nEles têm muito menos vida, com 65 &4Corações&r e droparão Brasas Moribundas ao serem mortos. 4 Brasas Moribundas podem ser transformadas em 1 &bCinza Ardente&r."]
			old: ["Este é bem único em seu aparecimento! Depois que você mata o &b&lIgnis&r, há uma chance de &bBerserkers Incendiados&r aparecerem em Fortalezas do Nether. \\n\\nEles são como &bRevenants&r, só que em vez de Escudos, eles têm Espadas! Suas Espadas não protegem contra danos como os Escudos, em vez disso, causam mais dano. \\n\\nEles têm muito menos vida, com 65 &4Corações&r e droparão Brasas Moribundas ao serem mortos. 4 Brasas Moribundas podem ser transformadas em 1 &bCinza Ardente&r."]
		}
		quest.747B62A955D0C629.quest_desc: {
			new: [
				"A &4Fábrica Ancestral&r fica nas profundezas da &2Superfície&r. \\n\\nVocê encontrará muitos Itens de Redstone como Alavancas, Trilhos Elétricos e PEMs... me pergunto se eles serão úteis em breve? \\n\\nVocê também encontrará algumas Máquinas de Redstone tentando te matar! Como os &4Observadores &fe &4Rondadores&r! \\n\\nMesmo com o perigo, ainda há toneladas de Saques e Blocos que você pode roubar daqui, especialmente Redstone."
				"{image:atm:textures/questpics/cataclysm/cataclysm_factory.png width:200 height:100 align:center}"
			]
			old: [
				"A &4Fábrica Ancestral&r fica nas profundezas do &2Mundo Superior&r. \\n\\nVocê encontrará muitos Itens de Redstone como Alavancas, Trilhos Elétricos e PEMs... me pergunto se eles serão úteis em breve? \\n\\nVocê também encontrará algumas Máquinas de Redstone tentando te matar! Como os &4Observadores &fe &4Rondadores&r! \\n\\nMesmo com o perigo, ainda há toneladas de Saques e Blocos que você pode roubar daqui, especialmente Redstone."
				"{image:atm:textures/questpics/cataclysm/cataclysm_factory.png width:200 height:100 align:center}"
			]
		}
		quest.69439426534EBDC4.quest_desc: {
			new: ["&bPunhos Blazing&r são outro Item que podemos fazer com &bIgnitium&r! \\n\\nÉ um Item de Curio que vai em suas Mãos. \\n\\nQuando usado, todos os ataques têm uma chance de dar ao alvo a &bMarca Blazing&r. \\n\\nIsto diminui a Armadura e a Resistência da Armadura, e é ruim de conseguir do &b&lIgnis&r."]
			old: ["&bPunhos Flamejantes&r são outro Item que podemos fazer com &bIgnitium&r! \\n\\nÉ um Item de Curio que vai em suas Mãos. \\n\\nQuando usado, todos os ataques têm uma chance de dar ao alvo a &bMarca Flamejante&r. \\n\\nIsto diminui a Armadura e a Resistência da Armadura, e é ruim de conseguir do &b&lIgnis&r."]
		}
	}
	"chapters/powah.snbt": {
