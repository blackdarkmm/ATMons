{
	"chapters/ars_nouveau.snbt": {
		quest.5766C8B9E850C186.quest_desc: {
			new: [
				"Para criar um dos principais itens de criação em Ars, a &9Gema de Fonte&r, precisaremos fazer uma &6Imbuement Chamber&r. \\n\\nA Imbuement Chamber requer Fonte para imbuir itens. Ela produz uma pequena quantidade de Fonte por si só, mas também pode usar Jarro de Fonte como fonte de energia. \\n\\nVárias receitas também exigem que Pedestais Arcanos sejam colocados ao redor dela.\\n"
				"{image:atm:textures/questpics/ars/imbuement.png width:200 height:150 align:1}"
			]
			old: [
				"Para criar um dos principais itens de criação em Ars, a &9Source Gem&r, precisaremos fazer uma &6Imbuement Chamber&r. \\n\\nA Imbuement Chamber requer Fonte para imbuir itens. Ela produz uma pequena quantidade de Source por si só, mas também pode usar Source Jars como fonte de energia. \\n\\nVárias receitas também exigem que Pedestais Arcanos sejam colocados ao redor dela.\\n"
				"{image:atm:textures/questpics/ars/imbuement.png width:200 height:150 align:1}"
			]
		}
		quest.5C3FF43CF16BCF30.title: {
			new: "Pedras de Fonte"
			old: "Pedra de Fonte"
		}
		quest.5C3FF43CF16BCF30.quest_desc: {
			new: ["Com as Gemas de Fonte, você pode começar a criar as várias máquinas, criando &5Pedras de Fonte&r."]
			old: ["Com as Gemas de Fonte, você pode começar a criar as várias máquinas, criando &5Sourcestones&r."]
		}
		task.03EB390E79866058.title: {
			new: "Pedra de Fontes"
			old: "Sourcestones"
		}
		quest.33682F4B44950123.quest_desc: {
			new: ["Para obter mais conhecimento sobre feitiços, precisaremos de um tipo específico de madeira mágica! \\n\\nÁrvores de Archwood podem ser encontradas na Superfície."]
			old: ["Para obter mais conhecimento sobre feitiços, precisaremos de um tipo específico de madeira mágica! \\n\\nÁrvores de Archwood podem ser encontradas no Mundo Superior."]
		}
	}
	"chapters/eternal_starlight.snbt": {
		quest.0576C32B0FB360B0.quest_desc: {
			new: [
				"A &l&9Monstruosidade Lunar&r tem 200 &4Corações&r e só receberá 1 de dano por golpe, a menos que você use Fogo. \\n\\nEla tem alguns ataques, incluindo Espinhos do Chão, Projéteis e Cabeças Tangled Explosivas! \\n\\nQuando você a matar, ela derrubará Flechas, Lingotes, Crânio Emaranhado, &9Pétalas Tenazes&r, &5Vinhas Tenazes&r, &9Orvalho da Alma&r, e uma chance de uma Arma rara!"
				"{image:atm:textures/questpics/eternal/starlight_lunar.png width:100 height:125 align:center}"
			]
			old: [
				"A Monstruosidade Lunar tem 200 Corações e só receberá 1 de dano por golpe, a menos que você use Fogo.\\n\\nEla tem alguns ataques, incluindo Espinhos do Chão, Projéteis e Cabeças Emaranhadas Explosivas!\\n\\nQuando você a mata, ela dropa Flechas, Barras, Tangled Skulls, Pétalas Tenazes, Almas Aprisionadas e uma chance de uma Arma rara!"
				"{image:atm:textures/questpics/eternal/starlight_lunar.png width:100 height:125 align:center}"
			]
		}
		quest.5244B2D6B5FA0487.title: {
			new: "&5Deserto Cristalizado"
			old: "Deserto Cristalizado"
		}
		quest.636848ED1115A0B3.quest_desc: {
			new: [
				"&8Ratlins&r são Mobs pacíficos que podem surgir na Superfície. \\n\\nAo morrer, derrubarão Carne de Ratlin, Couro e Musgo de Caverna. \\n\\nEste último pode ser usado para reproduzi-los!"
				"{image:atm:textures/questpics/eternal/starlight_rat.png width:100 height:100 align:center}"
			]
			old: [
				"Ratlins são Mobs pacíficos que podem aparecer na Superfície. \\n\\nNa morte, eles soltarão Carne de Ratlin, Couro e Musgo de Caverna. \\n\\nO último pode ser usado para procriá-los!"
				"{image:atm:textures/questpics/eternal/starlight_rat.png width:100 height:100 align:center}"
			]
		}
		quest.4A5EA948F5DCEB73.quest_desc: {
			new: ["&7Prata Abissal&r costumava se chamar Prata do Pântano e só surgia nos &9Pântanos Escuros&r. \\n\\nAgora é encontrado em todo lugar no subsolo... provavelmente foi por isso que mudaram o nome!"]
			old: ["Prata do Pântano pode ser raramente encontrada na Lama do Crepúsculo. \\n\\nPode ser usada para criar Armaduras e Ferramentas!"]
		}
		quest.17EC65B33AC5F0B4.quest_desc: {
			new: [
				"&8Andarilho Sedento&r são Mobs neutros que surgem na superfície dos &5Desertos Cristalizados&r. \\n\\nQuando provocados, eles vão te bater e te dar Fome. \\n\\nEles têm 20 &4Corações&r e podem derrubar &8Dente da Fome&r ao morrer."
				"{image:atm:textures/questpics/eternal/starlight_thirst.png width:100 height:125 align:center}"
			]
			old: [
				"Andarilhos da Sede são Mobs neutros que aparecem na superfície dos Desertos Cristalizados. \\n\\nQuando provocados, eles te baterão e te darão Fome. \\n\\nEles têm 20 Corações e podem dropar Dente da Fome na morte."
				"{image:atm:textures/questpics/eternal/starlight_thirst.png width:100 height:125 align:center}"
			]
		}
		quest.2E29DC243E8AD61E.quest_desc: {
			new: [
				"&9Asas-de-renda Cintilantes&r não fazem nem derrubam nada; só adicionam atmosfera. \\n\\nElas também se parecem com o único inseto que eu tolero!"
				"{image:atm:textures/questpics/eternal/starlight_shimmer.png width:150 height:100 align:center}"
			]
			old: [
				"As Lacraias Cintilantes não fazem ou dropam nada, elas apenas adicionam atmosfera. \\n\\nElas também se assemelham ao único inseto que eu tolero!"
				"{image:atm:textures/questpics/eternal/starlight_shimmer.png width:150 height:100 align:center}"
			]
		}
		quest.1533D98B3B2A758E.quest_desc: {
			new: ["&7Espadas Estilhaçadas&r podem ser derrubadas por &7Esqueletos Lonestar&r ou fabricadas usando as &7Lâminas&r derrubadas. \\n\\nA &7Espada Estilhaçada&r é usada mais como um Tridente do que como uma Espada; em vez de golpear, você a arremessa. Depois, você pode Clicar com o Botão Direito para trazer a &7Lâmina&r de volta como um Tridente com Lealdade, e Clicar com o Botão Direito novamente para recarregá-la, se necessário."]
			old: ["Espadas Estilhaçadas podem ser dropadas de Esqueletos Lonestar ou criadas usando as Lâminas dropadas. \\n\\nA Espada Estilhaçada é usada mais como um Tridente do que como uma Espada, em vez de bater, você a arremessa. Então, você pode Clicar com o Botão Direito para trazer a Lâmina de volta como um Tridente com Lealdade, e Clicar com o Botão Direito novamente para recarregá-la, se necessário."]
		}
		quest.40C776497D68367F.quest_desc: {
			new: ["Vinhas, &dMusgos de Cristal Vermelho &fe &bAzul em Carpete&r, &3Bagas Lunares&r, Musgo de Caverna e &dRaízes de Cristal Vermelhas &fe &bAzuis&r. \\n\\nEsses podem ser usados na sua Mão Secundária com o Olho Buscador para encontrar o &9Jardim Amaldiçoado&r."]
			old: ["Vinha, Tapetes de Musgo de Cristal Vermelho e Azul, Bagas Lunares, Musgo de Caverna e Raízes de Cristal Vermelho e Azul. \\n\\nEles podem ser usados na sua mão secundária com o Olho Perseguidor para encontrar o Jardim Amaldiçoado."]
		}
		quest.70A82A5D17D558FB.quest_desc: {
			new: ["A &bEspada de Energia&r só pode ser derrubada pelo &b&lGolem de Starlight&r. \\n\\nEla funciona como uma Espada normal, mas com Clique Direito você pode avançar até eles enquanto a balança, como o Genji de Overwatch! "]
			old: ["A Espada de Energia só pode ser dropada pelo Starlight Golem. \\n\\nEla funciona como uma Espada normal, mas com o Botão Direito você pode avançar em direção a eles enquanto a balança, como o Genji do Overwatch! "]
		}
		quest.252AD9C886DE45C8.title: {
			new: "&9Olhar do Crepúsculo"
			old: "Twilight Gaze"
		}
		quest.7FF77463F2A0E210.quest_desc: {
			new: ["A Lama do Anoitecer só pode ser encontrada nos &9Pântanos Escuros&r. \\n\\nVocê pode fazer mais Blocos com ela!"]
			old: ["Lama do Anoitecer só pode ser encontrada nos Pântanos Escuros. \\n\\nVocê pode fazer mais Blocos com ela!"]
		}
		quest.375F0A098589CF29.title: {
			new: "&bForja do Golem"
			old: "Forja do Golem"
		}
		quest.10AB188AC6FB24D3.quest_desc: {
			new: [
				"O &b&lGolem de Starlight&r tem 220 &4Corações&r e 2 Modos. \\n\\nO 1º modo é o modo de ataque; aqui ele não pode ser ferido, então você terá que esperar os ataques dele terminarem antes de acertá-lo. Ele ataca com Bolas de Fogo, Pancada no Chão ou um devastador Raio Laser! \\n\\nO 2º modo é o modo de carregamento; neste ele começará a receber energia dos Blocos de Energia, que precisarão ser desligados para poder causar dano nele. \\n\\nAo morrer, ele derrubará muitos Lingotes e Flechas, &bAço de Golem&r, Enfeite de Armadura da Forja, e talvez até a Espada de Energia!"
				"{image:atm:textures/questpics/eternal/starlight_golem.png width:150 height:100 align:center}"
			]
			old: [
				"O Starlight Golem tem 220 Corações e 2 Modos.\\n\\nO 1º modo é o seu modo de ataque, aqui ele não pode ser danificado, em vez disso, você terá que esperar que seus ataques terminem antes de atingi-lo. Ele ataca com Bolas de Fogo, Batida no Chão ou um devastador Raio Laser!\\n\\nSeu 2º modo é o seu modo de carregamento; neste, ele começará a pegar energia dos Blocos de Energia, que precisarão ser desligados para poder danificá-lo.\\n\\nAo morrer, ele dropará muitas Barras e Flechas, Aço de Golem, Ornamento de Armadura de Forja e talvez até a Espada de Energia!"
				"{image:atm:textures/questpics/eternal/starlight_golem.png width:150 height:100 align:center}"
			]
		}
		quest.0342248394E40B6A.quest_desc: {
			new: ["Esta Missão foi criada pela equipe do &6AllTheMods Staff&r, ou por um &2contribuidor da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes do &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público que não seja lançado pela equipe do &6AllTheMods Team&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isto, está no modo de edição."]
			old: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta, se você está vendo isso, está no modo de edição."]
		}
		quest.17D82EEA20D02EC8.quest_desc: {
			new: ["O fundo do &bMar&r é revestido com &5Cascalho Empoeirado&r. \\n\\nEle pode ser usado como substituto do &7Cascalho&r normal e raramente pode derrubar &5Fragmentos Empoeirados&r, que podem criar outros Blocos!"]
			old: ["Forrando o fundo do mar está o Cascalho Empoeirado. \\n\\nEle pode ser usado como um substituto para o Cascalho normal e pode raramente dropar Cacos Empoeirados que podem fazer outros Blocos!"]
		}
		quest.63362CC33B39C627.title: {
			new: "&bMar Estelar"
			old: "Mar Estrelado"
		}
		quest.40786B63E2901D11.quest_desc: {
			new: [
				"Vamos ver como eu descrevo o &9Jardim Amaldiçoado&r... é um labirinto enorme pra caramba! \\n\\nHá entradas em cada lado e você precisa encontrar o caminho até o meio, onde está a &9&lMonstruosidade Lunar&r!\\n\\nPor todo o labirinto você pode encontrar baús cheios de Saque e &9Tangled&r!"
				"{image:atm:textures/questpics/eternal/starlight_maze.png width:150 height:150 align:center}"
			]
			old: [
				"Deixe-me ver como descrevo o Jardim Amaldiçoado... é um labirinto gigante! \\n\\nHá entradas de cada lado e você deve encontrar o caminho para o meio, onde está a Monstruosidade Lunar! \\n\\nPor todo o labirinto você pode encontrar baús cheios de Saque e Emaranhados!"
				"{image:atm:textures/questpics/eternal/starlight_maze.png width:150 height:150 align:center}"
			]
		}
		quest.6314B892B569A0A5.quest_desc: {
			new: ["A &9&lStarlight&r! \\n\\nUma Dimensão onde é constantemente &9Crepúsculo&r, e não, você não pode mudar isso. \\n\\nHá dezenas de Biomas, Mobs, Chefes e até Blocos para encontrar! Você consegue descobrir todos?"]
			old: ["A Starlight! \\n\\nUma Dimensão onde é constantemente Crepúsculo, e não, você não pode mudar isso. \\n\\nHá dezenas de Biomas, Mobs, Chefes e até mesmo Blocos para encontrar! Você consegue descobrir todos eles?"]
		}
		quest.1AB17923F87AE264.quest_desc: {
			new: [
				"O Yeti é um nome que causa medo em todos os que exploram o frio! Uma criatura abominável e peluda que vive nos climas mais duros e gelados, comendo qualquer coisa que ouse passar por lá! \\n\\nBem, não este Yeti; estes são fofos e amigáveis! Eles preferem rolar por aí a te comer. \\n\\nCaramba, eles nem revidam e só têm 10 &4Corações&r. \\n\\nAo morrer, derrubarão seu Pelo e Linha, sendo que o primeiro pode ser usado como substituto para Lã."
				"{image:atm:textures/questpics/eternal/starlight_yeti.png width:100 height:100 align:center}"
			]
			old: [
				"O Yeti é um nome que causa medo em todos que exploram o Frio! Uma abominável criatura peluda que vive no clima mais frio e severo, comendo qualquer coisa que se atreva a se aventurar por lá! \\n\\nBem, não este Yeti, estes são fofos e amigáveis! Eles preferem rolar por aí do que te comer. \\n\\nEles nem mesmo revidam e só têm 10 Corações. \\n\\nNa morte, eles droparão sua Pele e Linha, a primeira pode ser usada como substituto para Lã."
				"{image:atm:textures/questpics/eternal/starlight_yeti.png width:100 height:100 align:center}"
			]
		}
		quest.68B2D3B985FC1378.quest_desc: {
			new: [
				"Uma Floresta brilhante e bela, cheia de &cÁrvores de Torreya&r e &eVinhas&r."
				"{image:atm:textures/questpics/eternal/starlight_torreya.png width:200 height:100 align:center}"
			]
			old: [
				"Uma Floresta brilhante e bela, cheia de Árvores Torreya e Vinhas."
				"{image:atm:textures/questpics/eternal/starlight_torreya.png width:200 height:100 align:center}"
			]
		}
		quest.362F4CFD1B8B12B1.quest_desc: {
			new: ["Todos os seres vivos morrerão no Éter como se ele fosse Lava. Curiosamente, você pode colocá-lo em um Balde. \\n\\nA única forma de obtê-lo é encontrando-o no Rio de Éter. \\n\\nQuando a Água toca o Éter, ela formará &aBlocos de Tioquartzo&r!"]
			old: ["Todos os seres vivos morrerão em Éter como se fosse Lava. Engraçado que você pode colocá-lo em um Balde, no entanto! \\n\\nA única maneira de obtê-lo é encontrando-o no Rio de Éter. \\n\\nQuando a Água toca o Éter, formará Blocos de Thioquartz!"]
		}
		quest.484ABFF266C8791E.quest_desc: {
			new: ["&eOrbiflora&r são plantas que crescem no fundo do &bMar&r. \\n\\nPodem ser colhidas a qualquer momento, mas se você quiser as &eLuzes de Orbiflora&r, terá que esperar! \\n\\nQuando crescerem até o Nível do Mar, florescerão. Depois de florescerem, crescerá a &eLuz&r!"]
			old: ["Orbflora são plantas que crescem do fundo do mar. \\n\\nElas podem ser colhidas a qualquer momento, mas se você quiser as Luzes de Orbflora, precisará esperar! \\n\\nQuando crescem até o Nível do Mar, elas florescem. Após a floração, elas crescerão a Luz!"]
		}
		quest.03B40AB768FC0161.title: {
			new: "&3Rio Cintilante"
			old: "Rio Cintilante"
		}
		quest.01F322AEFCC6109E.quest_desc: {
			new: ["Crânio Emaranhado podem ser obtidos de... bem, Crânio Emaranhado. \\n\\nEles podem ser usados como projétil, como uma Cabeça de Wither arremessada por um Wither. \\n\\nMas serão consumidos quando você fizer isso."]
			old: ["Tangled Skulls podem ser dropados de... bem, Tangled Skulls.\\n\\nEles podem ser usados como um projétil, como uma Cabeça de Wither lançada por um Wither.\\n\\nEle será consumido quando você fizer isso, no entanto."]
		}
		quest.49DC0BD7DC1B893C.title: {
			new: "&5O Abismo"
			old: "O Abismo"
		}
		quest.6EC289857CDC4969.title: {
			new: "&bEnts"
			old: "Ents"
		}
		quest.1815A439BA9879B7.quest_desc: {
			new: [
				"A &dCosta Quente&r é um Bioma bem sem graça e serve principalmente para conectar o &bMar Estelar&r à terra. \\n\\nEla tem &dAreia do Crepúsculo&r com Pedra abaixo dela. Também encontrei mais &eSalitra&r aqui do que o normal."
				"{image:atm:textures/questpics/eternal/starlight_shore.png width:200 height:100 align:center}"
			]
			old: [
				"A Costa Quente é um Bioma bem chato e serve principalmente para conectar o Mar Estrelado e a terra. \\n\\nTem Areia do Crepúsculo com Pedra por baixo. Eu também encontrei, mais do que o normal, Salitre aqui."
				"{image:atm:textures/questpics/eternal/starlight_shore.png width:200 height:100 align:center}"
			]
		}
		quest.29A1E1FF02BD9219.quest_desc: {
			new: [
				"Uma &3Floresta&r azul como o Oceano. \\n\\nA &3Floresta da Starlight&r é, de longe, o bioma mais comum na &9&lStarlight&r. \\n\\nEla tem dezenas de &3Árvores Lunares&r cobrindo tudo completamente, com muitos Mobs, passivos e hostis, abaixo delas."
				"{image:atm:textures/questpics/eternal/starlight_forest.png width:200 height:100 align:center}"
			]
			old: [
				"Uma Floresta tão azul quanto o Oceano. \\n\\nA Starlight Forest é de longe o bioma mais comum na Luz Estelar. \\n\\nEla tem dezenas de Árvores Lunares cobrindo-a inteiramente com muitos Mobs, passivos e hostis, abaixo dela."
				"{image:atm:textures/questpics/eternal/starlight_forest.png width:200 height:100 align:center}"
			]
		}
		quest.4147D247E4D754D0.quest_desc: {
			new: [
				"&7Sanguessuga Luminosa&r são pequenos mobs que surgem no &5Deserto Cristalizado&r. \\n\\nEles querem seu sangue sem descanso, e isso significa até por meios violentos. Felizmente, eles têm só 4 &4Corações&r! \\n\\nAo morrer, podem derrubar seus &7Ovos&r, que podem ser arremessados como projétil."
				"{image:atm:textures/questpics/eternal/starlight_gleech.png width:100 height:100 align:center}"
			]
			old: [
				"Gleeches são pequenos mobs que surgem no Deserto Cristalizado. \\n\\nEles querem seu sangue implacavelmente e isso significa até mesmo através de meios violentos. Felizmente, eles só têm 4 Corações! \\n\\nAo morrer, eles podem dropar seus Ovos, que podem ser arremessados como um projétil."
				"{image:atm:textures/questpics/eternal/starlight_gleech.png width:100 height:100 align:center}"
			]
		}
		quest.5466CB622A637DCD.quest_desc: {
			new: ["Fruta Abissal tecnicamente pode surgir em qualquer corpo de &9Água&r, mas é a única que vive dentro dos &3Rios Cintilantes&r. \\n\\nEla cresce como &2Alga&r, do chão para cima, mas também funciona como &eBagas Luminosas&r, no sentido de que a Fruta cresce e pode ser coletada dela."]
			old: ["A Fruta Abissal tecnicamente pode aparecer em qualquer corpo d'água, mas é a única que vive nos Rios Cintilantes. \\n\\nEla cresce como Kelp do chão para cima, mas também funciona como Glowberries, pois a Fruta cresce e pode ser coletada dela."]
		}
		quest.342EEB042DEC2B8C.quest_desc: {
			new: ["Magma e Gêiseres surgem no fundo de &5O Abismo&r. \\n\\nO Magma vai te ajudar a descer até lá embaixo e também a manter o fôlego. \\n\\nGêiseres só parecem legais!"]
			old: ["Magma e Gêiseres ambos aparecem no fundo do Abismo. \\n\\nMagma ajudará você a descer e a manter sua respiração. \\n\\nGêiseres apenas parecem legais!"]
		}
		quest.3D26E7BFE0AA964A.quest_desc: {
			new: [
				"O Peixe Luminária é um peixe brilhante que vive em &5O Abismo&r.\\n\\nEles agem como Peixes normais. Você pode pescá-los, colocá-los em um Balde e até cozinhá-los!"
				"{image:atm:textures/questpics/eternal/starlight_fish1.png width:100 height:100 align:center}"
			]
			old: [
				"O Luminofish é um Peixe Luminoso que vive no Abismo.\\n\\nEles agem como Peixes normais. Você pode pescá-los, colocá-los em um Balde, e pode até cozinhá-los!"
				"{image:atm:textures/questpics/eternal/starlight_fish1.png width:100 height:100 align:center}"
			]
		}
		quest.60FDCA2FDFE74056.title: {
			new: "&dFloresta Escarlate"
			old: "Floresta Escarlate"
		}
		quest.29A1E1FF02BD9219.title: {
			new: "&3Floresta da Starlight"
			old: "Starlight Forest"
		}
		quest.6EC289857CDC4969.quest_desc: {
			new: [
				"&bEnts&r são outro Mob pacífico que surge na Superfície da &9&lStarlight&r. Eles surgem nas florestas! \\n\\nEssas arvorezinhas podem derrubar Gravetos, &3Bagas Lunares&r e &3Folhas Lunares&r ao morrer. \\n\\nVocê pode usar &3Bagas Lunares&r para reproduzi-los!"
				"{image:atm:textures/questpics/eternal/starlight_ent.png width:100 height:100 align:center}"
			]
			old: [
				"Ents são outro Mob pacífico que surge na Superfície da Luz Estelar. Estes surgem nas florestas! \\n\\nEssas pequenas árvores podem dropar Gravetos, Bagas Lunares e Folhas Lunares ao morrer. \\n\\nVocê pode usar Bagas Lunares para procriá-los!"
				"{image:atm:textures/questpics/eternal/starlight_ent.png width:100 height:100 align:center}"
			]
		}
		quest.713EF442D59501BA.quest_desc: {
			new: ["A &5Corrente de &9Almas&r pode ser fabricada a partir de drops da &9&lMonstruosidade Lunar&r. \\n\\nÉ um gancho! Toque no Clique Direito para lançá-la e, quando atingir algo, começará a te puxar. Depois, você precisa Clicar com o Botão Direito de novo para soltá-la."]
			old: ["A Chain of Souls só pode ser criada a partir de drops do Tangled Hatred e da Lunar Monstrosity. \\n\\nÉ um gancho! Toque com o Botão Direito para enviá-lo e, assim que atingir algo, ele começará a te puxar. Então, você tem que clicar com o Botão Direito novamente para soltá-lo. \\n\\nTambém é necessário para a ATM Star!"]
		}
		quest.713548E540B18E07.quest_desc: {
			new: ["O &9Arco Moonring&r só pode ser derrubado pela &9&lMonstruosidade Lunar&r. \\n\\nEle dispara Flechas como um Arco normal, mas Espinhos do Chão virão na mesma direção em que a Flecha foi!"]
			old: ["O Moonring Bow só pode ser dropado pela Lunar Monstrosity. \\n\\nEle atira Flechas como um Arco normal, mas Espigões de Chão surgirão na mesma direção que a Flecha foi!"]
		}
		quest.50674FE3C6BE9990.title: {
			new: "&3Floresta Densa da Starlight"
			old: "Floresta Starlight Densa"
		}
		quest.4DBC3B4D38CC6152.title: {
			new: "&dMariposa Cristalizada"
			old: "Mariposa Cristalizada"
		}
		quest.7B5D34650BBD97D9.quest_desc: {
			new: ["&5Golpe Etéreo&r é Derrubado por &5Creteors&r e por &5Chuvas de Meteoros&r. \\n\\nA maioria das &5Chuvas de Meteoros&r derruba uma tonelada deles, então não se preocupe!"]
			old: ["Muito raramente na Dimensão da Luz Estrelar, uma Chuva de Meteoros pode ocorrer. \\n\\nA maioria das vezes os Meteoros são pequenos e desaparecem antes de atingir o chão. \\n\\nMas alguns são maiores e sobrevivem, lá você encontrará Minério de Aethersent!"]
		}
		quest.252AD9C886DE45C8.quest_desc: {
			new: [
				"&9Olhar do Crepúsculo&r são Peixes neutros localizados em &5O Abismo&r. \\n\\nSe você atingir um, todos irão te atacar, de forma semelhante a Lobos ou Piglins Zumbificados. Se você se afastar demais de &5O Abismo&r, eles vão parar de te seguir e voltar nadando para as profundezas. \\n\\nEles não derrubam nada ao morrer, então talvez não os ataque..."
				"{image:atm:textures/questpics/eternal/starlight_gaze.png width:150 height:100 align:center}"
			]
			old: [
				"Os Twilight Gaze são peixes neutros localizados no Abismo. \\n\\nSe você acertar um, todos atacarão você, semelhante a Lobos ou Porcos-zumbis. Se você se afastar muito do Abismo, eles pararão de segui-lo e nadarão de volta para as profundezas. \\n\\nEles não dropam nada ao morrer, então talvez não os acerte..."
				"{image:atm:textures/questpics/eternal/starlight_gaze.png width:150 height:100 align:center}"
			]
		}
		quest.29283BF1B6ED3634.quest_desc: {
			new: ["A &7Besta &3Mecânica&r é feita como uma Besta normal, só que com &bAço de Golem&r. \\n\\nEla funciona como uma Besta normal, só que muito mais forte! E pode ser encantada para fazer ainda mais!"]
			old: ["A Besta Mecânica é feita como uma Besta normal, só que com Aço de Golem. \\n\\nFunciona como uma Besta normal, só que muito mais forte! E pode ser encantada para fazer ainda mais!"]
		}
		quest.298963543B99734E.quest_desc: {
			new: ["Os &bMares Estelares&r geram suas próprias versões de Coral! \\n\\nSó não seja como eu e esqueça Toque Suave para coletá-los..."]
			old: ["Os Mares Estrelados geram suas próprias versões de Corais! \\n\\nSó não seja como eu e esqueça o Toque Suave para pegá-los..."]
		}
		quest.29EC143D7E0347DE.quest_desc: {
			new: ["A &8Adaga da Fome&r é feita com os &8Dentes da Fome&r. Não, eu não vou dizer Tooths. \\n\\nA &8Adaga&r tem um Valor de Fome. Quando você atinge Mobs, ele sobe; quando ela está inativa, diminui. Quando chega a 100%, você recebe bônus. E se cair para 0%, ela começará a te matar. \\n\\nQuando você atinge Mobs (ou Jogadores), ela também aplica o efeito de Fome. \\n\\nEu não a culpo; eu também fico bravo quando estou com fome."]
			old: ["A Adaga da Fome é feita com os Dentes da Fome. Não, não estou dizendo Dentes. \\n\\nA Adaga tem um Valor de Fome. Quando você atinge Mobs, ele sobe, quando está inativo, ele diminui. Quando chega a 100%, você recebe bônus. E se chegar a 0%, começará a te matar. \\n\\nQuando você atinge Mobs (ou Jogadores), também dará o efeito de Fome. \\n\\nEu não a culpo, eu também fico com raiva quando estou com fome."]
		}
		quest.7A16D2EB63359294.title: {
			new: "&3Cervos Aurora"
			old: "Cervo Aurora"
		}
		quest.429785E8F64929CE.title: {
			new: "O Guardião do Portal e o Portal"
			old: "O Guardião e o Portal"
		}
		quest.02B574B09AB45D09.quest_desc: {
			new: [
				"&bFreezes&r funcionam de forma parecida com &cBlazes&r, eles voam para cima e atiram uma bola em você. \\n\\nSó que &bFreezes&r lançam apenas 1 bola e ela vai te deixar com frio em vez de quente. \\n\\nEles têm 16 &4Corações&r e derrubam &bTubos Congelados&r ao morrer."
				"{image:atm:textures/questpics/eternal/starlight_freeze.png width:150 height:100 align:center}"
			]
			old: [
				"Freezes funcionam de forma semelhante aos Blazes, eles voam para cima e atiram uma bola em você.\\n\\nSó que os Freezes jogam apenas 1 bola e ela vai te deixar com frio em vez de quente.\\n\\nEles têm 16 Corações e droparão Tubos Congelados ao morrer."
				"{image:atm:textures/questpics/eternal/starlight_freeze.png width:150 height:100 align:center}"
			]
		}
		quest.0576C32B0FB360B0.title: {
			new: "&9&lMonstruosidade Lunar"
			old: "Monstruosidade Lunar"
		}
		quest.2F3E7233129F2B89.quest_desc: {
			new: [
				"Funciona exatamente como um Peixe Luminária, só que estes têm um chifre na cabeça!"
				"{image:atm:textures/questpics/eternal/starlight_fish2.png width:100 height:100 align:center}"
			]
			old: [
				"Age exatamente como um Luminofish, só que estes têm um chifre na cabeça!"
				"{image:atm:textures/questpics/eternal/starlight_fish2.png width:100 height:100 align:center}"
			]
		}
		quest.5424A0E1292B13EE.quest_desc: {
			new: ["Pela &9&lStarlight&r você pode encontrar Lagos Quentes. \\n\\n(Eles não são um bioma nem uma estrutura, então você vai precisar apenas procurar para encontrá-los!) \\n\\nDentro deles você pode encontrar &6Pedra Primaveril Térmica&r."]
			old: ["Perto da Starlight você pode encontrar Lagoas Quentes. \\n\\n(Estes não são um bioma ou estrutura, então você precisará apenas procurar para encontrá-los!) \\n\\nDentro delas você pode encontrar Pedra de Fonte Termal."]
		}
		quest.1815A439BA9879B7.title: {
			new: "&dCosta Quente"
			old: "Costa Quente"
		}
		quest.3CAD0701EC16C2D8.title: {
			new: "&9Pântano Escuro"
			old: "Pântano Escuro"
		}
		quest.4147D247E4D754D0.title: {
			new: "&7Sanguessuga Luminosa"
			old: "Gleech"
		}
		quest.7D7BD1458CF12021.quest_desc: {
			new: ["É um Deserto, claro que há &5Cactos&r! \\n\\nOs &5Cactos&r, quando totalmente crescidos, podem dar Fruta no topo deles!"]
			old: ["É um Deserto, claro que há Cactos! \\n\\nOs Cactos, quando totalmente crescidos, podem dar Frutos no topo!"]
		}
		quest.36BCCF7395658A5C.quest_desc: {
			new: ["Os Chefes da &9&lStarlight&r vivem em suas estruturas. Elas não são comuns (ainda bem), então você pode precisar de ajuda, também conhecida como Olhos Buscadores. \\n\\nOlhos Buscadores funcionam como &aOlhos de Ender&r; Clique com o Botão Direito com eles para arremessá-los e siga-os para chegar às estruturas. \\n\\nPara definir a estrutura, você precisará de um certo Item na sua Mão Secundária, itens como..."]
			old: ["Os Chefes no Starlight vivem em suas estruturas. Elas não são comuns (felizmente), então você pode precisar de ajuda, também conhecida como os Olhos Rastreadores. \\n\\nOs Olhos Rastreadores funcionam como os Olhos do End, Clique com o Botão Direito com eles para lançá-los e siga-os para chegar às estruturas. \\n\\nPara definir a estrutura, você precisará de um certo Item em sua mão secundária, itens como..."]
		}
		quest.5DFE3CB5B0130A7A.quest_desc: {
			new: ["Há muita vida vegetal sobre o &3Rio Cintilante&r, algumas nas quais você pode ficar em pé!"]
			old: ["Há muita vida vegetal no topo do Rio Cintilante, em algumas você pode ficar de pé!"]
		}
		quest.4D4DE266A2A325B0.quest_desc: {
			new: ["&4Redstone&r, &bAço de Golem&r e &8Aço de Golem Oxidado&r são Itens usados para encontrar a &bForja do Golem&r. \\n\\nSegure um desses (muito provavelmente &4Redstone&r, que realmente surge no subsolo da &9&lStarlight&r) na sua Mão Secundária e use o Olho Buscador para encontrar a &bForja do Golem&r, que, aliás, fica no subsolo!"]
			old: ["Redstone, Aço de Golem e Aço de Golem Oxidado são Itens usados para encontrar a Forja de Golem. \\n\\nSegure um desses (mais provavelmente Redstone que aparece no subterrâneo de Starlight) em sua mão secundária e use o Olho Inquieto para encontrar a Forja de Golem que, a propósito, é subterrânea!"]
		}
		quest.144ECED643031A9A.quest_desc: {
			new: ["Cogumelos Brilhantes são enormes plantas de Cogumelo que você pode encontrar nas Florestas Escarlates! \\n\\nEles funcionam como Cogumelos Marrons ou Vermelhos, só que estes brilham muito mais! \\n\\n(Caso você não soubesse, Cogumelos Marrons e Vermelhos na verdade emitem um nível de Luz de 1)."]
			old: ["Cogumelos Luminosos são enormes plantas de Cogumelo que você pode encontrar nas Florestas Escarlates! \\n\\nEles funcionam como Cogumelos Marrons ou Vermelhos, só que estes Brilham muito mais! \\n\\n(Se você não sabia, Cogumelos Marrons e Vermelhos na verdade emitem uma fonte de Luz de nível 1)."]
		}
		quest.4DBC3B4D38CC6152.quest_desc: {
			new: [
				"&dMariposa Cristalizada&r surgem bem abaixo dos &5Desertos Cristalizados&r. \\n\\nElas são neutras e eu recomendo não bater nelas porque causam um monte de dano! \\n\\nElas também têm 10 &4Corações&r e podem derrubar &bCristais da Starlight&r ou &9Gel Trêmulo&r ao morrer. \\n\\nEsses belos rapazes e moças podem ser Domesticados ao alimentá-los com Carne! Depois, lutarão por você."
				"{image:atm:textures/questpics/eternal/starlight_moth.png width:125 height:100 align:center}"
			]
			old: [
				"Mariposas Cristalizadas aparecem nas profundezas dos Desertos Cristalizados. \\n\\nElas são neutras e eu recomendo não atacá-las porque elas causam muito dano! \\n\\nElas também têm 10 Corações e podem derrubar Cristais de Starlight ou Gel Trêmulo na morte."
				"{image:atm:textures/questpics/eternal/starlight_moth.png width:125 height:100 align:center}"
			]
		}
		quest.4A54288FD22C903D.quest_desc: {
			new: ["&2Velvetumoss&r surge em &5O Abismo&r. \\n\\nVocê pode minerar os verdes para obter &2Bolas de Velvetumoss&r, que podem ser comidas ou transformadas em uma &aBola de Slime&r! \\n\\nOs &4Vermelhos&r irão gerar plantas bonitas!"]
			old: ["Velvetumoss surge dentro do Abismo. \\n\\nVocê pode minerar os verdes para obter Bolas de Velvetumoss, que podem ser comidas ou transformadas em uma Bola de Slime! \\n\\nOs vermelhos gerarão plantas bonitas!"]
		}
		quest.7FBB431AC055FE93.quest_desc: {
			new: ["O &7Espectador Iluminado pela Alma&r é fabricado com um &9Orvalho da Alma&r e um &9Olho de Aranha do Anoitecer&r. \\n\\nEle funciona de forma semelhante a uma Câmera Pegajosa de Tom Clancy's Splinter Cell. Você pode Clicar com o Botão Direito para enviar o &7Espectador&r e, depois de um tempo, poderá enxergar através dele. Você pode até se ver com ele! \\n\\nNão dá para encerrá-lo antes, então cuidado ao usar. Ele também tem durabilidade e tempo de recarga."]
			old: ["O Espectador Soulit é criado com uma Alma Aprisionada e um Olho de Aranha do Anoitecer. \\n\\nFunciona de forma semelhante a uma Câmera Adesiva de Tom Clancy's Splinter Cell. Você pode Clicar com o Botão Direito para enviar o Espectador e, após um tempo, poderá ver através dele. Você pode até se ver com ele! \\n\\nNão pode ser encerrado antes do tempo, então cuidado ao usá-lo. Ele também tem durabilidade e tempo de recarga."]
		}
		quest.40786B63E2901D11.title: {
			new: "&9Jardim Amaldiçoado"
			old: "Jardim Amaldiçoado"
		}
		quest.2DA8CE213AC3869B.quest_desc: {
			new: ["&bCristais da Starlight&r podem ser encontrados por toda parte e até sob os &5Desertos Cristalizados&r. \\n\\nEles funcionam de forma parecida com a &5Ametista&r e até soam como ela!"]
			old: ["Cristais de Luz Estelar podem ser encontrados por todo e até mesmo sob os Desertos Cristalizados. \\n\\nEles funcionam de forma semelhante à Ametista e até soam como ela!"]
		}
		quest.1ECD4331DDFBBB52.quest_desc: {
			new: ["&cÁrvores de Torreya&r são árvores roxas/rosas enormes que chegam a cerca de 40 Blocos de altura. \\n\\nAs Folhas brotam em todas as direções e as &eVinhas de Torreya&r ficam penduradas nelas."]
			old: ["As Árvores Torreya são árvores enormes, roxas/rosas, que têm cerca de 40 blocos de altura. \\n\\nAs folhas brotam em todas as direções e as Vinhas de Torreya pendem delas."]
		}
		quest.02B574B09AB45D09.title: {
			new: "&bFreeze"
			old: "Congelar"
		}
		quest.6E970CF05B96EB20.quest_desc: {
			new: ["Para causar dano ao &b&lGolem&r, você precisará desligar a fonte de energia dele! \\n\\nPara isso, você precisará Clicar com o Botão Direito nos Blocos de Energia quando eles ficarem azuis. \\n\\nNormalmente, você pode encontrar 2 nos cantos da sala do chefe e 2 acima dele!"]
			old: ["Para danificar o Golem, você precisará desligar sua fonte de energia! \\n\\nPara fazer isso, você precisará Clicar com o Botão Direito nos Blocos de Energia quando eles ficarem azuis. \\n\\nVocê geralmente pode encontrar 2 nos cantos da sala do chefe e 2 acima dele!"]
		}
		quest.3C74DAE7EC844A98.quest_desc: {
			new: ["As &3Bagas Lunares&r são uma excelente Fonte de Comida, além de muito fáceis de obter! \\n\\nElas surgem crescendo para baixo a partir das &3Folhas da Árvore Lunar&r; você pode colher as &3Bagas&r das Vinhas como &eBagas Luminosas&r. \\nSó que estas dão muito mais Pontos de Comida e Saturação!"]
			old: ["As Bagas Lunares são uma excelente fonte de comida, além de serem muito fáceis de obter! \\n\\nElas crescem para baixo das Folhas de Árvore Lunar, você pode colher as Bagas das Vinhas como as Bagas Luminosass. \\nSó que estas dão muito mais Pontos de Fome e Saturação!"]
		}
		quest.375F0A098589CF29.quest_desc: {
			new: [
				"Usando seus Olhos Buscadores, você pode ficar confuso ao ver que eles de repente foram para o subsolo. Isso provavelmente acontece porque a &bForja do Golem&r fica bem no subsolo, tipo nos níveis Y negativos. \\n\\nHá muitas salas sinuosas, cada uma cheia de Saque, &cLava&f e &bFreezes&r! A sala que estamos procurando abriga o &b&lGolem de Starlight&r!"
				"{image:atm:textures/questpics/eternal/starlight_golemforge.png width:200 height:100 align:center}"
			]
			old: [
				"Usando seus Olhos Buscadores, você pode ficar confuso por que eles de repente foram para o subsolo. Isso provavelmente ocorre porque a Forja do Golem está nas profundezas do subsolo, como nos níveis Y negativos. \\n\\nHá muitas salas sinuosas, cada uma cheia de Saques, Lava e Congelamentos! A sala que estamos procurando abriga o Golem da Luz Estrelar!"
				"{image:atm:textures/questpics/eternal/starlight_golemforge.png width:200 height:100 align:center}"
			]
		}
		quest.2D457E53BB6D63C7.title: {
			new: "Floresta de Gelo Eterno"
			old: "Floresta de Permafrost"
		}
		quest.4D0B50731FED3CEE.quest_desc: {
			new: ["Para conseguir a Lança Cresant, você precisará fabricá-la a partir de Itens derrubados pela Monstruosidade Lunar e pelo Ódio Tangled, ou consegui-la como drop da Monstruosidade Lunar. (Basicamente, você terá que matá-lo de qualquer forma). \\n\\nVocê pode usar a Lança como um Tridente e simplesmente bater nos Mobs, ou segurar o Clique Direito para ser lançado para frente com ela. Se atingir qualquer Mob com o segundo ataque, quaisquer Mobs próximos também receberão dano."]
			old: ["Para obter a Lança Crescente, você precisará fabricá-la a partir de Itens derrubados pela Monstruosidade Lunar e pelo Ódio Emaranhado, ou tê-la derrubada pela Monstruosidade Lunar. (Você terá que matá-lo de qualquer maneira, basicamente). \\n\\nVocê pode usar a Lança como um Tridente e apenas bater nos Mobs ou pode segurar o Clique Direito para ser lançado para a frente com ela. Se você atingir algum Mob com o segundo ataque, qualquer Mob próximo também sofrerá dano."]
		}
		quest.3CAD0701EC16C2D8.quest_desc: {
			new: [
				"&9Pântanos Escuros&r cobrem o mundo da &9&lStarlight&r. \\n\\nAqui você pode encontrar muitas plantas, animais e, claro, Lama."
				"{image:atm:textures/questpics/eternal/starlight_swamp.png width:200 height:100 align:center}"
			]
			old: [
				"Pântanos Escuros cobrem o mundo do Starlight. \\n\\nAqui você pode encontrar muitas plantas, animais e, claro, Lama."
				"{image:atm:textures/questpics/eternal/starlight_swamp.png width:200 height:100 align:center}"
			]
		}
		quest.3D26E7BFE0AA964A.title: {
			new: "Peixe Luminária"
			old: "Luminofish"
		}
		quest.68B2D3B985FC1378.title: {
			new: "&cFloresta de Torreya"
			old: "Floresta Torreya"
		}
		quest.636848ED1115A0B3.title: {
			new: "&8Ratlins"
			old: "Ratlins"
		}
		quest.6314B892B569A0A5.title: {
			new: "&9&lStarlight Eterna"
			old: "Eternal Starlight"
		}
		quest.3991EEEFDD263A91.title: {
			new: "&9Aranhas do Anoitecer"
			old: "Aranhas do Crepúsculo"
		}
		quest.6B00D5DBB3552F15.title: {
			new: "&9Tangled"
			old: "Tangled"
		}
		quest.6B00D5DBB3552F15.quest_desc: {
			new: [
				"&9Tangled&r são inimigos que surgem no &9Jardim Amaldiçoado&r. \\n\\nEles têm 10 &4Corações&r e atacam te acertando. Se você for atingido, receberá uma pequena quantidade de Veneno. \\n\\nAo morrer, derrubarão Vinhas e Ossos, mas também surgirá um Crânio Tangled! \\n\\nCrânio Emaranhado agem de forma parecida com Vexes; eles voarão atravessando blocos e te acertarão. Eles têm apenas 5 &4Corações&r e, ao morrer, te darão a si mesmos como Item."
				"{image:atm:textures/questpics/eternal/starlight_tangled.png width:150 height:100 align:center}"
			]
			old: [
				"Tangleds são inimigos que surgem no Jardim Amaldiçoado. \\n\\nEles têm 10 Corações e atacarão dando tapas em você. Se você for atingido, receberá uma pequena quantidade de veneno. \\n\\nAo morrer, eles droparão Vinhas e Ossos, mas também gerarão uma Caveira de Tangled! \\n\\nAs Caveiras de Tangled agem de forma semelhante aos Vexes, voarão através de blocos e o atingirão. Elas têm apenas 5 Corações e, ao morrer, lhe darão elas como um Item."
				"{image:atm:textures/questpics/eternal/starlight_tangled.png width:150 height:100 align:center}"
			]
		}
		quest.50674FE3C6BE9990.quest_desc: {
			new: [
				"Assim como a &3Floresta da Starlight&r normal, só que com muito menos espaçamento entre as Árvores!"
				"{image:atm:textures/questpics/eternal/starlight_dense.png width:200 height:100 align:center}"
			]
			old: [
				"Assim como a Floresta Starlight normal, só que com muito menos espaçamento entre as Árvores!"
				"{image:atm:textures/questpics/eternal/starlight_dense.png width:200 height:100 align:center}"
			]
		}
		quest.00453FF528AA0B1C.quest_desc: {
			new: ["&7Esqueletos Lonestar&r são Mobs hostis que podem surgir em qualquer lugar. \\n\\nEles têm 10 &4Corações&r e arremessam sua Espada em você para atacar. \\n\\nAo morrer, podem derrubar Ossos, &7Pepitas de Prata Abissal&r e &7Espadas Estilhaçadas&r."]
			old: ["Esqueletos Lonestar são Mobs hostis que podem aparecer em qualquer lugar.\\n\\nEles têm 10 Corações e jogarão sua Espada em você para atacá-lo.\\n\\nAo morrer, eles podem dropar Ossos, Pepitas de Prata do Pântano, Espadas Quebradas e os drops adicionados por Corail para Mobs Mortos-Vivos."]
		}
		quest.3991EEEFDD263A91.quest_desc: {
			new: [
				"&9Aranhas do Anoitecer&r, como os &7Esqueletos Lonestar&r, são hostis e surgem em qualquer lugar. \\n\\nElas têm 5 &4Corações&r e atacam te acertando. Depois de te atingir, vão te dar o efeito de Brilho por alguns segundos. \\n\\nAo morrer, derrubarão Linha e seus olhos!"
				"{image:atm:textures/questpics/eternal/starlight_spider.png width:100 height:100 align:center}"
			]
			old: [
				"Aranhas do Crepúsculo, como Esqueletos da Estrela Solitária, são Hostis e aparecem em qualquer lugar. \\n\\nElas têm 5 Corações e atacam te atingindo. Depois de te atingir, elas lhe darão o efeito de Brilho por alguns segundos. \\n\\nNa morte, elas droparão Linha e seus olhos!"
				"{image:atm:textures/questpics/eternal/starlight_spider.png width:100 height:100 align:center}"
			]
		}
		quest.127D085D6C9DB690.quest_desc: {
			new: ["&eSalitra&r pode ser encontrado em qualquer lugar Subterrâneo, mas é muito comum no Bioma da &dCosta Quente&r. \\n\\nEle precisa de uma Picareta de Pedra para ser minerado e, quando minerado, derrubará um pouco de &ePó de Salitra&r. Sim, Fortuna funciona nele! \\n\\nO &ePó&r pode ser usado como substituto para outros Nitros."]
			old: ["O salitre pode ser encontrado em qualquer lugar subterrâneo, mas é muito comum no Bioma de Costa Quente.\\n\\nÉ preciso uma Picareta de Pedra para minerá-lo e, quando minerado, ele dropa um pouco de Pó de Salitre. Sim, Fortuna funciona nele!\\n\\nO Pó pode ser usado como substituto para outros Nitratos."]
		}
		quest.49D1EA8E812A12F6.quest_desc: {
			new: ["É só uma plantinha legal. \\n\\nVocê vai precisar de uma Foice para coletá-la! \\n\\nNão sei por quê, nunca liguei para plantas, mas Juncos são legais para mim. Talvez seja por estarem perto da &9Água&r, ou porque Taboas parecem Cachorros-Quentes de Milho. Não sei, mas eu gosto deles."]
			old: ["É apenas uma planta legal. \\n\\nVocê precisará de uma Foice de Prata do Pântano para coletá-la! \\n\\nNão sei por que nunca me importei com plantas, mas Juncos são legais para mim. Talvez seja por estarem perto da Água, ou por Taboas parecerem Corndogs. Não sei, mas eu gosto deles."]
		}
		quest.2D457E53BB6D63C7.quest_desc: {
			new: [
				"Os pontos mais altos da &9&lStarlight&r são as Florestas de Gelo Eterno, que ficam sobre Montanhas. \\n\\nEstar tão alto as torna muito mais frias, deixando-as cobertas de Neve e Gelo! \\n\\nPelo menos os Mobs amigáveis parecem gostar do frio!"
				"{image:atm:textures/questpics/eternal/starlight_permafrost.png width:200 height:100 align:center}"
			]
			old: [
				"Os pontos mais altos da Luz Estelar são as Florestas de Permafrost que se encontram sobre as Montanhas. \\n\\nEstar tão alto as torna muito mais frias, cobrindo-as de Neve e Gelo! \\n\\nPelo menos os Mobs amigáveis parecem gostar do Frio!"
				"{image:atm:textures/questpics/eternal/starlight_permafrost.png width:200 height:100 align:center}"
			]
		}
		quest.41C70F0873E14307.quest_desc: {
			new: ["Há Árvores no Deserto! \\n\\nNão, espera, havia Árvores..."]
			old: ["Há Árvores no Deserto! \\n\\nNão, espere, havia Árvores..."]
		}
		quest.0F0D41F29386333A.quest_desc: {
			new: ["&dÁrvores Escarlates&r variam em tamanho e forma e às vezes até estão caídas! \\n\\nMas todas têm &dFolhas rosas&r! Inclusive as que estão no chão."]
			old: ["As Árvores Escarlates variam em tamanho e forma e às vezes até caem!\\n\\nMas todas têm folhas rosas! Incluindo as que estão no chão."]
		}
		quest.0C096EE635645E43.quest_desc: {
			new: ["A &dBesta de Cristal&r é fabricada como uma &7Besta &3Mecânica&r, só que com &bCristais&r em vez de gravetos. \\n\\nEla dispara Flechas e causa o mesmo dano que uma Besta normal, mas esta dá Infecção de Cristal. Infecção de Cristal causa 1 de dano por segundo com os Cristais que surgem neles! E sim, isso vai matá-los."]
			old: ["A Besta de Cristal é fabricada como uma Besta Mecânica, só que com Cristais em vez de gravetos.\\n\\nEla atira Flechas e causa o mesmo dano que uma Besta normal, mas esta causa Infecção de Cristal. A Infecção de Cristal causa 1 de dano a cada segundo com os Cristais que aparecem neles! E sim, isso os matará."]
		}
		quest.0F4783FA019C4567.quest_desc: {
			new: ["&4Âmbaramarelos&r é encontrado raramente ao descascar &cTroncos de Torreya&r. \\n\\nEle pode ser transformado em Lingotes para fazer Armaduras e Ferramentas, ou usado em outras receitas, como uma fogueira que vai te dar regeneração!"]
			old: ["Amaranto é encontrado raramente ao descascar Troncos de Torreya.\\n\\nPode ser transformado em Barras para fazer Armaduras e Ferramentas ou usado em outras receitas como uma fogueira que lhe dará regeneração!"]
		}
		quest.5244B2D6B5FA0487.quest_desc: {
			new: [
				"O &5Deserto Cristalizado&r parece um Deserto normal, mas com tom &5Roxo&r. \\n\\nTambém com cristais gigantes adicionados; não acho que Desertos normais tenham isso..."
				"{image:atm:textures/questpics/eternal/starlight_desert.png width:200 height:100 align:center}"
			]
			old: [
				"O Deserto Cristalizado parece um Deserto normal, mas com tons de Roxo. \\n\\nTambém com cristais gigantes adicionados, eu não acho que Desertos normais tenham isso..."
				"{image:atm:textures/questpics/eternal/starlight_desert.png width:200 height:100 align:center}"
			]
		}
		quest.4C23D7E3DC8327C2.quest_desc: {
			new: ["Para matar a &9&lMonstruosidade Lunar&r, você precisará colocá-la em chamas! \\n\\nVocê pode usar Pederneira e Aço ou uma &eCaixa de Fósforos de Salitra&r. \\n\\nPessoalmente, acho a &eCaixa de Fósforos&r mais apropriada!"]
			old: ["Para matar a Monstruosidade Lunar, você precisará incendiá-la! \\n\\nVocê pode usar Pederneira e Isqueiro ou uma Caixa de Fósforos de Salitre. \\n\\nPessoalmente, acho que a Caixa de Fósforos é mais adequada!"]
		}
		quest.7E90138B0A2C3210.quest_desc: {
			new: ["As Árvores Northland são Árvores grandes e robustas nas Florestas de Gelo Eterno. \\n\\nElas parecem Abetos, mas muito mais claras! Talvez sejam Abetos albinos. \\n\\nSuas mudas precisam ser colocadas na Terra, não na Grama, e em uma formação 2x2."]
			old: ["As Árvores da Terra do Norte são árvores grandes e robustas nas Florestas de Permafrost. \\n\\nElas parecem Abetos, mas muito mais claras! Talvez sejam um Abeto albino. \\n\\nSuas mudas precisam ser plantadas na Terra, não na Grama, e em uma formação 2x2."]
		}
		quest.4D4DE266A2A325B0.title: {
			new: "&lItens do &bGolem&r"
			old: "Itens de Golem"
		}
		quest.4D53D9BBD8279282.quest_desc: {
			new: ["&3Árvores Lunares&r podem variar de enormes &3Árvores&r imponentes a pequeninas. Elas se adaptam para ocupar o máximo de espaço possível! (Isso explicaria as &3Florestas Densas&r). \\n\\nElas são plantadas como Mudas normais e podem ter &3Bagas Lunares&r surgindo em suas folhas!"]
			old: ["As Árvores Lunares podem variar de árvores imponentes e gigantescas a pequeninas. Elas se adaptam para ocupar o máximo de espaço possível! (Isso explicaria as Florestas Densas). \\n\\nElas são plantadas como mudas normais e podem ter Bagas Lunares surgindo de suas folhas!"]
		}
		quest.62F33BBE7BDFE404.quest_desc: {
			new: ["&5Varinha de &bTeleportação&r é outro drop da &9Monstruosidade Lunar&r, e só dela! \\n\\nVocê pode segurar o Clique Direito com a Varinha para iniciá-la; então, quando soltar, ela te teleportará para o Bloco para o qual você estava olhando por último! \\n\\nHá um alcance, mas é bem grande. E há um tempo de recarga após o uso!"]
			old: ["A Varinha de Teletransporte é outra queda da Monstruosidade Lunar, e apenas dela! \\n\\nVocê pode segurar o botão direito com a Varinha para iniciá-la, então, quando soltar, ela o teleportará para o Bloco que você estava olhando por último! \\n\\nHá um alcance, mas é bem longe. E há um tempo de recarga após o uso!"]
		}
		quest.2E29DC243E8AD61E.title: {
			new: "&9Asa-de-renda Cintilante"
			old: "Shimmer Lacewing"
		}
		quest.00453FF528AA0B1C.title: {
			new: "&7Esqueletos Lonestar"
			old: "Esqueletos Lonestar"
		}
		quest.516AC1F0E0BCAE55.quest_desc: {
			new: ["&bTubos Congelados&r são derrubados por &bFreezes&r na &bForja do Golem&r. \\n\\nEles podem ser arremessados como Poções para machucar quem quer que atinjam."]
			old: ["Tubos Congelados são dropados por Freezes na Forja de Golem. \\n\\nEles podem ser arremessados como Poções para ferir quem for atingido."]
		}
		quest.54DE8AAAE2181F18.quest_desc: {
			new: ["O &dMontante do Anel Lunar&r não precisa mais de Drops de ambos os Chefes; agora ele só precisa que você mate a &9&lMonstruosidade Lunar&r. \\n\\nEle funciona como uma Espada normal, só que antes da 1.9. Ele pode bloquear ataques como um escudo, mas não pode ser usado sem parar para causar dano total."]
			old: ["A Moonring Greatsword precisa ser criada a partir de drops de ambos os Chefes! Obviamente, tornando-a a mais difícil de obter e a mais poderosa! \\n\\nEla funciona como uma Espada normal, pouco antes da 1.9. Ela pode bloquear ataques como um escudo, mas não pode ser usada repetidamente para dano total."]
		}
		quest.60FDCA2FDFE74056.quest_desc: {
			new: [
				"É &dROSA&r! \\n\\nAqui você encontrará &dÁrvores Escarlates&r com suas folhas caídas amontoadas sob elas. Você também pode encontrar Cogumelos Brilhantes aqui!"
				"{image:atm:textures/questpics/eternal/starlight_scarlet.png width:200 height:100 align:center}"
			]
			old: [
				"É ROSA! \\n\\nAqui você encontrará Árvores Escarlates com suas folhas caídas empilhadas abaixo delas. Você também pode encontrar Cogumelos Luminosos aqui!"
				"{image:atm:textures/questpics/eternal/starlight_scarlet.png width:200 height:100 align:center}"
			]
		}
		quest.25E782DB4309A1B8.quest_desc: {
			new: ["&3Galhadas de Cervos Aurora&r são derrubadas por &3Cervos Aurora&r ao morrer. \\n\\nPodem ser usadas como Espada ou Enxada."]
			old: ["Galhadas de Aurora Deer são dropadas por Aurora Deers ao morrer. \\n\\nPode ser usado como uma Espada ou uma Enxada."]
		}
		quest.7A16D2EB63359294.quest_desc: {
			new: [
				"&3Cervos Aurora&r são animais amistosos com casco que também vivem no frio. \\n\\nEsses &3Cervos&r não vão tentar te machucar, mas se você ficar na frente quando eles correrem, talvez sinta alguns &3Chifres&r. \\n\\n&3Chifres&r que também podem ser derrubados por eles ao morrer e podem ser usados tanto como arma quanto como enxada! \\n\\nEles também podem derrubar Couro ou Bife de Cervo Aurora."
				"{image:atm:textures/questpics/eternal/starlight_deer.png width:200 height:100 align:center}"
			]
			old: [
				"Cervos Aurora são animais de casco amigáveis que também vivem no frio. \\n\\nEstes Cervos não tentarão te machucar, mas se você ficar no caminho deles quando correm, pode sentir alguns Chifres. \\n\\nChifres que também podem ser dropados por eles na morte e podem ser usados como arma ou enxada! \\n\\nEles também podem dropar Couro ou Bife de Cervo Aurora."
				"{image:atm:textures/questpics/eternal/starlight_deer.png width:200 height:100 align:center}"
			]
		}
		quest.17EC65B33AC5F0B4.title: {
			new: "&8Andarilho Sedento"
			old: "Andarilho da Sede"
		}
		quest.429785E8F64929CE.quest_desc: {
			new: ["Para chegar à &9&lDimensão da Starlight&r, você precisará encontrar &7Ruínas de Portal&r na &2&lSuperfície&r. \\n\\nLá você encontrará um &7&lGuardião do Portal&r; Clique com o Botão Direito para iniciar uma conversa e desafiá-lo para um duelo! Cuidado, eles são bem fortes. \\n\\nAssim que vencer o duelo, você receberá alguns Itens, sendo o &3Orbe da Profecia&r um deles. Clique com o Botão Direito no &7Portal&r com o &3Orbe&r para ativá-lo! Depois, entre para chegar à..."]
			old: ["Para chegar à Dimensão Starlight, você precisará encontrar Ruínas do Portal no Mundo Superior. \\n\\nLá você encontrará um Guardião do Portal, clique com o botão direito para iniciar uma conversa e desafiá-lo para um duelo! Cuidado, eles são muito difíceis. \\n\\nAssim que vencer o duelo, você receberá alguns Itens, sendo o Orbe da Profecia um deles. Clique com o botão direito no Portal com o Orbe para ativá-lo! Então, entre para chegar ao..."]
		}
		quest.40C776497D68367F.title: {
			new: "&9Itens da &lMonstruosidade&r"
			old: "Itens da Monstruosidade"
		}
		quest.15195F456D8AD4C8.quest_desc: {
			new: ["Quando o Éter toca a &9Água&r, &aTioquartzo&r se forma. Isso pode acontecer naturalmente com a geração aleatória ou você pode fazer acontecer! \\n\\nMas não é assim que conseguimos Fragmentos; eles vêm da &aDrusa de Tioquartzo&r!"]
			old: ["Quando Éter toca Água, Tioquartzo se formará. Isso pode acontecer naturalmente com a geração aleatória ou você pode fazer acontecer! \\n\\nNão é assim que conseguimos Fragmentos, no entanto, esses vêm do Tioquartzo em Brotação!"]
		}
		quest.37355F60E45777FE.quest_desc: {
			new: ["O &3Orbe da Profecia&r pode ser fabricado ou obtido ao derrotar o &7&lGuardião do Portal&r! \\n\\nSeu principal uso é ativar o Portal, mas haverá mais utilidades para ele!"]
			old: ["O Orbe da Profecia pode ser criado ou obtido ao vencer o Gatekeeper! \\n\\nSeu uso principal é ativar o Portal, mas haverá mais usos para ele!"]
		}
		quest.3D4032E7119AF8B7.quest_desc: {
			new: ["&5Bombas Sônica&r são feitas com &9Gel Trêmulo&r, que é derrubado por &dMariposa Cristalizada&r. \\n\\nElas podem ser arremessadas para causar dano a qualquer Mob (e Jogador) em uma área enorme! Também vão sacudir a tela dos jogadores e tocar um efeito sonoro alto. \\n\\nÉ desorientador, então use só nos seus amigos!"]
			old: ["Bombas Sonares são feitas com Gel Trêmulo, que é dropado de Mariposas Cristalizadas. \\n\\nElas podem ser arremessadas para danificar qualquer Mob (e Jogador) em uma área enorme! Também irá sacudir a tela dos jogadores e tocar um efeito sonoro alto. \\n\\nÉ desorientador, então use apenas em seus amigos!"]
		}
		quest.49DC0BD7DC1B893C.quest_desc: {
			new: ["&5O Abismo&r são trincheiras profundas dentro dos &bMares Estelares&r. Elas chegam até -50! \\n\\nElas têm várias camadas coloridas de Pedra revestindo-as e guardam muitos Blocos, Musgos e Peixes diferentes!"]
			old: ["O Abismo são fossas profundas dentro dos Mares Estrelados. Estas indo tão fundo quanto -50! \\n\\nEles têm várias camadas coloridas de Pedra que os revestem e abrigam muitos Blocos, Musgos e Peixes diferentes!"]
		}
		quest.10AB188AC6FB24D3.title: {
			new: "&b&lGolem de Starlight"
			old: "Starlight Golem"
		}
		quest.770C0975CA61CE46.quest_desc: {
			new: ["&bGlacita&r pode ser encontrada bem no subsolo das Florestas de Gelo Eterno. \\n\\nEla pode ser usada para fabricar Armaduras e Ferramentas que ajudam contra dano de Congelamento!"]
			old: ["Glacite pode ser encontrada nas profundezas das Florestas de Permafrost. \\n\\nPode ser usada para criar Armaduras e Ferramentas que ajudam contra o dano de Congelamento!"]
		}
		quest.03B40AB768FC0161.quest_desc: {
			new: [
				"&3Rios Cintilantes&r são rios amigáveis. Eles não vão sair do caminho deles para te matar. \\n\\nÀs vezes conectam &bMares&r entre si e atravessam Florestas. \\n\\nClaramente têm &9Água&r, mas dentro da &9Água&r há muitas riquezas!"
				"{image:atm:textures/questpics/eternal/starlight_river.png width:200 height:100 align:center}"
			]
			old: [
				"Rios Cintilantes são rios amigáveis. Estes não farão de tudo para te matar.\\n\\nEles às vezes conectam Mares e atravessam Florestas.\\n\\nClaramente eles têm Água, mas dentro da Água há muitos bens!"
				"{image:atm:textures/questpics/eternal/starlight_river.png width:200 height:100 align:center}"
			]
		}
		quest.63362CC33B39C627.quest_desc: {
			new: [
				"Mares Estelares são enormes corpos d'Água situados confortavelmente entre as Costas Quentes e a terra. \\n\\nEles guardam muitas maravilhas dentro deles e crescendo neles! \\n\\nEspero que você tenha trazido seus óculos!"
				"{image:atm:textures/questpics/eternal/starlight_starlitsea.png width:200 height:100 align:center}"
			]
			old: [
				"Mares Estrelados são enormes corpos de Água situados entre as Costas Quentes e a terra firme. \\n\\nEles guardam muitas maravilhas dentro deles e crescendo neles! \\n\\nEspero que você tenha trazido seus óculos de proteção!"
				"{image:atm:textures/questpics/eternal/starlight_starlitsea.png width:200 height:100 align:center}"
			]
		}
		quest.0BB8D556305EB307.quest_desc: {
			new: [
				"Rio de Éter é algo que você vai reconhecer quando vir. \\n\\nÉ brilhante, muito brilhante, e pode aparecer vermelho no seu Mapa, isso é um bug, ignore isso. "
				"{image:atm:textures/questpics/eternal/starlight_ether.png width:200 height:100 align:center}"
			]
			old: [
				"O Rio de Éter é algo que você saberá quando vir.\\n\\nÉ luminoso, muito luminoso e pode aparecer vermelho no seu Mapa, isso é um bug, ignore."
				"{image:atm:textures/questpics/eternal/starlight_ether.png width:200 height:100 align:center}"
			]
		}
		quest.271A112ABDD923A6.quest_desc: {
			new: ["Como Mangue normal, mas estes não são feios."]
			old: ["Como o Manguezal normal, mas estes não são feios."]
		}
		quest.47CB136D7764B86D.quest_desc: {
			new: ["&eVinhas de Torreya&r são encontradas penduradas nas &cÁrvores de Torreya&r. \\n\\nElas ficam penduradas porque não podem ser colocadas de nenhuma outra forma... \\n\\nO bulbo na parte inferior delas emitirá Luz!"]
			old: ["As Torreya Vines são encontradas penduradas nas Árvores de Torreya. \\n\\nElas estão penduradas porque não podem ser colocadas de outra forma... \\n\\nO bulbo na parte inferior delas emitirá Luz!"]
		}
	}
	file.snbt: {
		file.0000000000000001.title: {
			new: "All The Mons"
			old: "All The Mods Mons"
		}
	}
	"chapters/mainquestline_part_1.snbt": {
		quest.6D09511D64DDC282.quest_desc: {
			new: ["O &3&lDefensor&r. O Chefe mais forte do &2&lMinecraft&r. Sabe aquele que os criadores declararam explicitamente que você não deveria matar? \\n\\nO &3&lDefensor&r tem 500 &4Corações&r. Ele pode matar jogadores com dois golpes em uma armadura de &cNetherita&r completa. \\n\\nSe os jogadores estiverem perto dele, ele simplesmente os esmagará com os braços. Se detectado muito mais longe, ele atirará neles com seu &3Feixe Sônico&r. \\n\\nFelizmente ele é prejudicado por ser cego (ao contrário do Demolidor). Ele funciona unicamente através do Som e Olfato. Sim, se você estiver muito perto ele sempre será capaz de encontrá-lo. \\n\\nSe você fizer sons, ele pode ouvi-los e ir para onde você fez o som. Mesmo com &3Sensores de Sculk&r, se eles dispararem ele pode te encontrar! Se ele ouvir um ruído longe, ele pode afundar no &3Sculk&r para se teletransportar para mais perto do som! \\n\\nEntão, como o matamos? Você sempre pode tentar construir 23 blocos acima dele e acertá-lo com flechas. 23 blocos acima é muito longe para o seu Feixe Sônico! \\n\\nSe você conseguir matá-lo, ele deixará cair um monte de &3Sculk&r e itens do &3&lDeeper and Darker&r!"]
			old: ["O &3&lWarden&r. O Chefe mais forte do &2&lMinecraft&r. Sabe aquele que os criadores declararam explicitamente que você não deveria matar? \\n\\nO &3&lWarden&r tem 500 &4Corações&r. Ele pode matar jogadores com dois golpes em uma armadura de &cNetherita&r completa. \\n\\nSe os jogadores estiverem perto dele, ele simplesmente os esmagará com os braços. Se detectado muito mais longe, ele atirará neles com seu &3Feixe Sônico&r. \\n\\nFelizmente ele é prejudicado por ser cego (ao contrário do Demolidor). Ele funciona unicamente através do Som e Olfato. Sim, se você estiver muito perto ele sempre será capaz de encontrá-lo. \\n\\nSe você fizer sons, ele pode ouvi-los e ir para onde você fez o som. Mesmo com &3Sensores de Sculk&r, se eles dispararem ele pode te encontrar! Se ele ouvir um ruído longe, ele pode afundar no &3Sculk&r para se teletransportar para mais perto do som! \\n\\nEntão, como o matamos? Você sempre pode tentar construir 23 blocos acima dele e acertá-lo com flechas. 23 blocos acima é muito longe para o seu Feixe Sônico! \\n\\nSe você conseguir matá-lo, ele deixará cair um monte de &3Sculk&r e itens do &3&lDeeper and Darker&r!"]
		}
		quest.6D09511D64DDC282.title: {
			new: "&3&lDefensor"
			old: "&3&lWarden"
		}
		quest.616AE66BE7812E09.quest_desc: {
			new: ["Existem muuuuuitos Mods diferentes para explorar! \\n\\nDesde aqueles na &2&lSuperfície&r como Repurposed Structures até o &4&lCataclysm&r. \\nHá ainda mais em suas próprias Dimensões, como &9&lTwilight Forest&r, &2&lUndergarden&r, &6&lBumblezone&r e &5&lEternal Starlight&r. \\n\\nTodos esses Mods requerem a coleta de novos Blocos, luta contra Criaturas únicas e a melhor parte são as armas incríveis!"]
			old: ["Existem muuuuuitos Mods diferentes para explorar! \\n\\nDesde aqueles no &2&lMundo Superior&r como Repurposed Structures até o &4&lCataclysm&r. \\nHá ainda mais em suas próprias Dimensões, como &9&lTwilight Forest&r, &2&lUndergarden&r, &6&lBumblezone&r e &5&lEternal Starlight&r. \\n\\nTodos esses Mods requerem a coleta de novos Blocos, luta contra Criaturas únicas e a melhor parte são as armas incríveis!"]
		}
		task.6CAD0E4CF3577BEB.title: {
			new: "Mate 1 Defensor"
			old: "Mate 1 Warden"
		}
	}
	"chapters/apotheosis_2.snbt": {
		quest.3F55F3CC8519D783.quest_desc: {
			new: ["O Gerador Soulium é o Gerador presenteado a nós pelo Mystical Agriculture. Ele usa Essência de Criatura e Energia para gerar as criaturas. Essência de Criatura é obtida através da colheita de Mob Plants, feitas por Frascos de alma. Então você terá que matar as criaturas primeiro, ou usar o Soul Extractor."]
			old: ["O Gerador Soulium é o Gerador presenteado a nós pelo Mystical Agriculture. Ele usa Essência de Criatura e Energia para gerar as criaturas. Essência de Criatura é obtida através da colheita de Mob Plants, feitas por Soul Jars. Então você terá que matar as criaturas primeiro, ou usar o Soul Extractor."]
		}
		task.524CBF7058496E7F.title: {
			new: "Outros Gerador"
			old: "Outros Geradores"
		}
		task.55587BA32D30318C.title: {
			new: "Ovos Gerador"
			old: "Ovos Geradores"
		}
		task.45250DA4433007C6.title: {
			new: "Livros de Captura"
			old: "Livros de Capturando"
		}
		quest.6D68D9941049E806.quest_desc: {
			new: ["Este gerador irá, como o próprio nome sugere, fazer uso de &dFonte&r como combustível. Para decidir qual criatura gerar, você precisará de um Jarro de Contenção contendo a criatura na área."]
			old: ["Este gerador irá, como o próprio nome sugere, fazer uso de &dSource&r como combustível. Para decidir qual criatura gerar, você precisará de um Containment Jar contendo a criatura na área."]
		}
	}
	"chapters/basic_power.snbt": {
		quest.3BDB94F17765EE77.title: {
			new: "Opções de Energia do fim de jogo"
			old: "Opções de Energia de Fim de Jogo"
		}
		quest.7A979BEB20C9591E.quest_desc: {
			new: ["Pó de Flux pode ser automatizado usando &6Productive Bees&r!\\n\\nOvos Gerador de Abelha de Redstone podem ser convertidos em Ovos Gerador de Abelha de Pó de Flux usando uma Abelha de Obsidiana."]
			old: ["Pó de Flux pode ser automatizado usando &6Productive Bees&r!\\n\\nOvos de Geração de Abelha de Redstone podem ser convertidos em Ovos de Geração de Abelha de Pó de Flux usando uma Abelha de Obsidiana."]
		}
	}
	"chapters/industrial_foregoing.snbt": {
		quest.15551AC6C68E12E0.quest_desc: {
			new: ["Basicamente o gerador de mobs do &bIndustrial Foregoing&r. Ele usa &aEssência&r junto com um mob em uma Ferramenta de Prisão de Mob para gerar uma cópia desse mob.\\n\\nChefes e outros mobs que não podem ser colocados em um gerador* estão na lista negra do Duplicador de Mobs também.\\n\\n*&8Com algumas exceções, segure SHIFT em um Ovo Gerador enquanto as dicas avançadas (F3 + H) estiverem ativadas para ver se consegue encontrar a tag de Lista Negra do Duplicador de Mobs."]
			old: ["Basicamente o gerador de mobs do &bIndustrial Foregoing&r. Ele usa &aEssência&r junto com um mob em uma Ferramenta de Prisão de Mob para gerar uma cópia desse mob.\\n\\nChefes e outros mobs que não podem ser colocados em um gerador* estão na lista negra do Duplicador de Mobs também.\\n\\n*&8Com algumas exceções, segure SHIFT em um Ovo de Gerador enquanto as dicas avançadas (F3 + H) estiverem ativadas para ver se consegue encontrar a tag de Lista Negra do Duplicador de Mobs."]
		}
		quest.79D48F8F31B152C3.quest_subtitle: {
			new: "Tem que ser rápido!"
			old: "Tem que ser rápido! (WIP)"
		}
		quest.79D48F8F31B152C3.quest_desc: {
			new: [
				"&bIndustrial Foregoing &#27AEB9Souls&r adiciona máquinas para permitir que você acelere outras máquinas.\\n\\nA &#27AEB9Base de Laser de Alma&r é o coração disso, funcionando de forma semelhante a uma Base de Laser de Fluido extraindo Gás Éter de um Wither. Ela usa &9Lente de Laser Azul&r para extrair &#27AEB9Almas&r de um &#27AEB9Mewtwo&r, que podem ser extraídas com &#27AEB9Tubos de alma&r, ou usadas com AE2. Estas &#27AEB9Almas&r serão usadas por &#27AEB9Conduto de Alma&r para acelerar blocos. Sim, eu sei que a maioria de vocês está acostumada a extrair &#27AEB9Almas&r de um &#27AEB9Defensor&r, mas fala sério, tivemos que dar uma folga para aquela criatura.\\n\\nExtrair &#27AEB9Almas&r do &#27AEB9Mewtwo&r é um processo &4&ldoloroso&r para a criatura, o que significa que ela recebe dano do processo e pode até morrer por causa disso. Câmaras de Estase são altamente recomendadas, especialmente com melhorias para tornar a cura mais rápida."
				"{@pagebreak}"
				"Certifique-se de que haja um espaço de 3 blocos entre o chão e a &#27AEB9Base de Laser de Alma&r, assim:"
				"{image:atm:textures/questpics/industrialforegoing/soul_laser_gap.png width:100 height:100 align:center}"
			]
			old: [
				"&c&lAviso: No momento em que este texto foi escrito, o Mewtwo é inobtível. Como resultado, o mod Industrial Foregoing Souls não tem utilidade neste momento.&r \\n\\n&bIndustrial Foregoing &#27AEB9Souls&r adiciona máquinas para permitir que você acelere outras máquinas.\\n\\nA &#27AEB9Base de Laser de Alma&r é o coração disso, funcionando de forma semelhante a uma Base de Laser de Fluido extraindo Gás Éter de um Wither. Ela usa &9Lente de Laser Azul&r para extrair &#27AEB9Almas&r de um &#27AEB9Mewtwo&r, que podem ser extraídas com &#27AEB9Tubos de alma&r, ou usadas com AE2. Estas &#27AEB9Almas&r serão usadas por &#27AEB9Conduto de Alma&r para acelerar blocos. Sim, eu sei que a maioria de vocês está acostumada a extrair &#27AEB9Almas&r de um &#27AEB9Warden&r, mas fala sério, tivemos que dar uma folga para aquela criatura.\\n\\nExtrair &#27AEB9Almas&r do &#27AEB9Mewtwo&r é um processo &4&ldoloroso&r para a criatura, o que significa que ela recebe dano do processo e pode até morrer por causa disso. Câmaras de Estase são altamente recomendadas, especialmente com melhorias para tornar a cura mais rápida."
				"{@pagebreak}"
				"Certifique-se de que haja um espaço de 3 blocos entre o chão e a &#27AEB9Base de Laser de Alma&r, assim:"
				"{image:atm:textures/questpics/industrialforegoing/soul_laser_gap.png width:100 height:100 align:center}"
			]
		}
	}
