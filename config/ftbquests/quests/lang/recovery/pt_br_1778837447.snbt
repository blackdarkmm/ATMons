		}
	}
	"chapters/welcome.snbt": {
		quest.7658C1C663394E85.quest_desc: {
			new: ["Existem muitos comandos úteis no ATM. Aqui estão alguns:\\n\\n&e/sethome&r (nome da casa) | Permite que você defina um ponto de retorno para o qual pode se teletransportar usando /home (nome). Exemplo: /sethome fazenda - depois teleporte com /home fazenda.\\n\\n&e/spawn&r | Isso teletransportará você para o ponto de origem da Superfície.\\n\\n&e/rtp&r | 'Teletransporte Aleatório' teletransportará você para um local aleatório no mundo.\\n\\nNota: Estes comandos possuem tempos de recarga e limites. Se desejar alterá-los, você pode editar o arquivo de configuração que pode ser encontrado aqui:\\n\\n - Para Singleplayer | &osaves/(nome do save)/serverconfig/ftbessentials.snbt&r\\n\\n - Para Servidores | &oworld/serverconfig/ftbessentials.snbt&r"]
			old: ["Existem muitos comandos úteis no ATM. Aqui estão alguns:\\n\\n&e/sethome&r (nome da casa) | Permite que você defina um ponto de retorno para o qual pode se teletransportar usando /home (nome). Exemplo: /sethome fazenda - depois teleporte com /home fazenda.\\n\\n&e/spawn&r | Isso teletransportará você para o ponto de origem do seu Mundo Superior.\\n\\n&e/rtp&r | 'Teletransporte Aleatório' teletransportará você para um local aleatório no mundo.\\n\\nNota: Estes comandos possuem tempos de recarga e limites. Se desejar alterá-los, você pode editar o arquivo de configuração que pode ser encontrado aqui:\\n\\n - Para Singleplayer | &osaves/(nome do save)/serverconfig/ftbessentials.snbt&r\\n\\n - Para Servidores | &oworld/serverconfig/ftbessentials.snbt&r"]
		}
	}
	"chapters/deeper_and_darker.snbt": {
		quest.4D57A07592AED307.quest_desc: {
			new: [
				"O &3&lPerseguidor&r é um Chefe que pode ser invocado quebrando Vasos Ancestrais. \\n\\nEle tem 200 &4Corações&r e uma Barra de Chefe para acompanhar. Precisaremos matá-lo para obter &3Cristais de Alma&r. \\n\\nEle é muito rápido e causa muito Dano se te acertar. Felizmente, ele é Cego, como o &9&lDefensor&r. Mas ele também tem um incrível senso de audição que lhe permite ouvir tudo por perto. \\n\\nEle tem alguns ataques, normalmente ele apenas te Baterá. Às vezes, ele pode causar um ataque em área e pode invocar &3Sanguessugas de Sculk&r para te atacar! \\n\\nEle também atacará todos os Mobs que não sejam de &3Sculk&r."
				"{image:atm:textures/questpics/deepndark/dnd_stalker.png width:100 height:200 align:center}"
			]
			old: [
				"O &3&lPerseguidor&r é um Chefe que pode ser invocado quebrando Vasos Ancestrais. \\n\\nEle tem 200 &4Corações&r e uma Barra de Chefe para acompanhar. Precisaremos matá-lo para obter &3Cristais de Alma&r. \\n\\nEle é muito rápido e causa muito Dano se te acertar. Felizmente, ele é Cego, como o &9&lWarden&r. Mas ele também tem um incrível senso de audição que lhe permite ouvir tudo por perto. \\n\\nEle tem alguns ataques, normalmente ele apenas te Baterá. Às vezes, ele pode causar um ataque em área e pode invocar &3Sanguessugas de Sculk&r para te atacar! \\n\\nEle também atacará todos os Mobs que não sejam de &3Sculk&r."
				"{image:atm:textures/questpics/deepndark/dnd_stalker.png width:100 height:200 align:center}"
			]
		}
		quest.196003E1486ABB31.title: {
			new: "&9Molde de Ferraria do Defensor"
			old: "&9Molde de Ferraria do Warden"
		}
		quest.4A01C5F5DCF32C19.quest_desc: {
			new: ["A &3Élitros das Almas&r funciona como uma &8Élitra&r normal, só que agora com mais Durabilidade e Pontos de Armadura! \\n\\nElas não podem ser reparadas com &7Membranas de Phantom&r como as &8Élitras&r normais... mas os Encantamentos ainda podem repará-las! \\n\\nPara criar uma, você precisará de uma &8Élitra&r, 4 &3Ossos de Sculk&r que dropam dos &3Estilhaçado&r, 2 &3Pó de Alma&r que dropam dos &3Agarrador de Sculk &fou &3Sanguessugas de Sculk&r, e um &3Cristal de Alma&r que dropa do &3&lPerseguidor&r."]
			old: ["A &3Élitros das Almas&r funciona como uma &8Élitra&r normal, só que agora com mais Durabilidade e Pontos de Armadura! \\n\\nElas não podem ser reparadas com &7Membranas de Phantom&r como as &8Élitras&r normais... mas os Encantamentos ainda podem repará-las! \\n\\nPara criar uma, você precisará de uma &8Élitra&r, 4 &3Ossos de Sculk&r que dropam dos &3Estilhaçado&r, 2 &3Pós de Alma&r que dropam dos &3Agarrador de Sculk &fou &3Sanguessugas de Sculk&r, e um &3Cristal de Alma&r que dropa do &3&lPerseguidor&r."]
		}
		quest.13B338F377951032.quest_desc: {
			new: ["Você já desejou poder usar a &bExplosão Sônica&r do &9&lDefensor&r? \\n\\nBem, com o &bCajado Sonoro&r você pode! Simplesmente Segure o Botão Direito para carregá-lo, depois solte para enviar uma &bExplosão Sônica&r. \\nHá um pequeno tempo de recarga e ele tem Durabilidade, então use por sua conta e risco! \\n\\nPara criar um, você precisará de um &9Coração das Profundezas&r do &9&lDefensor&r, 2 &3Cristais de Alma&r do &3&lStalker&r e 2 &3Ossos de Sculk &fdos &3Estilhaçados&r."]
			old: ["Você já desejou poder usar a &bExplosão Sônica&r do &9&lWarden&r? \\n\\nBem, com o &bCajado Sonoro&r você pode! Simplesmente Segure o Botão Direito para carregá-lo, depois solte para enviar uma &bExplosão Sônica&r. \\nHá um pequeno tempo de recarga e ele tem Durabilidade, então use por sua conta e risco! \\n\\nPara criar um, você precisará de um &9Coração das Profundezas&r do &9&lWarden&r, 2 &3Cristais de Alma&r do &3&lStalker&r e 2 &3Ossos de Sculk &fdos &3Estilhaçados&r."]
		}
		quest.5E287410EE969244.quest_desc: {
			new: [
				"Os &9Estilhaçado&r aparecem em alguns Biomas no &3&lOutro Lado&r. \\n\\nEles agem como mini &9&lDefensores&r, sendo Cegos e dependendo do &3Sculk&r para encontrar Inimigos. Eles também atacam todos os Mobs que não são de &3Sculk&r. \\n\\nOs &9Estilhaçados&r têm 50 &4Corações&r e batem bem forte! Então, cuidado para não atrair muitos. \\n\\nSe você conseguir matá-los, eles droparão &9Ossos de Sculk&r. Estes serão necessários para algumas Receitas."
				"{image:atm:textures/questpics/deepndark/dnd_shattered.png width:100 height:150 align:center}"
			]
			old: [
				"Os &9Estilhaçado&r aparecem em alguns Biomas no &3&lOutro Lado&r. \\n\\nEles agem como mini &9&lWardens&r, sendo Cegos e dependendo do &3Sculk&r para encontrar Inimigos. Eles também atacam todos os Mobs que não são de &3Sculk&r. \\n\\nOs &9Estilhaçados&r têm 50 &4Corações&r e batem bem forte! Então, cuidado para não atrair muitos. \\n\\nSe você conseguir matá-los, eles droparão &9Ossos de Sculk&r. Estes serão necessários para algumas Receitas."
				"{image:atm:textures/questpics/deepndark/dnd_shattered.png width:100 height:150 align:center}"
			]
		}
		quest.7CBAA67204CC258C.quest_desc: {
			new: ["Não, o &9&lDefensor&r não usa Espadas e Machados. Mas nós podemos! \\n\\nAmbos, a &9Espada do Defensor &fe o &9Machado&r, são aprimoramentos de suas &cversões de Netherite&r com um &9Fragmento de Eco Reforçado &fe um &9Molde de Aprimoramento do Defensor&r. \\n\\nCada um tem 1 &4Coração&r de Dano a mais e ainda mais Durabilidade! \\n\\nSim, o Machado ainda pode derrubar Árvores eficientemente."]
			old: ["Não, o &9&lWarden&r não usa Espadas e Machados. Mas nós podemos! \\n\\nAmbos, a &9Espada do Warden &fe o &9Machado&r, são aprimoramentos de suas &cversões de Netherite&r com um &9Fragmento de Eco Reforçado &fe um &9Molde de Aprimoramento do Warden&r. \\n\\nCada um tem 1 &4Coração&r de Dano a mais e ainda mais Durabilidade! \\n\\nSim, o Machado ainda pode derrubar Árvores eficientemente."]
		}
		quest.45C9D975E3731DFE.quest_desc: {
			new: ["O &9Fragmento de Eco Reforçado&r é um Item fabricado que requer alguns Itens. \\n\\nPrimeiro, e mais fácil de obter, são as &7Membranas de Phantom&r! &7Phantoms&r surgirão depois que o Jogador não dormir por alguns dias. Quanto mais noites sem dormir, mais &7Phantoms&r! \\n\\nSegundo, é o &9Fragmento de Eco&r. Estes podem ser encontrados de várias maneiras, mas a mais fácil é saqueando nas &6Cidades Ancestrais&r. \\n\\nO último são as &9Carapaças do Defensor&r. São drops do &9&lDefensor&r ao morrer. Não se preocupe, ele geralmente dropa mais de uma!"]
			old: ["O &9Fragmento de Eco Reforçado&r é um Item fabricado que requer alguns Itens. \\n\\nPrimeiro, e mais fácil de obter, são as &7Membranas de Phantom&r! &7Phantoms&r surgirão depois que o Jogador não dormir por alguns dias. Quanto mais noites sem dormir, mais &7Phantoms&r! \\n\\nSegundo, é o &9Fragmento de Eco&r. Estes podem ser encontrados de várias maneiras, mas a mais fácil é saqueando nas &6Cidades Ancestrais&r. \\n\\nO último são as &9Carapaças do Warden&r. São drops do &9&lWarden&r ao morrer. Não se preocupe, ele geralmente dropa mais de uma!"]
		}
		quest.0B718FC37699B822.quest_desc: {
			new: ["Os &aTroncos de Eco&r são feitas de &aÁrvores de Eco&r que aparecem na &5Floresta Ecoante&r... há um eco aqui, por que ouço tanto isso? \\n\\nAs &aÁrvores de Eco&r têm &5Folhas Roxas&r e Brilho de Sculk dentro delas. Enquanto seus Troncos têm uma &7Casca Cinza Clara&r e uma cor de &aTronco Verde muito Clara&r. \\n\\nTodas as Tábuas e Itens de Madeira feitos a partir dela são todos da &aCor Verde Clara&r, quase como Menta. \\n\\nOs Alçapões e as Portas têm padrões únicos e legais!"]
			old: ["Os &aTroncos de Eco&r são feitas de &aÁrvores de Eco&r que aparecem na &5Floresta Ecoante&r... há um eco aqui, por que ouço tanto isso? \\n\\nAs &aÁrvores de Eco&r têm &5Folhas Roxas&r e Brilho de Sculk dentro delas. Enquanto suas Toras têm uma &7Casca Cinza Clara&r e uma cor de &aTronco Verde muito Clara&r. \\n\\nTodas as Tábuas e Itens de Madeira feitos a partir dela são todos da &aCor Verde Clara&r, quase como Menta. \\n\\nOs Alçapões e as Portas têm padrões únicos e legais!"]
		}
		quest.0B11EAB8D76529E0.quest_desc: {
			new: [
				"A &6Cidade Ancestral&r é apenas a Estrutura mais perigosa do &2&lMinecraft Vanilla&r. Então, é claro que isso é apenas o começo para &3&lDeeper and Darker&r! \\n\\nAqui podemos encontrar &3Sculk&r em abundância, juntamente com Saques e o &9&lDefensor&r. Também encontraremos a Estrutura do Portal feita de &8Ardosiabissal Reforçada&r. \\n\\nMas até lá, saqueie tudo o que puder! E tenha cuidado com o..."
				"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
			]
			old: [
				"A &6Cidade Ancestral&r é apenas a Estrutura mais perigosa do &2&lMinecraft Vanilla&r. Então, é claro que isso é apenas o começo para &3&lDeeper and Darker&r! \\n\\nAqui podemos encontrar &3Sculk&r em abundância, juntamente com Saques e o &9&lWarden&r. Também encontraremos a Estrutura do Portal feita de &8Ardosiabissal Reforçada&r. \\n\\nMas até lá, saqueie tudo o que puder! E tenha cuidado com o..."
				"{image:atm:textures/questpics/allthemodium/all_city.png width:200 height:100 align:center}"
			]
		}
		quest.726A627BD7654E0C.quest_desc: {
			new: ["Não há muita mudança de &cNetherita&r para &9Defensor&r para estas Ferramentas. \\n\\nA Picareta é do mesmo Nível e mesma Velocidade. As Pás ainda podem fazer Caminhos e, novamente, mesma Velocidade. As Enxadas ainda podem fazer Terra Arada e também mesma Velocidade. \\n\\nA única mudança real é um Dano de Ataque maior para todas elas. \\n\\nCuriosamente, isso significa que as &9Enxadas do Defensor&r têm Dano maior do que todas as Enxadas do &2&lVanilla&r!"]
			old: ["Não há muita mudança de &cNetherita&r para &9Warden&r para estas Ferramentas. \\n\\nA Picareta é do mesmo Nível e mesma Velocidade. As Pás ainda podem fazer Caminhos e, novamente, mesma Velocidade. As Enxadas ainda podem fazer Terra Arada e também mesma Velocidade. \\n\\nA única mudança real é um Dano de Ataque maior para todas elas. \\n\\nCuriosamente, isso significa que as &9Enxadas do Warden&r têm Dano maior do que todas as Enxadas do &2&lVanilla&r!"]
		}
		quest.6E38CF6E7360E9CA.quest_desc: {
			new: ["O &9&lDefensor&r dropará alguns Itens, mas o &9Coração das Profundezas&r é o mais importante. \\n\\nPodemos usar o &9Coração das Profundezas&r em uma estrutura de &8Ardosiabissal Reforçada&r para obter nosso Portal para o &3&lOutro Lado&r. Não pode haver nenhum Bloco bloqueando a Estrutura do Portal, senão não funcionará. \\n\\nEle também dropa &9Carapaça do Defensor&r e &9Fragmentos de Eco&r, ambos serão úteis para Criar outros Itens!"]
			old: ["O &9&lWarden&r dropará alguns Itens, mas o &9Coração das Profundezas&r é o mais importante. \\n\\nPodemos usar o &9Coração das Profundezas&r em uma estrutura de &8Ardosiabissal Reforçada&r para obter nosso Portal para o &3&lOutro Lado&r. Não pode haver nenhum Bloco bloqueando a Estrutura do Portal, senão não funcionará. \\n\\nEle também dropa &9Carapaça do Warden&r e &9Fragmentos de Eco&r, ambos serão úteis para Criar outros Itens!"]
		}
		quest.196003E1486ABB31.quest_desc: {
			new: ["Para aprimorar de &cNetherita&r para &9Equipamento do Defensor&r, você precisará de um &9Molde de Ferraria&r! \\n\\nEles são encontrados em Baús nas &6Cidades Ancestrais&r. \\n\\nEles podem ser duplicados com 7 Diamantes e um &3Bloco de Sculk&r!"]
			old: ["Para aprimorar de &cNetherita&r para &9Equipamento do Warden&r, você precisará de um &9Molde de Ferraria&r! \\n\\nEles são encontrados em Baús nas &6Cidades Ancestrais&r. \\n\\nEles podem ser duplicados com 7 Diamantes e um &3Bloco de Sculk&r!"]
		}
		quest.6E901EF1CB411088.title: {
			new: "Armadura do &9Defensor&r"
			old: "Armadura do &9Warden&r"
		}
		quest.6E901EF1CB411088.quest_desc: {
			new: ["A &9Armadura do Defensor&r é um aprimoramento direto da de &cNetherite&r. Basta usar um &9Molde de Ferraria do Defensor&r, um &9Fragmento de Eco Reforçado&r e uma peça de &cArmadura de Netherite&r para fazê-la. \\n\\nCada peça tem 1 Ponto de Armadura a mais e 1 Ponto de Proteção de Armadura a mais em comparação com sua contraparte de &cNetherita&r. \\n\\nNo entanto, não há mais Resistência à Repulsão. \\n\\nPelo menos elas parecem muito mais legais do que as de &cNetherita&r! O &9Elmo&r tem chifres gigantes como o &9&lDefensor&r e o &9Peitoral&r tem um ponto de coração."]
			old: ["A &9Armadura do Warden&r é um aprimoramento direto da de &cNetherite&r. Basta usar um &9Molde de Ferraria do Warden&r, um &9Fragmento de Eco Reforçado&r e uma peça de &cArmadura de Netherite&r para fazê-la. \\n\\nCada peça tem 1 Ponto de Armadura a mais e 1 Ponto de Proteção de Armadura a mais em comparação com sua contraparte de &cNetherita&r. \\n\\nNo entanto, não há mais Resistência à Repulsão. \\n\\nPelo menos elas parecem muito mais legais do que as de &cNetherita&r! O &9Elmo&r tem chifres gigantes como o &9&lWarden&r e o &9Peitoral&r tem um ponto de coração."]
		}
		quest.7CBAA67204CC258C.title: {
			new: "&3Armas do Defensor&r"
			old: "&3Armas do Warden&r"
		}
		quest.3D579A1F7EFEDD5C.title: {
			new: "Mate o &9&lDefensor&r"
			old: "Mate o &9&lWarden&r"
		}
		quest.0450060852F290CA.quest_desc: {
			new: [
				"As &9Terras Profundas&r são muito semelhantes ao &3Deep Dark&r. \\n\\nElas estão cheias de &3Sculk &fjuntamente com &3Emissores &fe &3Sensores&r, que sim, ainda podem gerar o &9&lDefensor&r. \\n\\nAqui você também encontrará mais &3Criaturas de Sculk&r e Plantas, e até mesmo a única Estrutura que o &3&lOutro Lado&r possui!"
				"{image:atm:textures/questpics/deepndark/dnd_land.png width:200 height:100 align:center}"
			]
			old: [
				"As &9Terras Profundas&r são muito semelhantes ao &3Deep Dark&r. \\n\\nElas estão cheias de &3Sculk &fjuntamente com &3Emissores &fe &3Sensores&r, que sim, ainda podem gerar o &9&lWarden&r. \\n\\nAqui você também encontrará mais &3Criaturas de Sculk&r e Plantas, e até mesmo a única Estrutura que o &3&lOutro Lado&r possui!"
				"{image:atm:textures/questpics/deepndark/dnd_land.png width:200 height:100 align:center}"
			]
		}
		quest.76F14C2B866B4EAD.quest_desc: {
			new: ["O &3&lOutro Lado&r é o local de nascimento do &3Sculk &fe das criaturas de &3Sculk&r, incluindo o &9&lDefensor&r. \\n\\nAqui você encontrará muitos de seus primos distantes, mas não se preocupe, também há alguns pontos positivos no &3&lOutro Lado&r! \\n\\nHá muitos novos Blocos de Construção e Itens que podemos encontrar e &3Sculk&r por toda parte para obter toneladas de &aXP&r! \\n\\nEntão, prepare sua Enxada e aventure-se no &3&lOutro Lado&r!"]
			old: ["O &3&lOutro Lado&r é o local de nascimento do &3Sculk &fe das criaturas de &3Sculk&r, incluindo o &9&lWarden&r. \\n\\nAqui você encontrará muitos de seus primos distantes, mas não se preocupe, também há alguns pontos positivos no &3&lOutro Lado&r! \\n\\nHá muitos novos Blocos de Construção e Itens que podemos encontrar e &3Sculk&r por toda parte para obter toneladas de &aXP&r! \\n\\nEntão, prepare sua Enxada e aventure-se no &3&lOutro Lado&r!"]
		}
		quest.3D579A1F7EFEDD5C.quest_desc: {
			new: [
				"O &9&lDefensor&r. O chefe mais difícil do &2&lMinecraft&r, claro, estando dentro da Estrutura mais difícil. \\n\\nEle é gerado por um &3Emissor de Sculk&r sendo ativado 3 vezes, ou qualquer quantidade após o primeiro &9&lDefensor&r. \\n\\nEle tem 500 &4Corações&r e causa muito Dano, seja te atingindo com os punhos ou com sua &bExplosão Sônica&r! \\n\\nEle tem uma fraqueza, no entanto, que é ser Cego. Ele só pode te encontrar pelo Som, ou pelo Cheiro se você estiver perto o suficiente! Mantenha distância, tipo 23 Blocos de altura."
				"{image:atm:textures/questpics/gettingstarted/warden_roar.png width:100 height:100 align:center}"
			]
			old: [
				"O &9&lWarden&r. O chefe mais difícil do &2&lMinecraft&r, claro, estando dentro da Estrutura mais difícil. \\n\\nEle é gerado por um &3Emissor de Sculk&r sendo ativado 3 vezes, ou qualquer quantidade após o primeiro &9&lWarden&r. \\n\\nEle tem 500 &4Corações&r e causa muito Dano, seja te atingindo com os punhos ou com sua &bExplosão Sônica&r! \\n\\nEle tem uma fraqueza, no entanto, que é ser Cego. Ele só pode te encontrar pelo Som, ou pelo Cheiro se você estiver perto o suficiente! Mantenha distância, tipo 23 Blocos de altura."
				"{image:atm:textures/questpics/gettingstarted/warden_roar.png width:100 height:100 align:center}"
			]
		}
		quest.6BB948F44B0950E8.quest_desc: {
			new: ["A &3Pedra de Sculk&r aparece em quase todos os lugares, exceto nas &cColunas Nubladas&r. \\n\\nEla funciona como &7Pedra&r normal, em todos os sentidos. Você pode fundir as versões de Pedregulho para obter a &3Pedra de Sculk&r, que pode ser transformada em muitos outros Blocos de Construção. \\n\\nInfelizmente, não pode ser usada para fazer Ferramentas de Pedra... espere, o que você se importa, você matou o &9&lDefensor&r! Por que você precisa de Ferramentas de Pedra?!?!?!"]
			old: ["A &3Pedra de Sculk&r aparece em quase todos os lugares, exceto nas &cColunas Nubladas&r. \\n\\nEla funciona como &7Pedra&r normal, em todos os sentidos. Você pode fundir as versões de Pedregulho para obter a &3Pedra de Sculk&r, que pode ser transformada em muitos outros Blocos de Construção. \\n\\nInfelizmente, não pode ser usada para fazer Ferramentas de Pedra... espere, o que você se importa, você matou o &9&lWarden&r! Por que você precisa de Ferramentas de Pedra?!?!?!"]
		}
		quest.5C983A41886A2B75.quest_desc: {
			new: ["Para voltar a &2&lSuperfície&r, podemos sair pelo mesmo caminho que viemos! \\n\\nUse o &9Coração das Profundezas&r em uma Estrutura de &8Ardosiabissal Reforçada&r. \\n\\nFelizmente, conseguimos uma dessas na parte inferior do &6Templo Ancestral&r."]
			old: ["Para voltar ao &2&lMundo Superior&r, podemos sair pelo mesmo caminho que viemos! \\n\\nUse o &9Coração das Profundezas&r em uma Estrutura de &8Ardosiabissal Reforçada&r. \\n\\nFelizmente, conseguimos uma dessas na parte inferior do &6Templo Ancestral&r."]
		}
		quest.726A627BD7654E0C.title: {
			new: "&3Ferramentas do Defensor&r"
			old: "&3Ferramentas do Warden&r"
		}
	}
	"chapters/natures_aura.snbt": {
		quest.5A011CE8EEA3F9D8.quest_desc: {
			new: ["A Aura pode ser engarrafada clicando com o botão direito na ar com uma Garrafa e Rolha. A Aura assume diferentes formas dependendo de onde é coletada.\\n\\nNo Superfície, ela é engarrafada como &aLuz do Sol&r, no Nether são &4Fantasmas&r e no End é &0Escuridão&r.\\n\\nSe a área onde você usou a Garrafa e Rolha tiver uma grande falta de aura, você obterá &0Vácuo Engarrafado&r."]
			old: ["A Aura pode ser engarrafada clicando com o botão direito no ar com uma Garrafa e Rolha. A Aura assume diferentes formas dependendo de onde é coletada.\\n\\nNo Mundo Superior, ela é engarrafada como &aLuz do Sol&r, no Nether são &4Fantasmas&r e no End é &0Escuridão&r.\\n\\nSe a área onde você usou a Garrafa e Rolha tiver uma grande falta de aura, você obterá &0Vácuo Engarrafado&r."]
		}
		quest.54F7AD64A403C9BF.quest_desc: {
			new: ["Esses Catalisadores podem ser adicionados como topos de pilar ao seu &2Altar Natural&r. Eles permitem que você transforme mais itens em outros itens ou os decomponha.\\n\\nO Catalisador de Desmoronamento permite que você transforme cada Folha de Ouro em 4 Pó de Ouro em vez de 2!"]
			old: ["Esses Catalisadores podem ser adicionados como topos de pilar ao seu &2Altar Natural&r. Eles permitem que você transforme mais itens em outros itens ou os decomponha.\\n\\nO Catalisador de Desmoronamento permite que você transforme cada Folha de Ouro em 4 Pós de Ouro em vez de 2!"]
		}
	}
	"chapters/basic_armor.snbt": {
		quest.15978093237448FE.title: {
			new: "Armadura do &3Defensor"
			old: "Armadura do &3Warden"
		}
		quest.34D14B807A2DAC0F.quest_desc: {
			new: ["Você acha que o &5&lMekanism&r pode ter toda a diversão? \\n\\nEsta &5Armadura Quântica&r tem status padrão semelhantes à &cArmadura de Netherita&r, mas, como o &aMeka-Traje&r, pode usar Energia como um escudo. \\nTambém possui melhorias que podem ser instaladas para torná-lo ainda mais poderoso! Como Voo, Visão Noturna e até a capacidade de recarregar. \\n\\nMas a melhor parte é que ela pode ser vinculada ao seu Sistema de Armazenamento! Então, você pode retirar energia automaticamente dele e retirar qualquer Item dele, não importa onde você esteja. "]
			old: ["Você acha que o &5&lMekanism&r e o &l&7Modern Industrialization&r podem ter toda a diversão? \\n\\nEsta &5Armadura Quântica&r tem status padrão semelhantes à &cArmadura de Netherita&r, mas, como o &aMeka-Traje&r, pode usar Energia como um escudo. \\nTambém possui melhorias que podem ser instaladas para torná-lo ainda mais poderoso! Como Voo, Visão Noturna e até a capacidade de recarregar. \\n\\nMas a melhor parte é que ela pode ser vinculada ao seu Sistema de Armazenamento! Então, você pode retirar energia automaticamente dele e retirar qualquer Item dele, não importa onde você esteja. "]
		}
		quest.15978093237448FE.quest_desc: {
			new: ["Por que atualizar &cNetherita&r para &6Allthemodium&r ou até mesmo qualquer outra coisa quando podemos atualizá-la para &3Armadura do Defensor&r! \\n\\nVocê precisará de alguns Drops do Defensor para fazê-la, no entanto!"]
			old: ["Por que atualizar &cNetherita&r para &6Allthemodium&r ou até mesmo qualquer outra coisa quando podemos atualizá-la para &3Armadura do Warden&r! \\n\\nVocê precisará de alguns Drops do Warden para fazê-la, no entanto!"]
		}
	}
	"chapters/mega_showdown.snbt": {
		quest.41CFA175B69E6639.quest_desc: {
			new: ["&cBosque do Desejo&r, não Poço. Não há Água aqui, apenas uma Estrutura na Floresta. \\n\\nNo centro da Estrutura haverá uma Estrela caída. \\n\\nFaça um pedido! Ou Minere o Cristal com uma &bPicareta de Diamante&r. "]
			old: ["&cBosque do Desejo&r, não Poço. Não há água aqui, apenas uma estrutura na floresta. \\n\\nNo centro da estrutura haverá uma estrela caída. \\n\\nFaça um desejo! Ou minere o cristal com uma &bPicareta de Diamante&r. "]
		}
		task.5FEDBD789E019B8D.title: {
			new: "Movimento-Z"
			old: "Movimentos Z"
		}
		quest.33B301DB0637B6FC.quest_desc: {
			new: ["Nas profundezas da terra, você pode se deparar com um &bMegaroide&r! \\n\\nNão, não tem nada a ver com melhorias físicas... bem, exceto para &cPokemon&r. \\n\\nÉ chamado de roide por causa de Asteroides, não esteroides, é isso que estou tentando dizer! \\n\\nNo centro do &bMega-asteroide&r, encontra-se o Minério de Pedra-chave."]
			old: ["Nas profundezas da terra, você pode encontrar um &bMegaroide&r! \\n\\nNão, não tem nada a ver com melhorias físicas... bem, exceto para &cPokémon&r. \\n\\nÉ chamado de 'roide' por causa de asteroides, não esteroides, é isso que estou tentando dizer! \\n\\nNo centro do &bMega-asteroide&r, fica o Minério de Pedra-chave."]
		}
		quest.490A35A715E8E20E.title: {
			new: "&cDynamax"
			old: "&cDynamaxizando"
		}
		quest.16E0E86A19015F2A.title: {
			new: "&bMega Braceletes"
			old: "&bBraceletes Mega"
		}
		quest.53F54C6A1EAB9574.quest_desc: {
			new: ["Odeia ocupar 4 Espaços para usar &eMovimento-Z&f, &cDynamax&f, &bMega Evoluções&f e &5Terastalização&r? \\n\\nEntão por que não dar uma chance ao Anel &bO&5m&en&ci&r! \\n\\nBasta usar esse garotão em qualquer um desses 4 Espaços e você terá a função do &eAnel Z&f, &cPulseira Dynamax&f, &bMega Bracelete&f e &5Orbe Tera&r em um pequeno pacote."]
			old: ["Odeia ocupar 4 espaços para usar &eMovimentos Z&f, &cDynamax&f, &bMegaevoluções&f e &5Terastalização&r? \\n\\nEntão, por que não dar uma chance ao Anel &bO&5m&en&ci&r! \\n\\nBasta usar este garotão em qualquer um desses 4 espaços e você terá a função do &eAnel Z&f, &cPulseira Dynamax&f, &bBracelete Mega&f e &5Orbe Tera&r em um pequeno pacote."]
		}
		quest.117ADB40CE01CE07.quest_desc: {
			new: ["Por algum motivo, nossos &cPokemon&r precisam que usemos &eAnéis&r especiais para poder usar &eMovimento-Z&r. \\n\\nNão sei por que... mas precisaremos de uma Pedra Brilhante para fabricá-lo. Além de alguns outros Itens. \\n\\nO tipo de &eAnel&r não importa, apenas muda a aparência. Eu gosto mais dos &dAnéis da Olivia&r!"]
			old: ["Por algum motivo, nossos &cPokémon&r precisam que usemos &eAnéis&r especiais para podermos usar &eMovimentos Z&r. \\n\\nNão tenho certeza do porquê... mas precisaremos de uma Pedra Brilhante para fabricá-los. Além de alguns outros itens. \\n\\nO tipo de &eAnel&r não importa, apenas muda a aparência. Eu gosto mais dos &dAnéis da Olivia&r!"]
		}
		quest.53C0C8BCCB804368.title: {
			new: "&eMovimento-Z"
			old: "&eMovimentos Z"
		}
		task.25A056981B7F62F0.title: {
			new: "Mega Braceletes"
			old: "Braceletes Mega"
		}
		quest.56F6B205855AF7F2.quest_desc: {
			new: ["O &cPokemon&r não é grande o suficiente? Por que não usar o &cGigantamax&r! \\n\\nApenas alguns &cPokemon&r podem usá-lo (há uma lista online, mas Charizard e Eevee estão nela). \\n\\nAlimente-os com uma &cSopa Max&r (ou se for Urshifu, uma &cSopa Max Doce&r) e eles poderão usar &cMovimentos G-Max&r."]
			old: ["O &cPokémon&r não é grande o suficiente? Por que não usar o &cGigamax&r! \\n\\nApenas alguns &cPokémon&r podem usá-lo (há uma lista online, mas Charizard e Eevee estão nela). \\n\\nAlimente-os com uma &cSopa Max&r (ou se for um Urshifu, uma &cSopa Max Doce&r) e eles poderão usar &cMovimentos G-Max&r."]
		}
		quest.3D6167F673BB5256.quest_desc: {
			new: ["Ao Minerar o &bMega Cristal&r com uma &bPicareta de Diamante&r (ou superior), você obterá uma &bMega Pedra&r! \\n\\nElas não fazem nada sozinhas, em vez disso, precisaremos usá-las para Fabricar uma certa &bMega Pedra&r para um &cPokemon&r específico. \\n\\nNem todos os &cPokemon&r podem se tornar &bMega&r, apenas alguns selecionados. Cada um precisará de sua &bMega Pedra&r específica, o que significa que se você quiser vários &bMega Pokemon&r, precisará de vários &bMega Locais&r."]
			old: ["Ao minerar o &bMega Cristal&r com uma &bPicareta de Diamante&r (ou melhor), você obterá uma &bMega Pedra&r! \\n\\nEstas não fazem nada sozinhas; em vez disso, precisaremos usá-las para Fabrique uma certa &bMega Pedra&r para um &cPokémon&r específico. \\n\\nNem todos os &cPokémon&r podem se tornar &bMega&r, apenas alguns selecionados. Cada um precisará de sua &bMega Pedra&r específica, o que significa que se você quiser vários &bMega Pokémon&r, precisará de vários &bLocais Mega&r."]
		}
		quest.7895490EEBDCF601.title: {
			new: "&eLocal Arqueológico"
			old: "&eSítio Arqueológico"
		}
		quest.3FACB48732D14A79.quest_desc: {
			new: ["Raramente no subsolo você pode encontrar um &bMega Local&r. \\n\\nParece um pouco com um &bMegaroide&r se a atmosfera fosse muito mais severa com ele. \\n\\nVocê encontrará Minérios nele, bem como o &bMega Cristal&r."]
			old: ["Raramente, no subsolo, você pode encontrar um &bLocal Mega&r. \\n\\nParece um pouco com um &bMegaroide&r se a atmosfera fosse muito mais agressiva com ele. \\n\\nVocê encontrará minérios nele, assim como o &bMega Cristal&r."]
		}
		quest.69B766907C1226C0.quest_desc: {
			new: ["O &cDynamax&r precisa de um &cPonto de Energia&r a no máximo 20 Blocos de distância da Batalha. \\n\\nNão sei se são 20 Blocos de distância de você, do seu &cPokemon&r ou da coisa que você está lutando... apenas fique perto de todos eles para ter certeza. \\n\\nVocê precisará de uma Estrela do Desejo e um &cCogumelo Max&r para criar um."]
			old: ["O &cDynamax&r precisa de um &cPonto de Energia&r a no máximo 20 blocos de distância da batalha. \\n\\nNão sei se são 20 blocos de distância de você, do seu &cPokémon&r ou daquilo que você está enfrentando... apenas fique perto de todos eles para ter certeza. \\n\\nVocê precisará de uma Estrela do Desejo e de um &cCogumelo Max&r para criar um."]
		}
		quest.3642AF6FE63B1C90.title: {
			new: "&bMega Evolução"
			old: "&bMegaevolução"
		}
		quest.3FACB48732D14A79.title: {
			new: "&bMega Local"
			old: "&bLocal Mega"
		}
		quest.2C272D1D6DE6C0F1.quest_desc: {
			new: ["Enquanto estiver usando um &5Orbe Tera&r, você pode usar 50 dos mesmos &5Fragmentos Tera&r em seu &cPokemon&r para dar a ele esse Tipo. \\n\\nObviamente, o Tipo está relacionado ao Tipo de &5Fragmentos&r que você usa. \\n\\nIsso entrará em vigor quando o &cPokemon&r estiver em Batalha."]
			old: ["Enquanto estiver usando um &5Orbe Tera&r, você pode usar 50 do mesmo &5Fragmento Tera&r em seu &cPokémon&r para dar a ele esse tipo. \\n\\nObviamente, o tipo está relacionado ao tipo de &5Fragmentos&r que você usa. \\n\\nIsso entrará em vigor quando o &cPokémon&r estiver em batalha."]
		}
		quest.2E6646301ACD332E.quest_desc: {
			new: ["O &eObservatório&r é uma Estrutura alta com um telescópio gigante saindo dele. \\n\\nO primeiro nível tem muitos Vasos, um PC e alguns Monitores de Dados. \\n\\nO Segundo Nível tem Estações de Cura e Vidros pelos quais eu continuo tentando passar, assim como os pássaros tentam. \\n\\nO terceiro nível tem Baús, Barris e um..."]
			old: ["O &eObservatório&r é uma estrutura alta com um telescópio gigante saindo dela. \\n\\nO primeiro nível tem toneladas de Vasos, um PC e alguns monitores de dados. \\n\\nO segundo nível tem Estações de Cura e vidros pelos quais eu continuo tentando atravessar, assim como os pássaros tentam. \\n\\nO terceiro nível tem baús, barris e um..."]
		}
		quest.0CFF4E3560CFFB49.quest_desc: {
			new: ["Cada &cPokemon&r precisa de sua &bMega Pedra&r específica para se tornar &bMega&r. \\n\\nÉ bem fácil saber quem é quem, porque elas geralmente recebem o nome do &cPokemon&r a que se destinam, apenas com \"ita\" no final. \\n\\nCada um precisa de uma &bMega Pedra&r, 2 Lingotes de Ferro, um &bDiamante&r e um Item único para aquele &cPokemon&r. \\n\\nAlém disso, Charizard e Mewtwo têm duas formas de &bMega&r com X e Y."]
			old: ["Cada &cPokémon&r precisa de sua &bMega Pedra&r específica para se tornar &bMega&r. \\n\\nÉ bem fácil saber de quem é cada uma, porque geralmente elas são nomeadas com o nome do &cPokémon&r seguido de \"ita\". \\n\\nCada uma precisa de uma &bMega Pedra&r, 2 Lingotes de Ferro, um &bDiamante&r e um item único para aquele &cPokémon&r. \\n\\nAlém disso, Charizard e Mewtwo possuem duas formas de &bMega&r com X e Y."]
		}
		quest.23DBBEFCE729AEA3.quest_desc: {
			new: ["\"Ao fazer um pedido a uma Estrela\" \\n\\nVocê será capaz de usar o &cDynamax&r em seu &cPokemon&r! \\n\\nO &cDynamax&r é usado em Batalha para usar uma versão &cMax&r dos Movimentos do seu &cPokemon&r. \\n\\nIsso fará com que eles cresçam muito mais em tamanho, ganhem mais Vida e tornem seus Movimentos ainda mais poderosos!"]
			old: ["\"Ao fazer um desejo a uma estrela\" \\n\\nVocê será capaz de &cDynamaxizar&r seu &cPokémon&r! \\n\\nO &cDynamax&r é usado em batalha para usar uma versão &cMax&r dos movimentos do seu &cPokémon&r. \\n\\nIsso fará com que eles cresçam muito em tamanho, ganhem mais vida e tornem seus movimentos ainda mais poderosos!"]
		}
		quest.490A35A715E8E20E.quest_desc: {
			new: ["Com uma &cPulseira Dynamax&r em seu Personagem, um &cPonto de Energia&r por perto e um &cPokemon&r pronto para lutar, podemos usar o &cDynamax&r! \\n\\nSeu &cPokemon&r não precisa estar em um &cNível Dynamax&r mais alto para usá-lo, tudo o que isso fará é tornar seu Movimento ainda mais poderoso e dar a ele mais Vida. \\n\\nEm Batalha, você pode olhar abaixo dos Movimentos para ver o Botão &cDynamax&r. Clique nele para transformar nossos Movimentos em&c Movimentos Max&r!"]
			old: ["Com uma &cPulseira Dynamax&r em seu personagem, um &cPonto de Energia&r por perto e um &cPokémon&r pronto para lutar, podemos &cDynamaxizar&r! \\n\\nSeu &cPokémon&r não precisa ter um &cNível Dynamax&r alto para usá-lo; tudo o que isso fará é tornar o movimento dele ainda mais poderoso e dar a ele mais vida. \\n\\nEm batalha, você pode olhar abaixo dos movimentos para ver o botão &cDynamax&r. Clique nele para transformar nossos movimentos em &cMovimentos Max&r!"]
		}
		quest.658D2E531DDB116C.quest_desc: {
			new: ["Colocou suas belas Joias? Dê ao seu &cPokemon&r um &eMovimento-Z&r e estaremos prontos para usá-lo! \\n\\nTambém certifique-se de que seu &cPokemon&r conheça o Movimento e que você não esteja usando nenhuma &bMega Evolução&r. Você não pode usar &bMega Evoluções&r com &eMovimento-Z&r. \\n\\nUma vez em Batalha, abaixo de seus Movimentos você terá a opção de usar um &eMovimento-Z&r! \\n\\nIsso irá impulsionar ou mudar seus Movimentos de qualquer forma."]
			old: ["Já está com suas joias bonitas? Dê ao seu &cPokémon&r um &eMovimento Z&r e estaremos prontos para usá-lo! \\n\\nTambém certifique-se de que seu &cPokémon&r conheça o movimento e que você não esteja usando nenhuma &bMegaevolução&r. Você não pode usar &bMegaevoluções&r com &eMovimentos Z&r. \\n\\nUma vez em batalha, abaixo de seus movimentos você terá a opção de usar um &eMovimento Z&r! \\n\\nIsso irá impulsionar ou mudar seus movimentos de qualquer forma."]
		}
		quest.6F59C939D62FA6C8.quest_desc: {
			new: ["Os &5Fragmentos Tera&r são Drops raros ao derrotar &cPokemon&r Selvagens. \\n\\nO tipo de &cPokemon&r determina o Drop, então &cPokemon&r Normais Droparão Fragmentos Tera Normais, &cPokemon de Fogo&r dão &cFragmentos Tera de Fogo&r. \\n\\nTodo &cPokemon&r tem 10% de chance de Dropá-los. Há também 1% de chance de todos os &cPokemon&r Dropar um &5Fragmento Tera Estelar&r."]
			old: ["&5Fragmentos Tera&r são drops raros ao derrotar &cPokémon&r selvagens. \\n\\nO tipo do &cPokémon&r determina o drop, então &cPokémon&r do tipo Normal droparão Fragmentos Tera Normal, e &cPokémon de Fogo&r darão &cFragmentos Tera de Fogo&r. \\n\\nTodo &cPokémon&r tem 10% de chance de dropá-los. Também há 1% de chance de todos os &cPokémon&r droparem um &5Fragmento Tera Estelar&r."]
		}
		quest.658D2E531DDB116C.title: {
			new: "&eMovimento-Z&r em ação"
			old: "&eMovimentos Z&r em ação"
		}
		quest.440B61C517B8BD09.quest_desc: {
			new: ["Com um Pincel, podemos descobrir Itens da Areia Suspeita em &eLocais Arqueológicos&r. \\n\\nDois Itens raros que podemos obter são as Pedras Brilhantes Claras e Escuras. \\n\\nNão há diferença entre elas além dos &eAnéis&r que elas Fabricam. Os &eAnéis&r apenas mudam de aparência, não de efeito ou habilidade."]
			old: ["Com um pincel, podemos descobrir itens da Areia Suspeita em &eSítios Arqueológicos&r. \\n\\nDois itens raros que podemos obter são as Pedras Brilhantes de Luz e Escuridão. \\n\\nNão há diferença entre elas além dos &eAnéis&r que elas fabricam. Os &eAnéis&r apenas mudam a aparência, não o efeito ou habilidade."]
		}
		quest.53C0C8BCCB804368.quest_desc: {
			new: ["Agora temos nossos diferentes &eMovimento-Z&r. \\n\\nAlguns apenas tornarão um Movimento ainda mais Forte, esses geralmente recebem o nome dos Tipos, como Normalium-Z. \\n\\nAlguns mudarão o Movimento de um &cPokemon&r para um diferente, como o &ePikanium-Z&r. \\n\\nE alguns são apenas estranhos, como o &6Ultranecrozium-Z&r."]
			old: ["Agora temos nossos diferentes &eMovimentos Z&r. \\n\\nAlguns apenas tornarão um movimento ainda mais forte, esses geralmente são nomeados de acordo com os tipos, como Normalium Z. \\n\\nAlguns mudarão o movimento de um &cPokémon&r para um diferente, como o &ePikanium Z&r. \\n\\nE alguns são apenas estranhos, como o &6Ultranecrozium Z&r."]
		}
		quest.2C272D1D6DE6C0F1.title: {
			new: "&5Terastalização"
			old: "&5Terastalizando"
		}
		quest.00E4E946891014D9.quest_desc: {
			new: ["Para &5Terastalizar&r precisamos de permissão. Não pergunte o porquê, eu não sei a resposta. \\n\\nA forma de conseguirmos permissão é usando um &5Orbe Tera&r. \\n\\nVocê precisará Fabricá-lo. Curiosamente, ele é feito apenas com Itens &2&lVanilla&r. \\n\\nVocê pode apenas clicar com o Botão Direito com ele para Equipar ou usar sua Tela de Acessórios."]
			old: ["Para poder &5Terastalizar&r, precisamos de permissão. Não pergunte o porquê, eu não sei a resposta. \\n\\nA maneira de conseguirmos permissão é usando um &5Orbe Tera&r. \\n\\nVocê precisará de Fabrique. Curiosamente, ele é feito apenas com itens &2&lVanilla&r. \\n\\nVocê pode simplesmente clicar com o botão direito com ele para equipar ou usar sua Tela de Acessórios."]
		}
		quest.1690E9F6BBF820D1.quest_desc: {
			new: ["Para &5Terastalizar &cPokemon&r precisaremos de muitos &5Fragmentos Tera&r. \\n\\nVamos facilitar o armazenamento de muitos desses &5Fragmentos Tera&r usando uma Bolsa! \\n\\nA Bolsa Tera pode armazenar um Pack de cada tipo de &5Fragmento Tera&r."]
			old: ["Para &5Terastalizar&r &cPokémon&r, precisaremos de muitos &5Fragmentos Tera&r. \\n\\nVamos facilitar o transporte de muitos desses &5Fragmentos Tera&r usando uma Bolsa! \\n\\nA Bolsa Tera pode guardar um pack de cada tipo de &5Fragmento Tera&r."]
		}
		quest.5C34376765740C16.quest_desc: {
			new: ["O &cCogumelo Max&r cresce em Cavernas Exuberantes. \\n\\nEle será necessário para o &cPonto de Energia&r, além de poder fazer alguns Itens de Comida para &cPokemon&r. \\n\\n&cDoce Dynamax&r que aumentará o &cNível Dynamax daquele Pokemon&r, &cMel Max&r que ativará um &cMovimento Max&r, ou &cSopa Max&r para usar o &cGigantamax&f em um &cPokemon&r!"]
			old: ["O &cCogumelo Max&r cresce em Cavernas Exuberantes. \\n\\nEle será necessário para o &cPonto de Energia&r, além de poder criar alguns itens de comida para &cPokémon&r. \\n\\n&cDoce Dynamax&r, que aumentará o &cNível Dynamax&r daquele Pokémon, &cMel Max&r, que ativará um &cMovimento Max&r, ou &cSopa Max&r para &cGigamaxizar&f um &cPokémon&r!"]
		}
		quest.7895490EEBDCF601.quest_desc: {
			new: ["O &eLocal Arqueológico&r é uma área rochosa cortada cheia de Blocos Suspeitos. \\n\\nTambém há Baús e Vasos para Loot, mas os Blocos Suspeitos são mais legais!"]
			old: ["O &eSítio Arqueológico&r é uma área rochosa repleta de blocos suspeitos. \\n\\nTambém há baús e vasos para saquear, mas os blocos suspeitos são mais legais!"]
		}
		quest.380C4222BDD65415.quest_desc: {
			new: ["Para usar o &cDynamax&r precisamos de uma Pulseira. \\n\\nUma &cPulseira Dynamax&r. \\n\\nUse-a para que possamos usar o &cDynamax &fem nossos &cPokemon&r."]
			old: ["Para &cDynamaxizar&r, precisamos de uma pulseira. \\n\\nUma &cPulseira Dynamax&r. \\n\\nUse-a para que possamos &cDynamaxizar&f nossos &cPokémon&r."]
		}
		quest.53A556F14187F399.quest_desc: {
			new: ["O Movimento-Z em Branco! \\n\\nSim, está em Branco! \\n\\nSe quisermos fazer um &eMovimento-Z&r específico, precisaremos Fabricá-lo com alguns Itens para fazer esse &eMovimento-Z&r."]
			old: ["O Movimento Z em Branco! \\n\\nSim, ele está em branco! \\n\\nSe quisermos fazer um &eMovimento Z&r específico, precisaremos de Fabrique com alguns itens para criar esse &eMovimento Z&r."]
		}
		quest.56F6B205855AF7F2.title: {
			new: "&cGigantamax"
			old: "&cGigamax"
		}
		quest.747580F66BCFB9B0.quest_desc: {
			new: ["A Pedra-chave é encontrada no centro do &bMegaroide&r. Você precisará de uma &bPicareta de Diamante&r ou superior para Minerá-la. \\n\\nCada uma dará apenas uma Pedra-chave. Felizmente não precisamos de mais do que isso! "]
			old: ["A Pedra-chave é encontrada no centro do &bMegaroide&r. Você precisará de uma &bPicareta de Diamante&r ou melhor para minerá-la. \\n\\nCada uma dará apenas uma Pedra-chave. Felizmente, não precisamos de mais do que isso! "]
		}
		quest.6309224455079059.quest_desc: {
			new: ["&5&lMega Showdown&r! É um Addon do &c&lCobble&fmon&r que nos dá... um, dois, três, quatro! Quatro maneiras diferentes de apimentar as lutas de &cPokemon&r. \\n\\nTemos &bMega formas&f, &5Terastalização&f e &cDynamax&r que mudam nosso &cPokemon&r durante a luta. Além de &eMovimento-Z&r que mudam os Movimentos de luta do nosso &cPokemon&r. \\n\\nTodos esses exigem que visitemos Estruturas, exceto a &5Terastalização&r. \\n\\nTambém precisaremos de certos Acessórios Equipados para usá-los. Olhe para o seu Inventário, então onde sua Skin é mostrada no canto superior direito estará \"Abrir Tela de Acessórios\". Aqui é onde você colocará os Itens deles para Equipá-los."]
			old: ["&5&lMega Showdown&r! É um complemento de &c&lCobble&fmon&r que nos dá... um, dois, três, quatro! Quatro maneiras diferentes de apimentar as lutas de &cPokémon&r. \\n\\nTemos &bFormas Mega&f, &5Terastalização&f e &cDynamax&r, que mudam nossos &cPokémon&r enquanto lutam. Além dos &eMovimentos Z&r, que mudam os movimentos de luta dos nossos &cPokémon&r. \\n\\nTodos esses exigem que visitemos estruturas, exceto a &5Terastalização&r. \\n\\nTambém precisaremos de certos acessórios equipados para usá-los. Olhe para o seu inventário e, onde sua skin é mostrada no canto superior direito, haverá \"Abrir Tela de Acessórios\". Aqui é onde você colocará os itens para equipá-los."]
		}
		quest.16E0E86A19015F2A.quest_desc: {
			new: ["Para ativar a &bMega Pedra&r precisaremos de um &bMega Bracelete&r. \\n\\nSim, sim, sim, eu sei que nem todos são &bBraceletes&r. \\n\\nBracelete, Anel, Tiara, tanto faz! Desde que caiba no &bEspaço Mega&r, use-o."]
			old: ["Para ativar a &bMega Pedra&r, precisaremos de um &bBracelete Mega&r. \\n\\nSim, sim, sim, eu sei que nem todos são &bBraceletes&r. \\n\\nBracelete, Anel, Tiara, o que for! Desde que caiba no &bEspaço de Mega&r, use-o."]
		}
		quest.1E01E377A2091AA6.quest_desc: {
			new: ["Os &5Fragmentos Estelares&r têm 1% de Chance de Drop quando qualquer &cPokemon&r é derrotado. \\n\\nQuando você usa 50 deles em um &cPokemon&r, ele irá &5Terastalizar&r para o &5Tipo Estelar&r. Esta é a única maneira de obtê-lo. \\n\\nO &5Tipo Estelar&r receberá um Bônus para todos os Ataques! Mas será fraco contra outros &5Tipos Estelares&r. Felizmente eles são bem raros."]
			old: ["&5Fragmentos Estelares&r têm 1% de chance de cair quando qualquer &cPokémon&r é derrotado. \\n\\nQuando você usa 50 deles em um &cPokémon&r, ele irá &5Terastalizar&r para o &5Tipo Estelar&r. Esta é a única maneira de obtê-lo. \\n\\nO &5Tipo Estelar&r receberá um bônus para todos os ataques! Mas será fraco contra outros &5Tipos Estelares&r. Felizmente, eles são bem raros."]
		}
		quest.3642AF6FE63B1C90.quest_desc: {
			new: ["Vamos revisar nossa Lista de Verificação. \\n\\n&nPokemon Segurando sua Mega Pedra&r? &aConfere&r! \\n\\n&nVocê está usando um Mega Bracelete&r? &aConfere&r! \\n\\nSe ambos estiverem marcados, quando estiver em Batalha, abaixo de seus Movimentos, você verá um Botão que diz &bMega Evoluir&r. Clique nele para ativá-lo. \\n\\nEm seguida, selecione um Movimento e seu &cPokemon&r se transformará. \\n\\nCertifique-se de não estar usando um &eMovimento-Z&r junto com &bMega Evoluções&r também, você só pode usar 1 por vez."]
			old: ["Vamos revisar nossa lista. \\n\\n&nPokémon segurando sua Mega Pedra&r? &aCheck&r! \\n\\n&nVocê está usando um Bracelete Mega&r? &aCheck&r! \\n\\nSe ambos estiverem marcados, em batalha, abaixo de seus movimentos, você verá um botão que diz &bMegaevoluir&r. Clique nele para ativá-lo. \\n\\nDepois, selecione um movimento e seu &cPokémon&r irá se transformar. \\n\\nCertifique-se de não estar usando um &eMovimento Z&r junto com &bMegaevoluções&r, você só pode usar 1 por vez."]
		}
	}
	"chapters/undergarden.snbt": {
		quest.4985F82E0D300C6D.quest_desc: {
			new: ["Se você quer ir para casa na &2&lSuperfície&r, mas não consegue encontrar o seu Portal original, não se preocupe, existe um jeito! \\n\\nCom 4 Pedras das Profundezas, 4 &7Lingotes de Cloggrum&r e uma &aPepita de Esquecido&r, você pode fabricar o Crumbling Catalyst. \\n\\nO Crumbling Catalyst funciona exatamente como o Catalyst normal na ativação de um Portal. "]
			old: ["Se você quer ir para casa no &2&lMundo Superior&r, mas não consegue encontrar o seu Portal original, não se preocupe, existe um jeito! \\n\\nCom 4 Pedras das Profundezas, 4 &7Lingotes de Cloggrum&r e uma &aPepita de Esquecido&r, você pode fabricar o Crumbling Catalyst. \\n\\nO Crumbling Catalyst funciona exatamente como o Catalyst normal na ativação de um Portal. "]
		}
	}
	"chapters/allthemodium.snbt": {
		task.00DDA48F9632A5C1.title: {
			new: "Visite a Superfície"
			old: "Visitar o Mundo Superior"
		}
		quest.2C4299D33D419AA0.title: {
			new: "&2&lSuperfície"
			old: "&2&lMundo Superior"
		}
		quest.2C4299D33D419AA0.quest_desc: {
			new: ["Coloque o Bloco de Teleporte na &2&lSuperfície&r para ir para a &7&lDimensão de Mineração&r."]
			old: ["Coloque o Bloco de Teleporte no &2&lMundo Superior&r para ir para a &7&lDimensão de Mineração&r."]
		}
		quest.6ECDD26CCCBC07C3.quest_desc: {
			new: [
				"Melhora direta da &cArmadura de Netherita&r, por isso manterá os &5Encantamentos&r. \\n\\nO conjunto completo de &6AllTheModium&r tem 24 Pontos de Armadura, 20 de Resistência de Armadura e 50% de Resistência a Repulsão. \\n\\nVocê acha que é só isso que eles dão? \\n\\n&6Elmos&r: &9Respiração Aquática&r, Imunidade ao &0Efeito de Escuridão&r do &3&lDefensor&r e nenhum Dano de &7Élitro&r. \\n&6Peitoral&r: 50% de &dResistência a Dano Mágico&r e &cResistência ao Fogo&r. \\n&6Calças&r: &9Passos Profundos&r e Imunidade ao &0Wither&r. \\n&6Botas&r: Resistem a dano de queda, permitem que você ande sobre &bNeve Fofa&r e &cLava&r."
				"{image:atm:textures/questpics/allthemodium/all_armor_all.png width:100 height:175 align:center}"
			]
			old: [
				"Melhora direta da &cArmadura de Netherita&r, por isso manterá os &5Encantamentos&r. \\n\\nO conjunto completo de &6AllTheModium&r tem 24 Pontos de Armadura, 20 de Resistência de Armadura e 50% de Resistência a Repulsão. \\n\\nVocê acha que é só isso que eles dão? \\n\\n&6Elmos&r: &9Respiração Aquática&r, Imunidade ao &0Efeito de Escuridão&r do &3&lWarden&r e nenhum Dano de &7Élitro&r. \\n&6Peitoral&r: 50% de &dResistência a Dano Mágico&r e &cResistência ao Fogo&r. \\n&6Calças&r: &9Passos Profundos&r e Imunidade ao &0Wither&r. \\n&6Botas&r: Resistem a dano de queda, permitem que você ande sobre &bNeve Fofa&r e &cLava&r."
				"{image:atm:textures/questpics/allthemodium/all_armor_all.png width:100 height:175 align:center}"
			]
		}
	}
	"chapters/pylons.snbt": {
		quest.034A9FBCA6D79BB6.quest_desc: {
			new: ["O Pilão Colheitadeira precisa de uma Enxada para funcionar.\\n\\n(Enxadas que não quebram funcionarão para sempre, enxadas que quebram precisarão ser substituídas)."]
			old: ["O Pylon Colheitadeira precisa de uma Enxada para funcionar.\\n\\n(Enxadas que não quebram funcionarão para sempre, enxadas que quebram precisarão ser substituídas)."]
		}
		quest.30B0240543253EFB.title: {
			new: "&lPilão"
			old: "&lPylons"
		}
		quest.32E52AD6EF194A60.quest_desc: {
			new: ["O Pilão de Expulsão funciona como uma forma de manter as pessoas fora do seu gramado. \\n\\nQuando colocado, ele manterá qualquer Jogador que não esteja na lista branca fora de uma quantidade definida de Chunks ao redor dele. \\n\\nOs Chunks são definidos em sua INTERFACE no canto superior esquerdo de 1x1, 3x3 ou 5x5 Chunks. \\n\\nE não, ele não pode ser colocado muito perto do Spawn. Nós sabemos o que vocês, trolls, querem e não vamos dar! \\n\\nPara colocar jogadores na lista branca, confira a Missão do Filtro de Jogador!"]
			old: ["O Pylon de Expulsão funciona como uma forma de manter as pessoas fora do seu gramado. \\n\\nQuando colocado, ele manterá qualquer Jogador que não esteja na lista branca fora de uma quantidade definida de Chunks ao redor dele. \\n\\nOs Chunks são definidos em sua INTERFACE no canto superior esquerdo de 1x1, 3x3 ou 5x5 Chunks. \\n\\nE não, ele não pode ser colocado muito perto do Spawn. Nós sabemos o que vocês, trolls, querem e não vamos dar! \\n\\nPara colocar jogadores na lista branca, confira a Missão do Filtro de Jogador!"]
		}
		quest.30B0240543253EFB.quest_desc: {
			new: ["Pylons é um mod maravilhoso feito pelo nosso próprio &aMutant Gumdrop&r!\\n\\nNão deixe o tamanho do mod te subestimar! Ele fornece muitos Pilão que podem ser usados para muitas coisas para ajudar a tornar o jogo de Minecraft mais fácil.\\n\\nPara começar, você precisará de um pouco de Blackstone Polido para fazê-los."]
			old: ["Pylons é um mod maravilhoso feito pelo nosso próprio &aMutant Gumdrop&r!\\n\\nNão deixe o tamanho do mod te subestimar! Ele fornece muitos Pylons que podem ser usados para muitas coisas para ajudar a tornar o jogo de Minecraft mais fácil.\\n\\nPara começar, você precisará de um pouco de Blackstone Polido para fazê-los."]
		}
	}
	"chapters/atm_team.snbt": {
		quest.357C9381A8155C08.quest_desc: {
			new: ["A &6Equipe AllTheMods&r ou um &2contribuidor da Comunidade&r criou esta Missão para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, é proibido usar esta Missão em pacotes públicos que a &6Equipe AllTheMods&r não tenha lançado, sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isto, está no modo de edição."]
			old: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
		}
	}
	"chapters/bounty_board.snbt": {
		quest.08D1CC753F6B4283.quest_desc: {
			new: ["O Guardião Ancião era considerado um terceiro Chefe para o Minecraft antes do Defensor, mas eu o considero um Minichefe.\\n\\nOs Guardiões Anciões aparecem em Monumentos Oceânicos. Três deles aparecem lá e infligirão Fadiga de Mineração em qualquer um por perto.\\n\\nSe você quer os tesouros do Monumento Oceânico, precisará encontrá-los e matá-los! (Dica: sempre encontrei 1 na Sala do topo, 1 no extremo esquerdo e 1 no extremo direito!)\\n\\nEles têm 80 Corações e atacam como Guardiões normais, Lasers e Espinhos!\\n\\nAo morrer, eles droparão: Esponjas, Prismarinho e o almoço deles..."]
			old: ["O Guardião Ancião era considerado um terceiro Chefe para o Minecraft antes do Warden, mas eu o considero um Minichefe.\\n\\nOs Guardiões Anciões aparecem em Monumentos Oceânicos. Três deles aparecem lá e infligirão Fadiga de Mineração em qualquer um por perto.\\n\\nSe você quer os tesouros do Monumento Oceânico, precisará encontrá-los e matá-los! (Dica: sempre encontrei 1 na Sala do topo, 1 no extremo esquerdo e 1 no extremo direito!)\\n\\nEles têm 80 Corações e atacam como Guardiões normais, Lasers e Espinhos!\\n\\nAo morrer, eles droparão: Esponjas, Prismarinho e o almoço deles..."]
		}
		task.69678CAC075C8EA5.title: {
			new: "Mate 1 Defensor"
			old: "Mate 1 Warden"
		}
		quest.0E20A9B79D1C6637.title: {
			new: "&fMate o &3Defensor"
			old: "&fMate o &3Warden"
		}
		quest.77FC692AC94D2EEF.title: {
			new: "&l&9Recompensa da Superfície:&r&e Creepers"
			old: "&l&9Recompensa do Mundo Superior:&r&e Creepers"
		}
		quest.728BE1816DA23DC0.quest_desc: {
			new: ["O Dragão do End é o Chefe que guarda O End. \\n\\nQuando você entra em um Portal do End, chegará à Ilha do End onde ele aparece. \\n\\nEle tem 200 Corações e pode atacar com Bolas de Fogo ou te atingindo. \\n\\nVocê terá que quebrar os Cristais do End nos pilares, pois eles o curam, para poder matá-lo! \\n\\nUma vez que você o mate, ele dropará: Essência Arcana, Shaderbags Épicos, Pele de Dragão, Escamas de Dragão de dois mods diferentes e um monte de experiência! \\n\\nEntão, o Portal se abrirá para que você possa retornar a Superfície, ou você pode encontrar um Portal do End para explorar as ilhas externas. Você também encontrará um Ovo de Dragão no Portal."]
			old: ["O Dragão do End é o Chefe que guarda O End. \\n\\nQuando você entra em um Portal do End, chegará à Ilha do End onde ele aparece. \\n\\nEle tem 200 Corações e pode atacar com Bolas de Fogo ou te atingindo. \\n\\nVocê terá que quebrar os Cristais do End nos pilares, pois eles o curam, para poder matá-lo! \\n\\nUma vez que você o mate, ele dropará: Essência Arcana, Shaderbags Épicos, Pele de Dragão, Escamas de Dragão de dois mods diferentes e um monte de experiência! \\n\\nEntão, o Portal se abrirá para que você possa retornar ao Mundo Superior, ou você pode encontrar um Portal do End para explorar as ilhas externas. Você também encontrará um Ovo de Dragão no Portal."]
		}
		quest.42822B1E8A53D051.title: {
			new: "&l&9Recompensa da Superfície:&r&e Esqueletos"
			old: "&l&9Recompensa do Mundo Superior:&r&e Esqueletos"
		}
		quest.1F18B64C84C8809D.title: {
			new: "&l&9Recompensa da Superfície:&r&e Aranhas"
			old: "&l&9Recompensa do Mundo Superior:&r&e Aranhas"
		}
		quest.0E20A9B79D1C6637.quest_desc: {
			new: ["O Defensor é um chefe adicionado na 1.20.\\n\\nEle aparece quando 3 Sculk Shriekers que surgem naturalmente são ativados em sequência, ou quando qualquer Shrieker é ativado após a aparição do primeiro Defensor.\\n\\nEle é o Mob mais poderoso adicionado pelo Minecraft, com 500 Corações e mais de 20 Corações de dano com seus ataques.\\n\\nSeus ataques incluem te atingir e Explosões Sônicas para os mais distantes.\\n\\nSua única fraqueza é ser cego, mas como o Demolidor, isso apenas tornou seus outros sentidos muito mais fortes! Se você estiver perto, ele pode te cheirar e cuidado ao fazer barulho!\\n\\nSe de alguma forma você matá-lo, ele dropará: Catalisadores de Sculk, Carapaça de Defensor e Coração das Profundezas."]
			old: ["O Warden é um chefe adicionado na 1.20.\\n\\nEle aparece quando 3 Sculk Shriekers que surgem naturalmente são ativados em sequência, ou quando qualquer Shrieker é ativado após a aparição do primeiro Warden.\\n\\nEle é o Mob mais poderoso adicionado pelo Minecraft, com 500 Corações e mais de 20 Corações de dano com seus ataques.\\n\\nSeus ataques incluem te atingir e Explosões Sônicas para os mais distantes.\\n\\nSua única fraqueza é ser cego, mas como o Demolidor, isso apenas tornou seus outros sentidos muito mais fortes! Se você estiver perto, ele pode te cheirar e cuidado ao fazer barulho!\\n\\nSe de alguma forma você matá-lo, ele dropará: Catalisadores de Sculk, Carapaça de Warden e Coração das Profundezas."]
		}
		quest.2B05A29C62676EB2.title: {
			new: "&l&9Recompensa da Superfície:&r&e Zumbis"
			old: "&l&9Recompensa do Mundo Superior:&r&e Zumbis"
		}
		quest.5AC497F76A086A5C.title: {
			new: "&l&9Recompensa da Superfície:&r&e Bruxas"
			old: "&l&9Recompensa do Mundo Superior:&r&e Bruxas"
		}
		task.452B65E139D9E12D.title: {
			new: "Mate 1 Wilden Quimera"
			old: "Mate 1 Wilden Chimera"
		}
	}
	"chapters/occultism.snbt": {
		quest.4C873491F6F0FFAF.quest_desc: {
			new: [
				"Usando &dFogo Espiritual&r, podemos converter vários materiais da Superfície em suas variantes do Outro Mundo. Você também pode encontrar vários materiais do Outro Mundo sob os efeitos do &bTerceiro Olho&r e se aventurando pelo mundo. Você pode se surpreender com o que encontrará. Para facilitar, existem receitas de fabricação para os materiais básicos, jogando-os no &dFogo Espiritual&r."
				""
				"&bAndesito&r se converte em &3Pedra do Outro&r, que pode ser usada para acender um &dFogo Espiritual&r permanente."
				""
				"Mudas de &aCarvalho&r se convertem em &9Mudas de Carvalho&r, mas não são as mesmas. Quando crescidas, elas se parecerão exatamente com uma árvore de Carvalho normal. No entanto, sob os efeitos do &bTerceiro Olho&r, você poderá colher a variante do Outro Mundo."
				""
				"Se você tiver problemas para coletar os troncos (se eles se transformarem em troncos de Carvalho normais mesmo com o &bTerceiro Olho&r), tente coletá-los pelo topo."
				""
				"&eDiamantes&r se transformarão em &dGemas Sintonizadas com Espírito&r, que são usadas em várias receitas que precisaremos mais tarde."
			]
			old: [
				"Usando &dFogo Espiritual&r, podemos converter vários materiais do Mundo Superior em suas variantes do Outro Mundo. Você também pode encontrar vários materiais do Outro Mundo sob os efeitos do &bTerceiro Olho&r e se aventurando pelo mundo. Você pode se surpreender com o que encontrará. Para facilitar, existem receitas de fabricação para os materiais básicos, jogando-os no &dFogo Espiritual&r."
				""
				"&bAndesito&r se converte em &3Pedra do Outro&r, que pode ser usada para acender um &dFogo Espiritual&r permanente."
				""
				"Mudas de &aCarvalho&r se convertem em &9Mudas de Carvalho&r, mas não são as mesmas. Quando crescidas, elas se parecerão exatamente com uma árvore de Carvalho normal. No entanto, sob os efeitos do &bTerceiro Olho&r, você poderá colher a variante do Outro Mundo."
				""
				"Se você tiver problemas para coletar os troncos (se eles se transformarem em troncos de Carvalho normais mesmo com o &bTerceiro Olho&r), tente coletá-los pelo topo."
				""
				"&eDiamantes&r se transformarão em &dGemas Sintonizadas com Espírito&r, que são usadas em várias receitas que precisaremos mais tarde."
			]
		}
		quest.367E891A50991436.quest_desc: {
			new: ["Usando o &cConfinamento Permanente de Sevira&r, podemos combinar vários materiais diferentes de Wither e um pouco de Netherite para criar três Pó de Witherita. Com estes, podemos criar para nós mesmos a forma mais elevada de Giz de Fundação, o Giz Preto."]
			old: ["Usando o &cConfinamento Permanente de Sevira&r, podemos combinar vários materiais diferentes de Wither e um pouco de Netherite para criar três Pós de Witherita. Com estes, podemos criar para nós mesmos a forma mais elevada de Giz de Fundação, o Giz Preto."]
		}
	}
