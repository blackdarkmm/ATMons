		quest.3E301F3EEC8C763A.quest_desc: {
			new: [
				"Isso pode ser usado para acelerar o ritmo de crescimento das abelhas bebês, ou para criar novos Ovos Gerador.\\n\\nColoque uma abelha bebê enjaulada com 20 Guloseimas de Mel para transformá-la em um adulto.\\n\\nPara criar Ovos Gerador, você precisará combinar o gene da abelha desejada com uma guloseima de mel, depois usar essa guloseima de mel nesta máquina com um ovo para criar o novo Ovo Gerador.\\n\\nOs genes podem ser combinados para uma pureza máxima de 100%, o que lhe dará 100% de chance de converter um Ovo em um Ovo Gerador de Abelha."
				"{@pagebreak}"
				"Você também pode aplicar genes em uma abelha sem retirá-la da sua gaiola com isso. Coloque uma Guloseima de Mel com as amostras de gene de sua escolha no incubador junto com uma gaiola de abelha contendo a abelha na qual você quer aplicar os genes."
			]
			old: [
				"Isso pode ser usado para acelerar o ritmo de crescimento das abelhas bebês, ou para criar novos Ovos de Geração.\\n\\nColoque uma abelha bebê enjaulada com 20 Guloseimas de Mel para transformá-la em um adulto.\\n\\nPara criar Ovos de Geração, você precisará combinar o gene da abelha desejada com uma guloseima de mel, depois usar essa guloseima de mel nesta máquina com um ovo para criar o novo Ovo de Gerador.\\n\\nOs genes podem ser combinados para uma pureza máxima de 100%, o que lhe dará 100% de chance de converter um Ovo em um Ovo de Gerador de Abelha."
				"{@pagebreak}"
				"Você também pode aplicar genes em uma abelha sem retirá-la da sua gaiola com isso. Coloque uma Guloseima de Mel com as amostras de gene de sua escolha no incubador junto com uma gaiola de abelha contendo a abelha na qual você quer aplicar os genes."
			]
		}
		quest.2E0275C21D3F0DA3.quest_subtitle: {
			new: "Criado por Fusão Wyvern"
			old: "Wyvern Fusão de Criação"
