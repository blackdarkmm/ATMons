	"chapters/mekanism.snbt": {
		task.6DCF32EB40B8E9C6.title: {
			new: "Pó de Minério"
			old: "Pós de Minério"
		}
		quest.566C1DBA9829E328.quest_desc: {
			new: ["O &e&lCombinador&r pode automatizar Receitas simples de 2 &eItens&r! \\n\\nComo 2 Corantes diferentes, ou Lama e Trigo para obter Lama Compactada. \\n\\nEle pode até fazer algumas Receitas novas e únicas como &7Pedregulho&f e &0Sílex&r para fazer &7Cascalho&r, ou 4 &5Pó de Obsidiana&r e &8Ardosiabissal&f para fazer &5Obsidiana&r!"]
			old: ["O &e&lCombinador&r pode automatizar Receitas simples de 2 &eItens&r! \\n\\nComo 2 Corantes diferentes, ou Lama e Trigo para obter Lama Compactada. \\n\\nEle pode até fazer algumas Receitas novas e únicas como &7Pedregulho&f e &0Sílex&r para fazer &7Cascalho&r, ou 4 &5Pós de Obsidiana &f e &8Ardósia Profunda&f para fazer &5Obsidiana&r!"]
		}
		quest.6DC1E08D019FD543.quest_desc: {
			new: [
				"Nossos &7Cristais&r precisarão de ainda mais &lProcessamento&r! \\n\\nRepita os passos anteriores de fazer uma &6&lPlanta de Evaporação Térmico&r para criar &eSalmoura&r. \\n\\nUse um &9&lSeparador Eletrolítico&r para Separar o &eCloro &fda &eSalmoura&r. \\n\\nEm seguida, obtenha &bOxigênio&r colocando &9Água &fem um &9&lSeparador Eletrolítico&r. \\n\\nCombine o &eCloro &fe o &bHidrogênio &fem um &a&lInfusor Químico&r para obter &3Cloreto de Hidrogênio&r! \\n\\nCom nosso &c&lInjetor Químico&r, podemos &cInjetar &fos &7Cristais&f com &3Cloreto de Hidrogênio&r para obter 2 &7Fragmentos de Minério&r de cada &7Cristal de Minério&r."
				"{image:atm:textures/questpics/mek/mek_tier4_3.png width:250 height:100 align:center}"
			]
			old: [
				"Nossos &7Cristais&r precisarão de ainda mais &lProcessamento&r! \\n\\nRepita os passos anteriores de fazer uma &6&lPlanta de Evaporação Térmico&r para criar &eSalmoura&r. \\n\\nUse um &9&lSeparador Eletrolítico&r para Separar o &eCloro &fda &eSalmoura&r. \\n\\nEm seguida, obtenha &bOxigênio&r colocando &9Água &fem um &9&lSeparador Eletrolítico&r. \\n\\nCombine o &eCloro &fe o &bOxigênio &fem um &a&lInfusor Químico&r para obter &3Cloreto de Hidrogênio&r! \\n\\nCom nosso &c&lInjetor Químico&r, podemos &cInjetar &fos &7Cristais&f com &3Cloreto de Hidrogênio&r para obter 2 &7Fragmentos de Minério&r de cada &7Cristal de Minério&r."
				"{image:atm:textures/questpics/mek/mek_tier4_3.png width:250 height:100 align:center}"
			]
		}
		quest.67E7A9A65B14C933.quest_desc: {
			new: [
				"Conseguimos &7Aglomerados de Minério&r? O que fazemos com um &7Aglomerado&r, queríamos &7Barras&r! \\n\\nPara começar, &4Esmague &fcada &7Aglomerado&f para obter 2 &7Pó de Minério Sujo&r. \\n\\nNão podemos &6Fundir &7Pó Sujo&r, isso estragaria a Fornalha! Então precisaremos &dEnriquecê-los&r para obter nosso &7Pó&r comum. \\n\\nE como de costume, &6Funda &fo &7Pó &fpara obter &7Barras&r."
				"{image:atm:textures/questpics/mek/mek_tier2_2.png width:250 height:50 align:center}"
			]
			old: [
				"Conseguimos &7Aglomerados de Minério&r? O que fazemos com um &7Aglomerado&r, queríamos &7Barras&r! \\n\\nPara começar, &4Esmague &fcada &7Aglomerado&f para obter 2 &7Pós de Minério Sujo&r. \\n\\nNão podemos &6Fundir &7Pó Sujo&r, isso estragaria a Fornalha! Então precisaremos &dEnriquecê-los&r para obter nosso &7Pó&r comum. \\n\\nE como de costume, &6Funda &fo &7Pó &fpara obter &7Barras&r."
				"{image:atm:textures/questpics/mek/mek_tier2_2.png width:250 height:50 align:center}"
			]
		}
		quest.08DDE018A804BFE7.quest_desc: {
			new: ["A &d&lCâmara de Enriquecimento&r &dEnriquecerá&r &eItens&r que passam por ela. Basta colocar os &eItens&r nos &4Slots Vermelhos&r e os &dItens Enriquecidos&r sairão dos &9Slots Azuis&r.\\n\\nO que é um &dItem Enriquecido&r? Ou o que acontece quando um &eItem&r é &dEnriquecido&r? Ou obtemos mais dos &eItens&r em que pode ser transformado, ou mudamos os &eItens&r em si!\\n\\nPodemos obter 2 Pó de 1 Minério. Podemos obter mais Corantes de uma Flor. Podemos até mudar os Estágios do &6Cobre&r ou remover &2Musgo&r de &7Pedregulho&r!\\n\\nCom Níveis posteriores de &d&lCâmaras de Enriquecimento&r, obtemos ainda mais Slots para &dEnriquecer&f mais &eItens&r de uma vez.\\n\\nTambém ganhamos a habilidade de Classificar Automaticamente. Com o pressionar deste Botão! Podemos configurá-lo para que as Pilhas de &eItens&r sejam distribuídas uniformemente para cada Slot, para que a &d&lMáquina&r seja mais Eficiente."]
			old: ["A &d&lCâmara de Enriquecimento&r &dEnriquecerá&r &eItens&r que passam por ela. Basta colocar os &eItens&r nos &4Slots Vermelhos&r e os &dItens Enriquecidos&r sairão dos &9Slots Azuis&r.\\n\\nO que é um &dItem Enriquecido&r? Ou o que acontece quando um &eItem&r é &dEnriquecido&r? Ou obtemos mais dos &eItens&r em que pode ser transformado, ou mudamos os &eItens&r em si!\\n\\nPodemos obter 2 Pós de 1 Minério. Podemos obter mais Corantes de uma Flor. Podemos até mudar os Estágios do &6Cobre&r ou remover &2Musgo&r de &7Pedregulho&r!\\n\\nCom Níveis posteriores de &d&lCâmaras de Enriquecimento&r, obtemos ainda mais Slots para &dEnriquecer&f mais &eItens&r de uma vez.\\n\\nTambém ganhamos a habilidade de Classificar Automaticamente. Com o pressionar deste Botão! Podemos configurá-lo para que as Pilhas de &eItens&r sejam distribuídas uniformemente para cada Slot, para que a &d&lMáquina&r seja mais Eficiente."]
		}
		quest.47F38E606AD3FF53.quest_desc: {
			new: ["Algumas Receitas exigirão &7Pó de Minério&r! \\n\\nGraças ao &6&lAllTheOres&r, podemos fazer &7Pós de Minério&r de um milhão de maneiras diferentes! \\n\\nAs maneiras do &5&lMekanism&r são com o &4&lTriturador&r e a &d&lCâmara de Enriquecimento&r. \\n\\nPodemos &4Triturar&r &7Barras&f em &7Pó&r. Ou &dEnriquecer&r &7Blocos de Minério&r para obter 2 &7Pós&r."]
			old: ["Algumas Receitas exigirão &7Pós de Minério&r! \\n\\nGraças ao &6&lAllTheOres&r, podemos fazer &7Pós de Minério&r de um milhão de maneiras diferentes! \\n\\nAs maneiras do &5&lMekanism&r são com o &4&lTriturador&r e a &d&lCâmara de Enriquecimento&r. \\n\\nPodemos &4Triturar&r &7Barras&f em &7Pó&r. Ou &dEnriquecer&r &7Blocos de Minério&r para obter 2 &7Pós&r."]
		}
		quest.1AEFF93A398B8BBF.quest_desc: {
			new: ["O &b&lTier Elite&r vem logo após o &c&lAvançado&r. Estes têm os mesmos bônus que o &c&lAvançado&r... só que mais! \\n\\n&b&lElite&r são feitos com &bLigas Reforçadas&f, &bCircuitos de Controle Elite&f, e na maioria das vezes &eGold Ingots&r. \\n\\nVocê pode obter &bLigas Reforçadas&r infundindo uma &cLiga Infundida&r com 20mb de &bDiamante&r. Isso são 2 &bPó de Diamante&r ou 1/4 de &bDiamante Enriquecido&r! \\n\\nVocê pode então usar essas &bLigas Reforçadas&r (2 delas) com um &cCircuito de Controle Avançado&r para fazer o &bCircuito de Controle Elite&r."]
			old: ["O &b&lTier Elite&r vem logo após o &c&lAvançado&r. Estes têm os mesmos bônus que o &c&lAvançado&r... só que mais! \\n\\n&b&lElite&r são feitos com &bLigas Reforçadas&f, &bCircuitos de Controle Elite&f, e na maioria das vezes &eGold Ingots&r. \\n\\nVocê pode obter &bLigas Reforçadas&r infundindo uma &cLiga Infundida&r com 20mb de &bDiamante&r. Isso são 2 &bPós de Diamante&r ou 1/4 de &bDiamante Enriquecido&r! \\n\\nVocê pode então usar essas &bLigas Reforçadas&r (2 delas) com um &cCircuito de Controle Avançado&r para fazer o &bCircuito de Controle Elite&r."]
		}
	}
	"chapters/apothic_enchanting.snbt": {
		quest.51E554305FFEBA1D.quest_desc: {
			new: ["&4Estantes Infernais Blazing&r dão um pouco de &cQuanta&r e &aEterna&r, mas não são a opção barata que estamos procurando para nossas &d&lInfusões&r!"]
			old: ["&4Estantes Infernais Flamejantes&r dão um pouco de &cQuanta&r e &aEterna&r, mas não são a opção barata que estamos procurando para nossas &d&lInfusões&r!"]
		}
		quest.78FEDE6FA4845585.quest_desc: {
			new: ["Algumas &d&lInfusões&r precisam de quantidades muito, muito exatas de &aEterna&r, &cQuanta&r ou &5Arcana&r. \\n\\nPara obtê-las, você pode precisar de uma destas &7Estantes&r. \\n\\nCada uma diminui a quantidade de suas respectivas qualidades."]
			old: ["Algumas &d&lInfusões&r precisam de quantidades muito, muito exatas de &aEterna&r, &cQuanta&r ou &5Arcana&r. \\n\\nPara obtê-las, você pode precisar de uma destas &7Prateleiras&r. \\n\\nCada uma diminui a quantidade de suas respectivas qualidades."]
		}
		quest.148A33CC36B2563A.title: {
			new: "&dEstante do End Dracônica"
			old: "&dPrateleira do End Dracônica"
		}
		quest.1873205CF5247E3E.quest_desc: {
			new: [
				"A última e maior das &7Estantes&r, as &dEstantes do End&r! \\n\\nElas são criadas com 6 &eTijolos de Pedra do End&r, 1 &3Pérola do End&r, 1 &7Estante de Livros&r e, claro, o &dBafo de Dragão Infundido&r. \\n\\nSeus status não são os melhores atualmente, dando apenas 5 para cada. Mas seu máximo de &aEterna&r de &a90&r é incrível! \\n\\nAh, sim, e elas podem ser Criadas com outros Itens para atualizá-las!"
				"{image:atm:textures/questpics/apothic/enchant_endshelf.png width:100 height:100 align:center}"
			]
			old: [
				"A última e maior das &7Estantes&r, as &dEstantes do End&r! \\n\\nElas são criadas com 6 &eTijolos de Endstone&r, 1 &3Pérola do End&r, 1 &7Estante de Livros&r e, claro, o &dBafo de Dragão Infundido&r. \\n\\nSeus status não são os melhores atualmente, dando apenas 5 para cada. Mas seu máximo de &aEterna&r de &a90&r é incrível! \\n\\nAh, sim, e elas podem ser Criadas com outros Itens para atualizá-las!"
				"{image:atm:textures/questpics/apothic/enchant_endshelf.png width:100 height:100 align:center}"
			]
		}
		quest.2EC2FA680076C07D.quest_desc: {
			new: ["Para aprimorar as &9Estantes Profundas&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Fabricação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados nas &9Profundezas Escuras&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Defensor&r... este é um Drop do &9&lDefensor&r... Sim, você precisará matar o &9&lDefensor&r. \\n\\nQuando tiver tudo isso, poderá fabricar uma das melhores &7Estantes de Livros&r! Uma que dá &a10 Eterna&r, &c10% Quanta&r e &515% Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase em 100!"]
			old: ["Para aprimorar as &9Estantes Profundas&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Fabricação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados nas &9Profundezas Escuras&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Warden&r... este é um Drop do &9&lWarden&r... Sim, você precisará matar o &9&lWarden&r. \\n\\nQuando tiver tudo isso, poderá fabricar uma das melhores &7Estantes de Livros&r! Uma que dá &a10 Eterna&r, &c10% Quanta&r e &515% Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase em 100!"]
		}
		quest.42746659C66CF17F.quest_desc: {
			new: ["A &6&oBiblioteca de Alexandria&r é uma &5Biblioteca de Encantamentos&r melhor. \\n\\nEla pode conter Níveis mais altos de &5Livros Encantados&r, mas ainda precisará do Nível do &5Livro&r para ser retirado nesse Nível. \\n\\nEla também conterá mais Pontos. A &5Biblioteca de Encantamentos&r pode conter 32768, enquanto a &6&oBiblioteca de Alexandria&r pode conter 1.1 Bilhão de Pontos de cada &5Livro&r! \\n\\nPara obtê-la, precisaremos &d&lInfundir&r a &5Biblioteca de Encantamentos&r. \\n\\nUse 4 &9Estante de Sculk Tocada por Almas&f, 4 &9Estante das Profundezas Ecoante&f, 1 &dEstante de Livro do End Dracônica&f, 5 &6Estantes de Estabilidade Revestidas de Geodo&r e uma Caveira de Esqueleto."]
			old: ["A &6&oBiblioteca de Alexandria&r é uma &5Biblioteca de Encantamentos&r melhor. \\n\\nEla pode conter Níveis mais altos de &5Livros Encantados&r, mas ainda precisará do Nível do &5Livro&r para ser retirado nesse Nível. \\n\\nEla também conterá mais Pontos. A &5Biblioteca de Encantamentos&r pode conter 32768, enquanto a &6&oBiblioteca de Alexandria&r pode conter 1.1 Bilhão de Pontos de cada &5Livro&r! \\n\\nPara obtê-la, precisaremos &d&lInfundir&r a &5Biblioteca de Encantamentos&r. \\n\\nUse 4 &9Prateleiras de Sculk Tocadas pela Alma&f, 4 &9Prateleiras de Sculk Ecoantes&f, 1 &dEstante de Livro do End Dracônica&f, 5 &6Estantes de Estabilidade Revestidas de Geodo&r e uma Caveira de Esqueleto."]
		}
		quest.516E66BE01EE5B31.quest_desc: {
			new: ["&8Tomos de Armamento&r darão &5Encantamentos&r para Espadas e Machados. \\n\\nPrincipalmente aqueles que ajudam a Matar coisas! Como &5Afiação &fe &5Aspecto de Fogo&r. \\n&8Tomos de Arquearia&r darão &5Encantamentos&r para Armas de longo alcance, o Arco e a Besta. \\n\\n&5Perfuração&f, &5Força&f, e &5Repulsão&r!"]
			old: ["&8Tomos de Armamento&r darão &5Encantamentos&r para Espadas e Machados. \\n\\nPrincipalmente aqueles que ajudam a Matar coisas! Como &5Afiação &fe &5Aspecto Flamejante&r. \\n&8Tomos de Arquearia&r darão &5Encantamentos&r para Armas de longo alcance, o Arco e a Besta. \\n\\n&5Perfuração&f, &5Força&f, e &5Repulsão&r!"]
		}
		quest.24FCFF18296ED907.quest_desc: {
			new: ["Para aprimorar as &9Estante de Livros Profunda&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Criação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados dentro do &9Deep Dark&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Defensor&r... este é um Drop do &9&lDefensor&r... Sim, você precisará matar o &9&lDefensor&r. \\n\\nQuando tiver tudo isso, poderá criar uma das melhores &7Estantes&r! Uma que dá &a10 de Eterna&r, &c15% de Quanta&r e &510% de Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase 100!"]
			old: ["Para aprimorar as &9Estante de Livros Profunda&r ainda mais, surpreendentemente não precisamos de &d&lInfusão&r! Em vez disso, precisamos de mais Criação! \\n\\nPrimeiro, são 5 &3Blocos de Sculk&r e um &3Catalisador de Sculk&r. Ambos podem ser encontrados dentro do &9Deep Dark&r e precisarão de &5Toque Suave&r para coletar. \\n\\nPor último, há o &9Tentáculo do Warden&r... este é um Drop do &9&lWarden&r... Sim, você precisará matar o &9&lWarden&r. \\n\\nQuando tiver tudo isso, poderá criar uma das melhores &7Estantes&r! Uma que dá &a10 de Eterna&r, &c15% de Quanta&r e &510% de Arcana&r. \\n\\nE o mais importante, nos dá um máximo de &aEterna&r de &a80&r! Quase 100!"]
		}
		quest.51E554305FFEBA1D.title: {
			new: "&4Estante Infernal Blazing"
			old: "&4Estante Infernal Flamejante"
		}
		quest.148A33CC36B2563A.quest_desc: {
			new: ["A &dEstante Dracônica&r é a última Estante que precisaremos para a configuração perfeita. \\n\\nPode dar apenas &aEterna&r, mas tem o máximo de &aEterna&r de &a100&r. \\n\\nPara criá-la, precisaremos de 5 &3Pérolas do End&r e uma &dCabeça de Dragão&r. É isso que a torna &dDracônica&r! \\n\\nPara obtê-las, você pode usar &a&lMA&r ou encontrá-las em &dNavios do End&r. Os &dNavios do End&r são Estruturas no &d&lO End&r, na proa (frente) fica a &dCabeça de Dragão&r."]
			old: ["A &dPrateleira Dracônica&r é a última Prateleira que precisaremos para a configuração perfeita. \\n\\nPode dar apenas &aEterna&r, mas tem o máximo de &aEterna&r de &a100&r. \\n\\nPara criá-la, precisaremos de 5 &3Pérolas do End&r e uma &dCabeça de Dragão&r. É isso que a torna &dDracônica&r! \\n\\nPara obtê-las, você pode usar &a&lMA&r ou encontrá-las em &dNavios do End&r. Os &dNavios do End&r são Estruturas no &d&lO End&r, na proa (frente) fica a &dCabeça de Dragão&r."]
		}
	}
	"chapters/forbidden__arcanus.snbt": {
		quest.5ED0DA95BAE43D88.quest_desc: {
			new: ["O último dos Prismas, bem, este é um &dCristal&r, mas você entendeu a ideia! \\n\\nPrimeiro, você precisará de uma Relíquia &eDivine Pact&r, que é encontrada em &b&lO Outro&r. \\n\\nEntão, você precisará de &3Fragmentos de Pérola do End&r, &5Ametista&r e Quartzo do Nether. Não se preocupe, fica mais difícil! \\n\\nAgora precisaremos de todos os tipos de Alma. Eu ensinei como obter Almas e &9Almas Corrompidas&r em outras Missões, agora vou ensinar sobre &dAlmas Encantadas&r. \\n\\nEncontre uma Alma Perdida voando pelo seu mundo, então jogue uma &bPoção de Aureal Arremessável&r nela! Então, ela se tornará uma &dAlma Perdida Encantada&r, mate-a! \\n\\nCom isso, você agora pode fazer o &dCristal&r, que pode ser aplicado a Ferramentas e Armaduras para dar-lhes Soulbound. Isso significa que quando você morrer, você reaparecerá com esses Itens em seu Inventário ainda."]
			old: ["O último dos Prismas, bem, este é um &dCristal&r, mas você entendeu a ideia! \\n\\nPrimeiro, você precisará de uma Relíquia &eDivine Pact&r, que é encontrada em &b&lO Outro&r. \\n\\nEntão, você precisará de &3Fragmentos de Enderpearl&r, &5Ametista&r e Quartzo do Nether. Não se preocupe, fica mais difícil! \\n\\nAgora precisaremos de todos os tipos de Alma. Eu ensinei como obter Almas e &9Almas Corrompidas&r em outras Missões, agora vou ensinar sobre &dAlmas Encantadas&r. \\n\\nEncontre uma Alma Perdida voando pelo seu mundo, então jogue uma &bPoção de Aureal Arremessável&r nela! Então, ela se tornará uma &dAlma Perdida Encantada&r, mate-a! \\n\\nCom isso, você agora pode fazer o &dCristal&r, que pode ser aplicado a Ferramentas e Armaduras para dar-lhes Soulbound. Isso significa que quando você morrer, você reaparecerá com esses Itens em seu Inventário ainda."]
		}
		quest.15849165CA8C00F9.quest_desc: {
			new: [
				"A última e mais poderosa &6&lForja&r, claro que isso significa que é a mais cara! \\n\\nVocê precisará de 2 &5Estrelas do Nether Escuras&r, que são feitas combinando 4 &5Obsidiansteel&r e uma Estrela do Nether. \\n\\n2 &dEscamas de Dragão&r que são dropadas quando o &dDragão do End&r morre. \\n\\n4 &3Catalisadores de Sculk&r que são dropados do &3Defensor&r, ou podem ser obtidos com Toque Suave no Deep Dark. \\n\\nE um &2Bloco de Estelarita&r que são apenas 9 &2Fragmento de Stellarita&r! \\n\\nIsso permite ainda mais Essências e Receitas de Fim de Jogo."
				"{image:atm:textures/questpics/forbidden/forbidden_tier5.png width:100 height:100 align:center}"
			]
			old: [
				"A última e mais poderosa &6&lForja&r, claro que isso significa que é a mais cara! \\n\\nVocê precisará de 2 &5Estrelas do Nether Escuras&r, que são feitas combinando 4 &5Obsidiansteel&r e uma Estrela do Nether. \\n\\n2 &dEscamas de Dragão&r que são dropadas quando o &dDragão do End&r morre. \\n\\n4 &3Catalisadores de Sculk&r que são dropados do &3Warden&r, ou podem ser obtidos com Toque Suave no Deep Dark. \\n\\nE um &2Bloco de Estelarita&r que são apenas 9 &2Fragmento de Stellarita&r! \\n\\nIsso permite ainda mais Essências e Receitas de Fim de Jogo."
				"{image:atm:textures/questpics/forbidden/forbidden_tier5.png width:100 height:100 align:center}"
			]
		}
		quest.03C54B07106091DD.quest_desc: {
			new: ["O &cPrisma de Fundição&r é provavelmente o Item mais usado desses Rituais, assim como é necessário para a &6&lEstrela ATM&r!\\n\\nVocê precisará de 4 &cPó de Blaze&r, 2 &8Carvões&r e um bloco de &bCristal Arcano&r para fazê-lo. E não se esqueça da Relíquia de &3Elementarium&r!\\nObviamente, e o que você provavelmente mais quer do &cPrisma de Fundição&r, é a &6&lEstrela ATM&r. Ele também pode ser usado com Ferramentas para Fundir os Itens que elas quebram: Minério Bruto em Barras, Troncos em Carvão Vegetal, Areia em Vidro.\\n\\nVocê também pode usá-lo como Combustível de Fornalha, mas é meio ruim. O que é bobo, porque o nome sugere que seria melhor!"]
			old: ["O &cPrisma de Fundição&r é provavelmente o Item mais usado desses Rituais, assim como é necessário para a &6&lEstrela ATM&r!\\n\\nVocê precisará de 4 &cPós de Blaze&r, 2 &8Carvões&r e um bloco de &bCristal Arcano&r para fazê-lo. E não se esqueça da Relíquia de &3Elementarium&r!\\nObviamente, e o que você provavelmente mais quer do &cPrisma de Fundição&r, é a &6&lEstrela ATM&r. Ele também pode ser usado com Ferramentas para Fundir os Itens que elas quebram: Minério Bruto em Barras, Troncos em Carvão Vegetal, Areia em Vidro.\\n\\nVocê também pode usá-lo como Combustível de Fornalha, mas é meio ruim. O que é bobo, porque o nome sugere que seria melhor!"]
		}
		quest.487C70679535DDDB.quest_desc: {
			new: ["Você não odeia aquelas limitações estúpidas no seu Capturador Quântico? Não pode colocar Defensores na base dos seus amigos! \\n\\nBem, agora não há mais preocupações, pois podemos aprimorar nosso Capturador Quântico com 3 &2Fragmento de Stellarita&r e uma Estrela do Nether para fazer o Capturador de Chefes. \\n\\nAgora podemos transportar nossos Chefes para onde quisermos!"]
			old: ["Você não odeia aquelas limitações estúpidas no seu Capturador Quântico? Não pode colocar Wardens na base dos seus amigos! \\n\\nBem, agora não há mais preocupações, pois podemos aprimorar nosso Capturador Quântico com 3 &2Fragmento de Stellarita&r e uma Estrela do Nether para fazer o Capturador de Chefes. \\n\\nAgora podemos transportar nossos Chefes para onde quisermos!"]
		}
		quest.580148D1141446A6.quest_desc: {
			new: [
				"&c&lO Nether&r é assustador demais para você? Então, você pode procurar Almas na &2&lSuperfície&r!\\n\\nDentro do seu mundo (eu te fiz ir para Florestas Escuras porque o antigo &l&6Forbidden \\& Arcanus&r costumava ter blocos lá) você pode encontrar algumas Almas Perdidas vagando por aí.\\n\\nVocê pode matá-las pelas Almas que elas dropam! Mas é bem menos eficiente...\\n"
				"Se estiver tendo dificuldades para encontrar Almas, talvez queira considerar o encantamento Saque de Alma para sua espada. Matar mobs com esse encantamento ocasionalmente fará aparecer Almas."
			]
			old: [
				"&c&lO Nether&r é assustador demais para você? Então, você pode procurar Almas no &2&lMundo Superior&r!\\n\\nDentro do seu mundo (eu te fiz ir para Florestas Escuras porque o antigo &l&6Forbidden \\& Arcanus&r costumava ter blocos lá) você pode encontrar algumas Almas Perdidas vagando por aí.\\n\\nVocê pode matá-las pelas Almas que elas dropam! Mas é bem menos eficiente...\\n"
				"Se estiver tendo dificuldades para encontrar Almas, talvez queira considerar o encantamento Saque de Alma para sua espada. Matar mobs com esse encantamento ocasionalmente fará aparecer Almas."
			]
		}
	}
	"chapters/applied_energistics_2.snbt": {
		quest.79D2617E01481281.quest_desc: {
			new: ["Para começar com o AE2, você precisará minerar um recurso importante para o mod conhecido como &bQuartzo Certus&r. Você encontrará Cristais de Quartzo Certus em Meteoritos que você pode minerar para obter &ePó&r e &eCristais&r de &bQuartzo Certus&r."]
			old: ["Para começar com o AE2, você precisará minerar um recurso importante para o mod conhecido como &bQuartzo Certus&f. Você encontrará Cristais de Quartzo Certus em Meteoritos que você pode minerar para obter &ePó&f e &eCristais&f de &bQuartzo Certus&r."]
		}
		quest.0F03E75CF79BADD7.title: {
			new: "&eArmazenamento para Itens em Massa"
			old: "&eArmazenamento de Itens em Massa"
		}
		quest.1348995F64A94396.quest_desc: {
			new: ["O &bMonitor de Fabricação&r exibe o item geral sendo criado, junto com a quantidade restante desse item que ainda está sendo criada.\\n\\nTanto o monitor base do &9AE2&r quanto o monitor &5MEGA&r funcionam de forma idêntica, mas são fornecidos para fins estéticos."]
			old: ["O &bMonitor de Fabricação&f exibe o item geral sendo criado, junto com a quantidade restante desse item que ainda está sendo criada.\\n\\nTanto o monitor base do &9AE2&r quanto o monitor &5MEGA&r funcionam de forma idêntica, mas são fornecidos para fins estéticos."]
		}
		quest.2077D64428E9C067.quest_desc: {
			new: [
				"Um conceito importante dentro do AE2 é uma técnica conhecida como '&esub-rede&r', na qual uma Rede ME extra separada (uma &esub-rede&r) atua em conjunto com a rede principal para executar alguma função ou processo especializado. "
				""
				"O que separa uma sub-rede de uma rede separada completamente desconectada é geralmente o uso da &bFibra de Quartzo&r como parte do cabo. Quando colocada entre dois comprimentos de cabo de outra forma não conectados, a &bFibra de Quartzo&r não transfere dados ou canais entre os dois, transmitindo apenas &aenergia&r. "
				""
				"Assim, uma sub-rede do outro lado da Fibra pode ser alimentada inteiramente pela fonte de energia da rede principal, sem exigir nenhuma geração de energia dedicada extra."
			]
			old: [
				"Um conceito importante dentro do AE2 é uma técnica conhecida como '&esub-rede&f', na qual uma Rede ME extra separada (uma &esub-rede&f) atua em conjunto com a rede principal para executar alguma função ou processo especializado. "
				""
				"O que separa uma sub-rede de uma rede separada completamente desconectada é geralmente o uso da &bFibra de Quartzo&f como parte do cabo. Quando colocada entre dois comprimentos de cabo de outra forma não conectados, a &bFibra de Quartzo&f não transfere dados ou canais entre os dois, transmitindo apenas &aenergia&r. "
				""
				"Assim, uma sub-rede do outro lado da Fibra pode ser alimentada inteiramente pela fonte de energia da rede principal, sem exigir nenhuma geração de energia dedicada extra."
			]
		}
		quest.2893F483C10293E6.quest_desc: {
			new: ["&lBem-vindo ao &bApplied Energistics 2&r!\\n\\nApplied Energistics 2 (ou &oAE2&r para abreviar) é um mod de &barmazenamento digital&r incrivelmente versátil, permitindo um armazenamento extremamente eficiente e todos os tipos de capacidades de automação para aumentar muito sua experiência de Minecraft modificado desde o início que você quiser até o final do jogo.\\n\\nPara mais informações sobre o AE2 além deste capítulo, consulte a wiki em \\n\\n&o&bappliedenergistics.github.io&r."]
			old: [
				"&lBem-vindo ao &bApplied Energistics 2&f!\\n\\nApplied Energistics 2 (ou &oAE2&r para abreviar) é um mod de &barmazenamento digital&f incrivelmente versátil, permitindo um armazenamento extremamente eficiente e todos os tipos de capacidades de automação para aumentar muito sua experiência de Minecraft modificado desde o início que você quiser até o final do jogo.\\n\\nPara mais informações sobre o AE2 além deste capítulo, consulte a wiki em"
				"&o&bappliedenergistics.github.io&f&r."
			]
		}
		quest.78311531069807DE.quest_desc: {
			new: ["No &bApplied Energistics 2&r, toda Rede ME tem um certo número de &ecanais&r disponíveis, o que simplesmente significa quantos dispositivos em rede podem caber em toda a rede.\\n\\nComo regra geral, qualquer dispositivo que mais ou menos lida diretamente com dados ME (itens armazenados na rede) e realiza alguma forma de E/S ocupará um canal. Geralmente, componentes que se preocupam apenas com o armazenamento de energia interno da rede, como &eCélulas de Energia&r e &eInscritores&r, &onão&r ocupam canais.\\n\\nRedes sem um &bControlador ME&r são conhecidas como redes 'ad-hoc' e suportam um máximo de 8 canais."]
			old: ["No &bApplied Energistics 2&r, toda Rede ME tem um certo número de &ecanais&f disponíveis, o que simplesmente significa quantos dispositivos em rede podem caber em toda a rede.\\n\\nComo regra geral, qualquer dispositivo que mais ou menos lida diretamente com dados ME (itens armazenados na rede) e realiza alguma forma de E/S ocupará um canal. Geralmente, componentes que se preocupam apenas com o armazenamento de energia interno da rede, como &eCélulas de Energia&f e &eInscritores&f, &onão&r ocupam canais.\\n\\nRedes sem um &bControlador ME&f são conhecidas como redes 'ad-hoc' e suportam um máximo de 8 canais."]
		}
		quest.3195A7AA874163CD.quest_desc: {
			new: ["O &bCartão de Distribuição Igualitária&r é uma melhoria para células de armazenamento que pré-aloca uma certa quantidade de itens que pode ser ocupada por qualquer tipo individual.\\n\\nEste comportamento é comparável a algo como uma &6Functional Storage Gaveta&r, onde cada compartimento contém um número definido de pilhas, em oposição a permitir que itens de um compartimento vazem para os outros e expulsem outros tipos de itens."]
			old: ["O &bCartão de Distribuição Igualitária&f é uma melhoria para células de armazenamento que pré-aloca uma certa quantidade de itens que pode ser ocupada por qualquer tipo individual.\\n\\nEste comportamento é comparável a algo como uma &6Functional Storage Gaveta&r, onde cada compartimento contém um número definido de pilhas, em oposição a permitir que itens de um compartimento vazem para os outros e expulsem outros tipos de itens."]
		}
		task.338A6DA0D711B7DC.title: {
			new: "Provedor de Padrões"
			old: "ME Pattern Provider"
		}
		quest.140DE53DC0FCD9F4.quest_desc: {
			new: [
				"O &bPlano de Aniquilação ME&r pode ser usado para quebrar automaticamente quaisquer blocos à sua frente e retornar qualquer coisa dropada pelo bloco diretamente para a Rede ME."
				""
				"Como um bônus adicional, o Plano de Aniquilação pode ser encantado da mesma forma que uma ferramenta de escavação comum, afetando os drops de blocos da mesma maneira que a ferramenta encantada faria. Isso o torna ideal para processar blocos de minério quando encantado com Fortuna, por exemplo."
				"Quaisquer encantamentos adicionados aumentam significativamente a quantidade de energia usada pelo plano toda vez que um bloco é quebrado. Encantar o plano com &eEficiência&r diminuirá o uso geral de energia incorrido por todos os outros encantamentos, enquanto o encantamento &eInquebrável&r dá ao plano a chance de usar energia apenas às vezes, de forma semelhante a Inquebrável em ferramentas comuns."
			]
			old: [
				"O &bPlano de Aniquilação ME&f pode ser usado para quebrar automaticamente quaisquer blocos à sua frente e retornar qualquer coisa dropada pelo bloco diretamente para a Rede ME."
				""
				"Como um bônus adicional, o Plano de Aniquilação pode ser encantado da mesma forma que uma ferramenta de escavação comum, afetando os drops de blocos da mesma maneira que a ferramenta encantada faria. Isso o torna ideal para processar blocos de minério quando encantado com Fortuna, por exemplo."
				"Quaisquer encantamentos adicionados aumentam significativamente a quantidade de energia usada pelo plano toda vez que um bloco é quebrado. Encantar o plano com &eEficiência&f diminuirá o uso geral de energia incorrido por todos os outros encantamentos, enquanto o encantamento &eInquebrável&f dá ao plano a chance de usar energia apenas às vezes, de forma semelhante a Inquebrável em ferramentas comuns."
			]
		}
		quest.22C4318523A43B49.quest_desc: {
			new: ["Os &eTerminal&r fornecem acesso a qualquer conteúdo de uma Rede ME. O &eTerminal ME&r padrão simplesmente lista tudo na rede como uma grande grade para puxar e inserir, semelhante a um único inventário.\\n\\nO &eTerminal de Fabricação ME&r é uma extensão do ME Terminal que também fornece uma Grade de Fabricação embutida, permitindo a fabricação usando qualquer item contido na rede e visível através da tela do terminal."]
			old: ["Os &eTerminal&f fornecem acesso a qualquer conteúdo de uma Rede ME. O &eTerminal ME&f padrão simplesmente lista tudo na rede como uma grande grade para puxar e inserir, semelhante a um único inventário.\\n\\nO &eTerminal de Fabricação ME&f é uma extensão do ME Terminal que também fornece uma grade de criação embutida, permitindo a criação conveniente usando qualquer item contido na rede e visível através da tela do terminal."]
		}
		quest.51A57E142C686C8F.quest_desc: {
			new: ["O quinto e último Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e268435456&r (262144k) bytes de armazenamento."]
			old: ["O quinto e último Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e268435456&f (262144k) bytes de armazenamento."]
		}
		quest.3B42CCC19D23EC6D.quest_desc: {
			new: ["O segundo tier de Componente de Armazenamento, fornecendo &e4096&r bytes de armazenamento."]
			old: ["O segundo tier de Componente de Armazenamento, fornecendo &e4096&f bytes de armazenamento."]
		}
		quest.5CD8D169181C7339.quest_desc: {
			new: ["Estes três últimos itens são mais ou menos alguns brinquedos extras fornecidos pelo AE2 e não se encaixam necessariamente em nenhuma dessas árvores de missões.\\n\\nO &bCajado Carregado&r é apenas um cajado simples movido a energia que causa 3 corações de dano e consome 300AE por acerto. Ele também usa a mecânica de combate anterior à 1.9, o que significa que você pode clicar repetidamente com ele como nos velhos tempos.\\n\\nO &bManipulador de Entropia&r, quando &ousado&r em certos blocos do mundo, os derreterá no local, como areia em vidro e minérios de metal em lingotes de metal. Caso contrário, ele simplesmente acenderá um fogo no bloco.\\n\\nFinalmente, o &bCanhão de Matéria&r funciona de forma semelhante ao Aplicador de Cor como uma célula dedicada para conter itens de 'munição', como Bolas de Matéria e pepitas de ferro/ouro, que podem ser disparadas para causar dano a mobs ou quebrar blocos. Bolas de Matéria 'munição' mais pesadas em um Canhão de Matéria podem ser substituídas por &bBolas de Tinta&r, que aplicarão um efeito de respingo de tinta na face de qualquer bloco que for atingido. &bBolas de Tinta Luminescente&r são uma variante de bolas de tinta usadas exclusivamente pelo Canhão de Matéria, cujos respingos de tinta também emitem alguma luz uma vez presentes no mundo."]
			old: ["Estes três últimos itens são mais ou menos alguns brinquedos extras fornecidos pelo AE2 e não se encaixam necessariamente em nenhuma dessas árvores de missões.\\n\\nO &bCajado Carregado&f é apenas um cajado simples movido a energia que causa 3 corações de dano e consome 300AE por acerto. Ele também usa a mecânica de combate anterior à 1.9, o que significa que você pode clicar repetidamente com ele como nos velhos tempos.\\n\\nO &bManipulador de Entropia&f, quando &ousado&r em certos blocos do mundo, os derreterá no local, como areia em vidro e minérios de metal em barras de metal. Caso contrário, ele simplesmente acenderá um fogo no bloco.\\n\\nFinalmente, o &bCanhão de Matéria&f funciona de forma semelhante ao Aplicador de Cor como uma célula dedicada para conter itens de 'munição', como Bolas de Matéria e pepitas de ferro/ouro, que podem ser disparadas para causar dano a mobs ou quebrar blocos. Bolas de Matéria 'munição' mais pesadas em um Canhão de Matéria podem ser substituídas por &bBolas de Tinta&f, que aplicarão um efeito de respingo de tinta na face de qualquer bloco que for atingido. &bBolas de Tinta Luminescente&f são uma variante de bolas de tinta usadas exclusivamente pelo Canhão de Matéria, cujos respingos de tinta também emitem alguma luz uma vez presentes no mundo."]
		}
		quest.2F556E7919582D2D.quest_desc: {
			new: ["A &bBancada de Células&r permite que as células sejam 'particionadas' para conter itens específicos, ou seja, receber um filtro de lista branca. Também permite que a célula seja atualizada com certos cartões de atualização, como o Cartão Inversor, que define a lista branca mencionada para ser uma lista negra.\\n\\nAs células também podem receber uma 'prioridade' maior ou menor através da bancada de trabalho, ou seja, permitir que a célula seja a primeira a receber certos itens até ficar cheia, ou ser feita para esperar que outras células de maior prioridade se encham primeiro."]
			old: ["A &bBancada de Células&f permite que as células sejam 'particionadas' para conter itens específicos, ou seja, receber um filtro de lista branca. Também permite que a célula seja atualizada com certos cartões de atualização, como o Cartão Inversor, que define a lista branca mencionada para ser uma lista negra.\\n\\nAs células também podem receber uma 'prioridade' maior ou menor através da bancada de trabalho, ou seja, permitir que a célula seja a primeira a receber certos itens até ficar cheia, ou ser feita para esperar que outras células de maior prioridade se encham primeiro."]
		}
		quest.51DE3157DE3E57B8.quest_desc: {
			new: [
				"Armazenamento é bom e tudo mais, mas de que adianta um sistema de armazenamento se ele está entupido de matérias-primas que precisam ser fabricadas e processadas em algo e você ainda está preso tendo que fazer isso manualmente?"
				""
				"O sistema de &efabricação automática&r do AE2 começa com o &bProvedor de Padrões&r. O Provedor de Padrões contém certos itens chamados &bPadrões&r (abordados na próxima missão) que são programados para conter alguma receita que transforma itens de entrada em uma certa saída. Até 9 padrões podem caber em um fornecedor."
				""
				"Você frequentemente usará múltiplos fornecedores de padrões espalhados por toda a sua base, e é por isso que é útil ter um &bTerminal de Acesso a Padrões&r para acessar remotamente o conteúdo de qualquer e todos os fornecedores em sua Rede ME mais ampla."
			]
			old: [
				"Armazenamento é bom e tudo mais, mas de que adianta um sistema de armazenamento se ele está entupido de matérias-primas que precisam ser fabricadas e processadas em algo e você ainda está preso tendo que fazer isso manualmente?"
				""
				"O sistema de &efabricação automática&f do AE2 começa com o &bProvedor de Padrões ME&f. O Provedor de Padrões contém certos itens chamados &bPadrões&f (abordados na próxima missão) que são programados para conter alguma receita que transforma itens de entrada em uma certa saída. Até 9 padrões podem caber em um fornecedor."
				""
				"Você frequentemente usará múltiplos fornecedores de padrões espalhados por toda a sua base, e é por isso que é útil ter um &bTerminal de Acesso a Padrões&f para acessar remotamente o conteúdo de qualquer e todos os fornecedores em sua Rede ME mais ampla."
			]
		}
		quest.5C22E3103544B120.quest_desc: {
			new: ["Para conectar a grande maioria da sua Rede ME, você precisará de alguns cabos. O &eCabos de Vidro de ME&r é o primeiro e mais básico tipo de cabo, e você o fabricará constantemente como o primeiro passo para fabricar os outros tipos de cabo.\\n\\nTanto os Cabo ME quanto sua contraparte &eCoberta&r podem transportar até &e8 canais&r por uma única seção de cabeamento. Diferente dos Cabo ME, os cabos cobertos podem ser posteriormente transformados em &eCabo ME Denso Coberto&r, capazes de transportar até 32 canais. No entanto, a maioria dos dispositivos 'multiparte', como Pontos e terminais, não pode ser conectada diretamente a Dense Cables, exigindo cabos de largura normal para formar uma conexão.\\n\\nTodos os cabos também podem ser fabricados com corante para colori-los. Cabos sem cor (de 'Fluix') podem se conectar a qualquer outra cor de cabo, mas, fora isso, cabos de cores diferentes nunca se conectarão uns aos outros."]
			old: ["Para conectar a grande maioria da sua Rede ME, você precisará de alguns cabos. O &eCabos de Vidro de ME&f é o primeiro e mais básico tipo de cabo, e você o fabricará constantemente como o primeiro passo para criar os outros tipos de cabo.\\n\\nTanto os cabos de vidro quanto sua contraparte &eCoberta&f podem transportar até &e8 canais&r por uma única seção de cabeamento. Diferente dos cabos de vidro, os cabos cobertos podem ser posteriormente transformados em &eCabo ME Denso Coberto&f, capazes de transportar até 32 canais. No entanto, a maioria dos dispositivos 'multiparte', como Pontos e terminais, não pode ser conectada diretamente a Dense Cables, exigindo cabos de largura normal para formar uma conexão.\\n\\nTodos os cabos também podem ser fabricados com corante para colori-los. Cabos sem cor (de 'Fluix') podem se conectar a qualquer outra cor de cabo, mas, fora isso, cabos de cores diferentes nunca se conectarão uns aos outros."]
		}
		quest.77C9EE701F72586D.quest_desc: {
			new: [
				"As &bCélula Portátil&r funcionam de forma idêntica às células normais, podendo ser inseridas em um baú ou drive e preenchidas adequadamente."
				""
				"No entanto, ao contrário das células normais, seu conteúdo também pode ser acessado de forma autônoma através do próprio item da célula, um pouco como uma mochila digital com sabor de ME."
			]
			old: [
				"As &bCélula Portátil&f funcionam de forma idêntica às células normais, podendo ser inseridas em um baú ou drive e preenchidas adequadamente."
				""
				"No entanto, ao contrário das células normais, seu conteúdo também pode ser acessado de forma autônoma através do próprio item da célula, um pouco como uma mochila digital com sabor de ME."
			]
		}
		quest.037488EF1F3581CE.quest_desc: {
			new: ["Por padrão, uma &bRede ME&r por si só tem apenas um buffer interno de &a800AE&r sem um &bControlador ME&r, com o controlador adicionando &a8kAE&r extras por bloco. Para redes suficientemente grandes, isso pode ser insuficiente e pode fazer com que uma rede desligue intermitentemente ao tentar recuperar energia para quaisquer dispositivos conectados.\\n\\nA &bCélula de Energia&r permite que uma &bRede ME&r armazene significativamente mais energia, adicionando outros &a200kAE&r por &bCélula de Energia&r regular e &a1.6MAE&r por &bCélula de Energia Densa&r. Elas também podem ser colocadas em qualquer lugar da rede para fornecer o buffer de energia aumentado."]
			old: ["Por padrão, uma &bRede ME&r por si só tem apenas um buffer interno de &a800AE&r sem um &bControlador ME&r, com o controlador adicionando &a8kAE&r extras por bloco. Para redes suficientemente grandes, isso pode ser insuficiente e pode fazer com que uma rede desligue intermitentemente ao tentar recuperar energia para quaisquer dispositivos conectados.\\n\\nA &bCélula de Energia&f permite que uma &bRede ME&r armazene significativamente mais energia, adicionando outros &a200kAE&r por &bCélula de Energia&r regular e &a1.6MAE&r por &bCélula de Energia Densa&r. Elas também podem ser colocadas em qualquer lugar da rede para fornecer o buffer de energia aumentado."]
		}
		quest.01F3F0C25BA72BDA.title: {
			new: "&bE/S Espacial"
			old: "&bEspacial E/S"
		}
		quest.1AAF0B31B47AF23D.quest_desc: {
			new: ["Dispositivos ME individuais também podem ser configurados para responder a sinais de redstone. Quando atualizados com um &bCartão de Redstone&r, um dispositivo pode ser configurado para funcionar apenas quando alimentado com redstone ou conforme necessário.\\n\\nEste comportamento também pode se aplicar a &oseções&r inteiras de uma Rede ME usando um &bPonto de Interruptor ME&r. Isso permite que uma seção da rede do outro lado do interruptor seja ativada apenas quando o interruptor é alimentado por redstone, ou desativada se estiver usando um &ePonto de Interruptor Invertido&r&r."]
			old: ["Dispositivos ME individuais também podem ser configurados para responder a sinais de redstone. Quando atualizados com um &bCartão de Redstone&f, um dispositivo pode ser configurado para funcionar apenas quando alimentado com redstone ou conforme necessário.\\n\\nEste comportamento também pode se aplicar a &oseções&r inteiras de uma Rede ME usando um &bPonto de Interruptor ME&f. Isso permite que uma seção da rede do outro lado do interruptor seja ativada apenas quando o interruptor é alimentado por redstone, ou desativada se estiver usando um &ePonto de Interruptor Invertido&r&f."]
		}
		quest.2B31E6C1707D8195.quest_desc: {
			new: ["O próximo passo para permitir o acesso à rede sem fio é o &bPonto de Acesso Sem Fio&r. O Ponto de Acesso é usado para abrir a rede para acesso sem fio através de um &eterminal sem fio&r, e tem um alcance definido (finito) dependendo de quantos &bAmplificador de Alcance Sem Fio&r são inseridos no Ponto de Acesso."]
			old: ["O próximo passo para permitir o acesso à rede sem fio é o &bPonto de Acesso Sem Fio&f. O Ponto de Acesso é usado para abrir a rede para acesso sem fio através de um &eterminal sem fio&f, e tem um alcance definido (finito) dependendo de quantos &bAmplificador de Alcance Sem Fio&f são inseridos no Ponto de Acesso."]
		}
		quest.525F25F4ADE45B50.quest_desc: {
			new: [
				"O &bPlano de Formação ME&r age de forma semelhante ao Ponto de Armazenamento, mas trata o próprio mundo como seu meio de armazenamento. Em outras palavras, ele colocará qualquer bloco em seu filtro diretamente à sua frente."
				""
				"Isso pode ser útil para situações em que um bloco pode ser processado simplesmente colocando-o e quebrando-o com uma determinada ferramenta."
			]
			old: [
				"O &bPlano de Formação ME&f age de forma semelhante ao Ponto de Armazenamento, mas trata o próprio mundo como seu meio de armazenamento. Em outras palavras, ele colocará qualquer bloco em seu filtro diretamente à sua frente."
				""
				"Isso pode ser útil para situações em que um bloco pode ser processado simplesmente colocando-o e quebrando-o com uma determinada ferramenta."
			]
		}
		quest.2077D64428E9C067.title: {
			new: "&eEsqueci de mencionar"
			old: "&eEsqueci de Mencionar"
		}
		quest.0B218DD73FE8D985.quest_desc: {
			new: ["Se você fez a última missão corretamente, deve ter transformado aquela singularidade em um par de &5Singularidades Quanticamente Entrelaçadas&r. Essas novas singularidades são usadas para conectar um dispositivo em forma de anel conhecido como &ePonte de Rede Quântica&r.\\n\\nQuando dois desses anéis individuais são conectados usando as &5Singularidades Quanticamente Entrelaçadas&r e inicializados com um pouco de energia AE (por exemplo, uma célula de energia), uma Rede ME pode ser expandida sem fio do outro lado da ponte, seja por longas distâncias ou até mesmo entre dimensões."]
			old: ["Se você fez a última missão corretamente, deve ter transformado aquela singularidade em um par de &5Singularidades Quanticamente Entrelaçadas&f. Essas novas singularidades são usadas para conectar um dispositivo em forma de anel conhecido como &ePonte de Rede Quântica&f.\\n\\nQuando dois desses anéis individuais são conectados usando as &5Singularidades Quanticamente Entrelaçadas&r e inicializados com um pouco de energia AE (por exemplo, uma célula de energia), uma Rede ME pode ser expandida sem fio do outro lado da ponte, seja por longas distâncias ou até mesmo entre dimensões."]
		}
		quest.371A382CF1DDF2B2.quest_desc: {
			new: ["O &bCartão de Capacidade&r permite que uma bus atualizada com ele carregue um filtro maior. As Import e Export buses atualizadas com capacity cards passam de suportar apenas um item filtrado cada para o máximo de nove slots de filtro, enquanto as Storage buses passam de 18 slots para um máximo de 63."]
			old: ["O &bCartão de Capacidade&f permite que uma bus atualizada com ele carregue um filtro maior. As Import e Export buses atualizadas com capacity cards passam de suportar apenas um item filtrado cada para o máximo de nove slots de filtro, enquanto as Storage buses passam de 18 slots para um máximo de 63."]
		}
		quest.55186B8602689B66.quest_desc: {
			new: [
				"O &bCartão de Memória&r é uma ferramenta com duas funções diferentes. A mais simples das duas é salvar as configurações de vários dispositivos (como filtros de lista branca) para serem copiadas para outro dispositivo do mesmo tipo."
				""
				"A segunda função de um cartão de memória é conectar &etúneis P2P&r. Ao fazer isso, o túnel P2P que está sendo conectado receberá uma ID exclusiva, que é armazenada no cartão de memória para futuras conexões."
			]
			old: [
				"O &bCartão de Memória&f é uma ferramenta com duas funções diferentes. A mais simples das duas é salvar as configurações de vários dispositivos (como filtros de lista branca) para serem copiadas para outro dispositivo do mesmo tipo."
				""
				"A segunda função de um cartão de memória é conectar &etúneis P2P&f. Ao fazer isso, o túnel P2P que está sendo conectado receberá uma ID exclusiva, que é armazenada no cartão de memória para futuras conexões."
			]
		}
		quest.1F7DFA5AA65F2812.quest_desc: {
			new: ["O &bCartão de Aceleração&r, dependendo do dispositivo sendo atualizado com ele, aumentará a velocidade com que o dispositivo opera ou permitirá que o dispositivo realize mais operações de uma só vez.\\n\\nNo caso do &eMontador Molecular&r, um conjunto completo de 5 cartões reduz o tempo necessário para o MM concluir uma fabricação de um segundo (sem cartões) para um &otick&r."]
			old: ["O &bCartão de Aceleração&f, dependendo do dispositivo sendo atualizado com ele, aumentará a velocidade com que o dispositivo opera ou permitirá que o dispositivo realize mais operações de uma só vez.\\n\\nNo caso do &eMontador Molecular&f, um conjunto completo de 5 cartões reduz o tempo necessário para o MM concluir uma fabricação de um segundo (sem cartões) para um &otick&r."]
		}
		quest.5E24012A3D9B72A1.quest_desc: {
			new: [
				"Itens não são as únicas coisas que podem ser armazenadas em células ME. &bCélulas de Armazenamento para Fluidos&r podem armazenar líquidos como água, lava e qualquer variedade de óleos e combustíveis de mods, para dar alguns exemplos."
				""
				"Note que todas as células de armazenamento, independentemente do que são projetadas para armazenar, diferem apenas em termos de seu invólucro; tanto as células de &6item&r quanto as de &bfluido&r usam o mesmo tipo de Componente de Armazenamento para serem feitas."
				""
				"Para fluidos, 1 byte equivale a 8 baldes (8000mb)."
			]
			old: [
				"Itens não são as únicas coisas que podem ser armazenadas em células ME. &bCélulas de Armazenamento de Fluidos ME&f podem armazenar líquidos como água, lava e qualquer variedade de óleos e combustíveis de mods, para dar alguns exemplos."
				""
				"Note que todas as células de armazenamento, independentemente do que são projetadas para armazenar, diferem apenas em termos de seu invólucro; tanto as células de &6item&r quanto as de &bfluido&r usam o mesmo tipo de Componente de Armazenamento para serem feitas."
				""
				"Para fluidos, 1 byte equivale a 8 baldes (8000mb)."
			]
		}
		quest.460A8F17F3ED6CAF.quest_desc: {
			new: ["Chega um ponto em qualquer jogatina de um grande modpack em que mesmo o maior nível padrão de célula de armazenamento não é suficiente para a quantidade de itens e recursos que você pode estar acumulando.\\n\\nÉ aqui que o add-on &dMEGA Cells&r entra, estendendo os níveis de armazenamento disponíveis para o território dos megabytes. O primeiro desses novos níveis é dado pelo &b1M MEGA Storage Component&r, fornecendo 1024 &oquilo&rbytes, ou &e1048576&r bytes, de armazenamento."]
			old: ["Chega um ponto em qualquer jogatina de um grande modpack em que mesmo o maior nível padrão de célula de armazenamento não é suficiente para a quantidade de itens e recursos que você pode estar acumulando.\\n\\nÉ aqui que o add-on &dMEGA Cells&f entra, estendendo os níveis de armazenamento disponíveis para o território dos megabytes. O primeiro desses novos níveis é dado pelo &b1M MEGA Storage Component&f, fornecendo 1024 &oquilo&rbytes, ou &e1048576&f bytes, de armazenamento."]
		}
		quest.523853C1C4E688BA.quest_desc: {
			new: ["O quarto nível do Componente de Armazenamento, fornecendo &e65536&r bytes de armazenamento."]
			old: ["O quarto nível do Componente de Armazenamento, fornecendo &e65536&f bytes de armazenamento."]
		}
		quest.6E15447FC3D678E0.quest_desc: {
			new: ["O &bCartão de Imprecisão&r permite que um item filtrado seja correspondido independentemente de quaisquer metadados (NBT), como dano ou encantamentos, enquanto o &bCartão Inversor&r alterna o filtro em tais Pontos de ser uma lista de permissão para ser uma lista de bloqueio."]
			old: ["O &bCartão de Imprecisão&f permite que um item filtrado seja correspondido independentemente de quaisquer metadados (NBT), como dano ou encantamentos, enquanto o &bCartão Inversor&f alterna o filtro em tais Pontos de ser uma lista de permissão para ser uma lista de bloqueio."]
		}
		task.08DA73B1AC17E5F5.title: {
			new: "Armazenamento de Fabricação"
			old: "Armazenamento de Criação"
		}
		quest.30E853CE699E669B.title: {
			new: "&eArmazenamento de &zFabricação"
			old: "&eArmazenamento de &bC&9r&1i&3a&cç&eã&5o"
		}
		quest.5233A447BAA4593C.quest_desc: {
			new: ["O &bCabo ME Inteligente&r e o &bCabo ME Denso Inteligente&r funcionam de forma idêntica aos cabos cobertos em termos de distribuição de canais, mas também exibirão visivelmente a quantidade de canais que estão usando como linhas coloridas ao longo deles."]
			old: ["O &bCabo ME Inteligente&f e o &bCabo ME Denso Inteligente&f funcionam de forma idêntica aos cabos cobertos em termos de distribuição de canais, mas também exibirão visivelmente a quantidade de canais que estão usando como linhas coloridas ao longo deles."]
		}
		quest.3CE3D9245F8EC005.quest_desc: {
			new: ["O quarto Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e67108864&r (65536k) bytes de armazenamento."]
			old: ["O quarto Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e67108864&f (65536k) bytes de armazenamento."]
		}
		task.75924053D6F5B242.title: {
			new: "Célula de Armazenamento Espacial"
			old: "Célula de Armazenamento Espacial s"
		}
		quest.1710B3D05215A71E.quest_desc: {
			new: [
				"&bP2P&r (ponto a ponto) é um sistema poderoso dentro do AE2, permitindo a transferência de itens, fluidos e muito mais sem a necessidade de qualquer armazenamento ME intermediário."
				""
				"Clicar com o botão direito em um túnel &bP2P&r com certos itens irá &esintonizar&r o túnel em um capaz de transferir outra coisa, como itens através de tubos, energia através de cabos, sinais de redstone e (por padrão) até mesmo conexões ME."
				""
				"&dTúneis P2P&r devem ser ligados uns aos outros com o uso de um &eCartão de Memória&r, detalhado na próxima missão."
			]
			old: [
				"&bP2P&f (ponto a ponto) é um sistema poderoso dentro do AE2, permitindo a transferência de itens, fluidos e muito mais sem a necessidade de qualquer armazenamento ME intermediário."
				""
				"Clicar com o botão direito em um túnel &bP2P&f com certos itens irá &esintonizar&f o túnel em um capaz de transferir outra coisa, como itens através de tubos, energia através de cabos, sinais de redstone e (por padrão) até mesmo conexões ME."
				""
				"&dTúneis P2P&f devem ser ligados uns aos outros com o uso de um &eCartão de Memória&f, detalhado na próxima missão."
			]
		}
		quest.361CCBD353D6FF34.title: {
			new: "Armazenamento para Itens"
			old: "Armazenamento de Itens"
		}
		quest.2897FA291E5A38D8.quest_desc: {
			new: ["A &bÂncora Espacial&r é um dispositivo companheiro da linhagem &bE/S Espacial&r que funciona simplesmente como um carregador de chunks. Quando conectado a uma Rede ME, o Anchor forçará o carregamento de todos os chunks ocupados pela Rede ME em todos os cabos e dispositivos, excluindo sub-redes, contanto que a rede permaneça energizada."]
			old: ["A &bÂncora Espcial&f é um dispositivo companheiro da linhagem &bEspacial E/S&r que funciona simplesmente como um carregador de chunks. Quando conectado a uma Rede ME, o Anchor forçará o carregamento de todos os chunks ocupados pela Rede ME em todos os cabos e dispositivos, excluindo sub-redes, contanto que a rede permaneça energizada."]
		}
		quest.3E3DF8E967D95DB0.quest_desc: {
			new: ["Ao usar um Componente de Armazenamento de 64k ou superior, o Condensador de Matéria se torna capaz de condensar significativamente mais para produzir uma &bSingularidade&r. Uma única singularidade requer que 256.000 itens sejam anulados. Isso é exatamente &o4000 stacks&r!\\n\\nVeja o que acontece quando você joga essa singularidade no chão com um pedaço de &ePó de Ender&r. Você terá que causar algum dano aos arredores enquanto faz isso, mas felizmente o AE2 oferece sua própria &bTNT Minúscula&r para minimizar isso."]
			old: ["Ao usar um Componente de Armazenamento de 64k ou superior, o Condensador de Matéria se torna capaz de condensar significativamente mais para produzir uma &bSingularidade&f. Uma única singularidade requer que 256.000 itens sejam anulados. Isso é exatamente &o4000 stacks&r!\\n\\nVeja o que acontece quando você joga essa singularidade no chão com um pedaço de &ePó de Ender&f. Você terá que causar algum dano aos arredores enquanto faz isso, mas felizmente o AE2 oferece sua própria &bTNT Minúscula&f para minimizar isso."]
		}
		quest.6144202A97C6CD1C.title: {
			new: "Âncora para Cabos ME"
			old: "Cable Anchor"
		}
		quest.5E6585F7627247E3.quest_desc: {
			new: ["Quando aplicada como um upgrade a qualquer dispositivo compatível, como uma Interface ou um Ponto de Exportação, a &bCartão de Fabricação&r permite que o dispositivo em questão envie automaticamente suas próprias solicitações de fabricação para um item necessário (filtrado). As CPUs de Fabricação podem ser configuradas para responder apenas a essas solicitações para evitar a ocupação de CPUs destinadas a fabricações solicitadas pelo jogador.\\n\\nQuando o &eEmissor de Nível&r é atualizado com o Cartão de Fabricação, ele pode ser configurado para emitir um sinal de redstone para facilitar diretamente a fabricação, emitindo um sinal &odurante&r a detecção de uma tarefa de fabricação para o item especificado ou especificamente &opara&r fabricar o item. O último caso se aplicaria a situações em que a única coisa necessária para fazer um item é um sinal de redstone, sem sequer exigir um padrão de fabricação."]
			old: ["Quando aplicada como um upgrade a qualquer dispositivo compatível, como uma Interface ou um Ponto de Exportação, a &bCartão de Fabricação&f permite que o dispositivo em questão envie automaticamente suas próprias solicitações de fabricação para um item necessário (filtrado). As CPUs de Fabricação podem ser configuradas para responder apenas a essas solicitações para evitar a ocupação de CPUs destinadas a fabricações solicitadas pelo jogador.\\n\\nQuando o &eEmissor de Nível&f é atualizado com o Cartão de Fabricação, ele pode ser configurado para emitir um sinal de redstone para facilitar diretamente a fabricação, emitindo um sinal &odurante&r a detecção de uma tarefa de fabricação para o item especificado ou especificamente &opara&r fabricar o item. O último caso se aplicaria a situações em que a única coisa necessária para fazer um item é um sinal de redstone, sem sequer exigir um padrão de fabricação."]
		}
		quest.15564C11744D6AA0.quest_desc: {
			new: ["Depois de obter um conjunto completo das &ePrensas de Inscrição&r necessárias, é hora de começar a fazer alguns &eProcessadores&r. Eles são um ingrediente para importantes fabricações usado para fazer a grande maioria dos dispositivos conectados à ME."]
			old: ["Depois de obter um conjunto completo das &ePrensas de Inscrição&r necessárias, é hora de começar a fazer alguns &eProcessadores&f. Eles são um ingrediente de criação importante usado para fazer a grande maioria dos dispositivos conectados à ME."]
		}
		quest.2FB231069D2E4E77.quest_desc: {
			new: ["Cada célula individual tem uma certa capacidade ditada pelo &ecomponente&r com o qual a célula foi fabricada.\\n\\nO primeiro dos componentes é o &bComponente de Armazenamento de 1k&r, fornecendo &e1024&r 'bytes' de armazenamento para uma determinada célula. Mais sobre isso depois."]
			old: ["Cada célula individual tem uma certa capacidade ditada pelo &ecomponente&f com o qual a célula foi fabricada.\\n\\nO primeiro dos componentes é o &bComponente de Armazenamento de 1k&f, fornecendo &e1024&f 'bytes' de armazenamento para uma determinada célula. Mais sobre isso depois."]
		}
		quest.083D458032F0325C.quest_desc: {
			new: ["O &bPonto de Exportação&r periodicamente ejeta itens de seu filtro de lista branca para qualquer armazenamento externo que o Ponto esteja voltado. Ao contrário do Ponto de Importação, o Ponto de Exportação não pode funcionar sem ser filtrado."]
			old: ["O &bPonto de Exportação ME&f periodicamente ejeta itens de seu filtro de lista branca para qualquer armazenamento externo que o Ponto esteja voltado. Ao contrário do Ponto de Importação, o Ponto de Exportação não pode funcionar sem ser filtrado."]
		}
		quest.361CCBD353D6FF34.quest_desc: {
			new: [
				"Com o &bComponente de Armazenamento de 1k&r, agora você pode fabricar uma &bCélula de Armazenamento para Itens&r para iniciar seu sistema de armazenamento digital de itens. Você provavelmente vai querer que a maior parte do seu armazenamento seja para itens, então provavelmente vai querer fazer algumas &bCélula de Armazenamento para Itens&r. "
				""
				"As &bCélula de Armazenamento para Itens&r podem conter até 63 tipos diferentes de itens. Cada novo tipo de item adicionado a uma célula ocupará uma certa fração da capacidade total da célula de armazenamento em bytes. Para cada tipo já presente, 1 'byte' conta para 8 itens do mesmo tipo. "
				""
				"Como exemplo, uma &bCélulas de Armazenamento de 1k para itens&r contendo apenas pedregulho pode armazenar até 8128 pedregulhos (8*1024b - 8b/tipo * 1 tipo). "
				""
				"Se uma célula estiver vazia, ela pode ser reaproveitada desmontando-a em seu respectivo componente e invólucro. Isso é feito agachando e clicando com o botão direito no ar com a célula na mão."
			]
			old: [
				"Com o &bComponente de Armazenamento de 1k&r, agora você pode criar uma &bCélulas de Armazenamento de Itens ME&r para iniciar seu sistema de armazenamento digital de itens. Você provavelmente vai querer que a maior parte do seu armazenamento seja para itens, então provavelmente vai querer fazer algumas &bCélulas de Armazenamento de Itens ME&f. "
				""
				"As &bCélulas de Armazenamento de Itens ME&r podem conter até 63 tipos diferentes de itens. Cada novo tipo de item adicionado a uma célula ocupará uma certa fração da capacidade total da célula de armazenamento em bytes. Para cada tipo já presente, 1 'byte' conta para 8 itens do mesmo tipo. "
				""
				"Como exemplo, uma &bCélulas de Armazenamento de Itens 1k&r contendo apenas pedregulho pode armazenar até 8128 pedregulhos (8*1024b - 8b/tipo * 1 tipo). "
				""
				"Se uma célula estiver vazia, ela pode ser reaproveitada desmontando-a em seu respectivo componente e invólucro. Isso é feito agachando e clicando com o botão direito no ar com a célula na mão."
			]
		}
		quest.16299B9AE87257DC.quest_desc: {
			new: ["O &bTerminal Sem Fio&r funciona de forma idêntica a um terminal comum, mas sem fio.\\n\\nAntes que possa ser usado para acessar uma rede, ele deve primeiro ser &econectado&r à rede, colocando-o no slot superior direito do &ePonto de Acesso Sem Fio&r. Se não estiver conectado a uma rede, ou estiver fora de alcance ou sem energia, o terminal não funcionará.\\n\\nTerminais sem fio também podem ser atualizados com &eCartões de Energia&r para fornecer uma bateria interna maior."]
			old: ["O &bTerminal Sem Fio&f funciona de forma idêntica a um terminal comum, mas sem fio.\\n\\nAntes que possa ser usado para acessar uma rede, ele deve primeiro ser &econectado&f à rede, colocando-o no slot superior direito do &ePonto de Acesso Sem Fio&r. Se não estiver conectado a uma rede, ou estiver fora de alcance ou sem energia, o terminal não funcionará.\\n\\nTerminais sem fio também podem ser atualizados com &eCartões de Energia&f para fornecer uma bateria interna maior."]
		}
		quest.7B7D1F0CB326B28F.quest_desc: {
			new: ["A &bPorto de E/S para Itens e Fluidos&r permite que o conteúdo do armazenamento de uma Rede ME seja rapidamente rearranjado entre diferentes mídias de armazenamento, como células ME e contêineres externos conectados a Pontos de armazenamento.\\n\\nQuando uma célula é inserida em um slot de entrada à esquerda, a Porto de E/S para Itens e Fluidos pode ser alternada para esvaziar a célula em outros ME Storages ou preencher a célula (idealmente, particionada) com certos itens espalhados por outros armazenamentos."]
			old: ["A &bPorta ME E/S&f permite que o conteúdo do armazenamento de uma Rede ME seja rapidamente rearranjado entre diferentes mídias de armazenamento, como células ME e contêineres externos conectados a Pontos de armazenamento.\\n\\nQuando uma célula é inserida em um slot de entrada à esquerda, a Porta de E/S pode ser alternada para esvaziar a célula em outros ME Storages ou preencher a célula (idealmente, particionada) com certos itens espalhados por outros armazenamentos."]
		}
		quest.03E6FA4DCB71162E.quest_desc: {
			new: ["O &bAplicador de Cor&r é uma ferramenta carregável que permite a tingidura de cabos no mundo. Ele funciona mais ou menos como uma &ecélula de armazenamento&r especializada a ser carregada com corantes vanilla ou &ebolas de tinta&r para cores específicas, juntamente com &ebolas de neve&r para lavar as cores e transformar os cabos de volta em sua variante Fluix.\\n\\nAplicar cor a um cabo consome &a100AE&r de energia de sua bateria interna, para um total de 3400 segmentos de cabo em uma única carga."]
			old: ["O &bAplicador de Cor&f é uma ferramenta carregável que permite a tingidura de cabos no mundo. Ele funciona mais ou menos como uma &ecélula de armazenamento&f especializada a ser carregada com corantes vanilla ou &ebolas de tinta&f para cores específicas, juntamente com &ebolas de neve&f para lavar as cores e transformar os cabos de volta em sua variante Fluix.\\n\\nAplicar cor a um cabo consome &a100AE&r de energia de sua bateria interna, para um total de 3400 segmentos de cabo em uma única carga."]
		}
		task.61D93B13D496547D.title: {
			new: "Armazenamento para Fluidos"
			old: "Armazenamento de Fluidos"
		}
		quest.68B0B3DAF1145191.quest_desc: {
			new: ["Duas das primeiras coisas que você precisará para começar no AE2 são o &bCarregador&r e o &bInscritor&r.\\n\\nO &bCarregador&r, quando abastecido com energia, pegará &eCristais de Quartzo Certus&r e os carregará. Esses &eCristais de Certus Carregados&r podem então ser usados na produção de &eFluix&r, outro recurso importante no mod. Ele também pode ser usado para carregar qualquer item que armazene energia.\\n\\nO &bInscritor&r pode ser usado para transformar os vários cristais de quartzo do AE2 em sua forma de pó, mas, mais importante, é usado para fabricar &eCircuitos Impressos&r e &eProcessadores Especiais&r, como ficará mais claro na próxima missão."]
			old: ["Duas das primeiras coisas que você precisará para começar no AE2 são o &bCarregador&f e o &bInscritor&f.\\n\\nO &bCarregador&f, quando abastecido com energia, pegará &eCristais de Quartzo Certus&r e os carregará. Esses &eCristais de Certus Carregados&r podem então ser usados na produção de &eFluix&f, outro recurso importante no mod. Ele também pode ser usado para carregar qualquer item que armazene energia.\\n\\nO &bInscritor&f pode ser usado para transformar os vários cristais de quartzo do AE2 em sua forma de pó, mas, mais importante, é usado para fabricar &eCircuitos Impressos&f e &eProcessadores Especiais&f, como ficará mais claro na próxima missão."]
		}
		quest.5BB887411B8B38FA.quest_desc: {
			new: ["Quanto a expandir a Rede ME sem fio, o primeiro passo é, admitidamente, um tanto heterodoxo.\\n\\nO &bCondensador de Matéria&r é a versão do AE2 de uma lixeira, descartando quaisquer itens inseridos nele. Quando equipado com um &eComponente de Armazenamento&r, no entanto, o condensador pode aproveitar um pouco da energia restante do item sendo descartado e armazená-la para fazer dois itens de fabricações especiais a partir de energia concentrada suficiente.\\n\\nO primeiro desses dois itens é a &bMatter Ball&r, exigindo pelo menos um Componente de Armazenamento de 1k e o valor de 256 itens de material descartado."]
			old: ["Quanto a expandir a Rede ME sem fio, o primeiro passo é, admitidamente, um tanto heterodoxo.\\n\\nO &bCondensador de Matéria&f é a versão do AE2 de uma lixeira, descartando quaisquer itens inseridos nele. Quando equipado com um &eComponente de Armazenamento&f, no entanto, o condensador pode aproveitar um pouco da energia restante do item sendo descartado e armazená-la para fazer dois itens de criação especiais a partir de energia concentrada suficiente.\\n\\nO primeiro desses dois itens é a &bMatter Ball&f, exigindo pelo menos um Componente de Armazenamento de 1k e o valor de 256 itens de material descartado."]
		}
		quest.219932CB19258C16.quest_desc: {
			new: ["O terceiro Tier do Componente de Armazenamento, fornecendo &e16384&r bytes de armazenamento."]
			old: ["O terceiro Tier de Componente de Armazenamento, fornecendo &e16384&f bytes de armazenamento."]
		}
		quest.74FC0DDDB91DB172.quest_desc: {
			new: ["Para tornar a vida muito mais fácil, o AE2 fornece um conjunto completo de dispositivos para a manipulação de dados ME, ou seja, mover itens armazenados pelo mundo.\\n\\nA &bME Interface&r é um desses dispositivos. Como dispositivo de entrada, a Interface permite que qualquer item/fluido/etc seja canalizado externamente através dela, que é então automaticamente armazenado na Rede ME à qual a interface está conectada.\\n\\nComo dispositivo de saída, a Interface pode ser configurada para manter uma certa quantidade disponível de um item armazenado em estoque, da Rede ME para seu próprio inventário interno. Isso permite que os itens sejam recebidos por alguma fonte externa, como outro jogador ou algum cano."]
			old: ["Para tornar a vida muito mais fácil, o AE2 fornece um conjunto completo de dispositivos para a manipulação de dados ME, ou seja, mover itens armazenados pelo mundo.\\n\\nA &bME Interface&f é um desses dispositivos. Como dispositivo de entrada, a Interface permite que qualquer item/fluido/etc seja canalizado externamente através dela, que é então automaticamente armazenado na Rede ME à qual a interface está conectada.\\n\\nComo dispositivo de saída, a Interface pode ser configurada para manter uma certa quantidade disponível de um item armazenado em estoque, da Rede ME para seu próprio inventário interno. Isso permite que os itens sejam recebidos por alguma fonte externa, como outro jogador ou algum cano."]
		}
		quest.3DDB0DDA7571B2C1.quest_desc: {
			new: ["O &bEmissor de Nível ME&r, quando configurado com um item específico e uma quantidade dele para responder, emitirá um sinal de redstone dependendo se o item armazenado na rede cair abaixo, ultrapassar ou igualar a quantidade dada.\\n\\nIsso pode ser usado, por exemplo, para ligar automaticamente certas máquinas com redstone para fabricar automaticamente um recurso quando ele cai abaixo de uma quantidade mínima definida."]
			old: ["O &bEmissor de Nível ME&f, quando configurado com um item específico e uma quantidade dele para responder, emitirá um sinal de redstone dependendo se o item armazenado na rede cair abaixo, ultrapassar ou igualar a quantidade dada.\\n\\nIsso pode ser usado, por exemplo, para ligar automaticamente certas máquinas com redstone para fabricar automaticamente um recurso quando ele cai abaixo de uma quantidade mínima definida."]
		}
		task.40A7CC56DACC2623.title: {
			new: "Cabo ME"
			old: "Cabos de Vidro de ME"
		}
		quest.7EFBAF3E281D2EBE.quest_desc: {
			new: [
				"O &aPonto de Armazenamento&r, quando voltado para algum contêiner de armazenamento externo, permitirá que o contêiner seja usado como se fizesse parte da Rede ME, permitindo que itens sejam retirados do contêiner ou inseridos nele puramente via ME. "
				""
				"Os &aPonto de Armazenamento&r podem ser filtrados e receber prioridades específicas, de modo que itens específicos tentarão ir para o armazenamento anexado primeiro, no entanto, ele não moverá retroativamente quaisquer itens filtrados de qualquer outro lugar na rede para seu armazenamento anexado."
			]
			old: [
				"O &aPonto de Armazenamento ME&f, quando voltado para algum contêiner de armazenamento externo, permitirá que o contêiner seja usado como se fizesse parte da Rede ME, permitindo que itens sejam retirados do contêiner ou inseridos nele puramente via ME. "
				""
				"Os Ponto de Armazenamento podem ser filtrados e receber prioridades específicas, de modo que itens específicos tentarão ir para o armazenamento anexado primeiro, no entanto, ele não moverá retroativamente quaisquer itens filtrados de qualquer outro lugar na rede para seu armazenamento anexado."
			]
		}
		quest.6F3D0A248B5A9CA2.quest_desc: {
			new: [
				"As &bCélula de Armazenamento Espacial&r são usadas para conter um volume definido cada uma, e vêm em três capacidades diferentes, permitindo um máximo de 2x2x2, 16x16x16 e &6128x128x128&r blocos de espaço. "
				""
				"Após a codificação, uma célula recebe uma seção de espaço dentro da &edimensão&r de armazenamento espacial, juntamente com um ID exclusivo correspondente à região alocada para a célula. Uma célula codificada ainda pode ser usada na &bPorto de E/S Espacial&r para recuperar quaisquer blocos e entidades armazenados. "
				""
				"A partir daí, quaisquer blocos contidos na região de espaço da célula ou em um &6ECE&r do mesmo tamanho do usado para a codificação inicial podem ser movidos de volta para a Superfície ou para a dimensão espacial, respectivamente. Se houver blocos tanto na região espacial quanto no &6ECE&r, eles simplesmente trocarão de lugar."
			]
			old: [
				"As &bCélula de Armazenamento Espacial s&f são usadas para conter um volume definido cada uma, e vêm em três capacidades diferentes, permitindo um máximo de 2x2x2, 16x16x16 e &6128x128x128&r blocos de espaço. "
				""
				"Após a codificação, uma célula recebe uma seção de espaço dentro da &edimensão&f de armazenamento espacial, juntamente com um ID exclusivo correspondente à região alocada para a célula. Uma célula codificada ainda pode ser usada na &bPorta de E/S Espacial&r para recuperar quaisquer blocos e entidades armazenados. "
				""
				"A partir daí, quaisquer blocos contidos na região de espaço da célula ou em um &6ECE&r do mesmo tamanho do usado para a codificação inicial podem ser movidos de volta para o Mundo Superior ou para a dimensão espacial, respectivamente. Se houver blocos tanto na região espacial quanto no &6ECE&r, eles simplesmente trocarão de lugar."
			]
		}
		quest.18DFB25DC48D8BF7.quest_desc: {
			new: [
				"A Estrutura de Contenção Espacial (&6ECE&r) consiste em uma gaiola de &bPilão Espacial&r cobrindo o volume que você deseja encerrar em uma célula E/S Espacial. No mínimo absoluto, uma ECE requer três linhas de blocos de pilar espacial, uma para cada dimensão do espaço sendo contido (comprimento, largura, altura)."
				""
				"No entanto, a &bE/S Espacial&r é um recurso extremamente faminto por energia, especialmente ao tentar capturar espaços muito maiores (até &6128x128x128&r). Ter mais Pilão Espacial incluídos na &6ECE&r ao redor do volume desejado aumentará sua &eeficiência&r geral, permitindo que use menos energia para capturar."
				""
				"Além disso, esteja ciente de que cada pilar individual (independentemente de seu comprimento) ocupa um canal. Para espaços particularmente grandes, você pode querer construir uma rede dedicada com um controlador para acomodar todos os pilares necessários."
			]
			old: [
				"A Estrutura de Contenção Espacial (&6ECE&r) consiste em uma gaiola de &bPilares Espaciais&f cobrindo o volume que você deseja encerrar em uma célula de Espacial E/S. No mínimo absoluto, uma ECE requer três linhas de blocos de pilar espacial, uma para cada dimensão do espaço sendo contido (comprimento, largura, altura)."
				""
				"No entanto, a &bEspacial E/S&r é um recurso extremamente faminto por energia, especialmente ao tentar capturar espaços muito maiores (até &6128x128x128&r). Ter mais pilares espaciais incluídos na &6ECE&r ao redor do volume desejado aumentará sua &eeficiência&f geral, permitindo que use menos energia para capturar."
				""
				"Além disso, esteja ciente de que cada pilar individual (independentemente de seu comprimento) ocupa um canal. Para espaços particularmente grandes, você pode querer construir uma rede dedicada com um controlador para acomodar todos os pilares necessários."
			]
		}
		quest.51236544BFEF487B.quest_desc: {
			new: ["É hora de encontrar &eMeteoritos&r que contêm &bPedra do Céu&r. Eles podem estar na superfície ou no subsolo e contêm um &bCubo Misterioso&r em seu centro.\\n\\nEste cubo contém todas as diferentes &ePrensas&r usadas no Inscritor para fazer os componentes de fabricação especiais do AE2.\\n\\nA maneira mais fácil de localizar um meteorito é fabricando uma &eBússola de Meteorito&r, colocando uma bússola dentro de um Carregador."]
			old: ["É hora de encontrar &eMeteoritos&f que contêm &bPedra do Céu&f. Eles podem estar na superfície ou no subsolo e contêm um &bCubo Misterioso&f em seu centro.\\n\\nEste cubo contém todas as diferentes &ePrensas&f usadas no Inscritor para fazer os componentes de fabricação especiais do AE2.\\n\\nA maneira mais fácil de localizar um meteorito é fabricando uma &eBússola de Meteorito&r, colocando uma bússola dentro de um Carregador."]
		}
		quest.1B686954D34A0F23.quest_desc: {
			new: ["A &bChave de Quartzo&r faz o que qualquer chave de mod de tecnologia comum faria. Ela gira blocos e dispositivos na face em que você clica com o botão direito e os desmonta quando clicado com o botão direito enquanto se agacha.\\n\\nEsta Chave vem nas variedades de Quartzo Certus e Quartzo do Nether."]
			old: ["A &bChave de Quartzo&f faz o que qualquer chave de mod de tecnologia comum faria. Ela gira blocos e dispositivos na face em que você clica com o botão direito e os desmonta quando clicado com o botão direito enquanto se agacha.\\n\\nEsta Chave vem nas variedades de Quartzo Certus e Quartzo do Nether."]
		}
		quest.4597D3B3BDC2BED5.quest_desc: {
			new: ["O &bMontador Molecular&r é o equivalente do AE2 a uma mesa de trabalho automática, necessária para cumprir todos os trabalhos de &ePadrão de Fabricação&r.\\n\\nMontadores Moleculares são capazes de transferir energia e canais para outros dispositivos ME conectados a ele, mas não ocuparão um canal. Até 6 &6MM's&r podem ser conectados a um único Provedor de Padrões (se empregado) para permitir que mais criações sejam feitas em paralelo.\\n\\n&6MMs&r também têm cada um seu próprio slot dedicado para um único Padrão de Fabricação, permitindo que funcionem de forma autônoma quando energizados. Quando operados desta forma, quaisquer itens correspondentes inseridos no MA serão automaticamente criados no resultado do padrão."]
			old: ["O &bMontador Molecular&f é o equivalente do AE2 a uma mesa de trabalho automática, necessária para cumprir todos os trabalhos de padrões de &ecriação&f.\\n\\nMontadores Moleculares são capazes de transferir energia e canais para outros dispositivos ME conectados a ele, mas não ocuparão um canal. Até 6 &6MM's&r podem ser conectados a um único Provedor de Padrões (se empregado) para permitir que mais criações sejam feitas em paralelo.\\n\\n&6MMs&r também têm cada um seu próprio slot dedicado para um único padrão de criação, permitindo que funcionem de forma autônoma quando energizados. Quando operados desta forma, quaisquer itens correspondentes inseridos no MA serão automaticamente criados no resultado do padrão."]
		}
		quest.69B7DE2283B4EE6C.quest_desc: {
			new: ["A &bUnidade de Co-processamento de Fabricação&r ajuda a acelerar os trabalhos de fabricação, permitindo que os provedores de padrões enviem itens para seus dispositivos conectados mais rapidamente ou trabalhem simultaneamente para fazer vários ingredientes necessários.\\n\\nA unidade de co-processamento base do AE2 fornece uma 'thread' de co-processador para auxiliar nisso, enquanto a unidade de co-processamento de &dMEGA Células&r fornece 4 threads em um único bloco."]
			old: ["A &bUnidade de Co-processamento de Criação&f ajuda a acelerar os trabalhos de criação, permitindo que os provedores de padrões enviem itens para seus dispositivos conectados mais rapidamente ou trabalhem simultaneamente para fazer vários ingredientes necessários.\\n\\nA unidade de co-processamento base do AE2 fornece uma 'thread' de co-processador para auxiliar nisso, enquanto a unidade de co-processamento de &dMEGA Células&f fornece 4 threads em um único bloco."]
		}
		quest.0E809747193ED3A9.quest_desc: {
			new: ["O terceiro Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e16777216&r (16384k) bytes de armazenamento."]
			old: ["O terceiro Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e16777216&f (16384k) bytes de armazenamento."]
		}
		quest.2C04B3BA507D5673.quest_desc: {
			new: ["&bPadrões&r são o que contém uma receita codificada para ser realizada por um Provedor de Padrões. Para codificar uma receita em um Padrão, o &bTerminal de Codificação de Padrões ME&r deve ser usado.\\n\\nPadrões podem ser configurados para conter uma receita de &efabricação&r regular, que exigirá o uso de um &eMontador Molecular&r na face de seu Fornecedor, ou uma receita de '&eprocessamento&r' mais geral, onde quaisquer itens de entrada podem ser enviados pelo fornecedor para algum outro bloco de máquina ou planta de processamento especializada."]
			old: ["&bPadrões&f são o que contém uma receita codificada para ser realizada por um Provedor de Padrões. Para codificar uma receita em um Padrão, o &bTerminal de Codificação de Padrões ME&f deve ser usado.\\n\\nPadrões podem ser configurados para conter uma receita de &efabricação&f regular, que exigirá o uso de um &eMontador Molecular&f na face de seu Fornecedor, ou uma receita de '&eprocessamento&f' mais geral, onde quaisquer itens de entrada podem ser enviados pelo fornecedor para algum outro bloco de máquina ou planta de processamento especializada."]
		}
		quest.01F3F0C25BA72BDA.quest_desc: {
			new: [
				"Além do armazenamento de itens e fluidos, o AE2 também oferece uma maneira nativa de armazenar &eestruturas&r inteiras dentro de células de armazenamento, não muito diferente do mod Compact Machines."
				""
				"A &bPorto de E/S Espacial&r permite que estruturas contidas em uma &bEstrutura de Contenção Espacial&r sejam capturadas dentro de uma célula de armazenamento especialmente projetada, ativada por um sinal de redstone."
				""
				"Se um mob ou jogador estiver dentro da &6ECE&r enquanto o espaço está sendo capturado, eles também serão transportados para onde o resto do espaço vai, ou seja, para uma dimensão dedicada. Apenas certifique-se de ter uma maneira de voltar e entrar se for você quem está sendo capturado."
			]
			old: [
				"Além do armazenamento de itens e fluidos, o AE2 também oferece uma maneira nativa de armazenar &eestruturas&f inteiras dentro de células de armazenamento, não muito diferente do mod Compact Machines."
				""
				"A &bPorta de E/S Espacial&f permite que estruturas contidas em uma &bEstrutura de Contenção Espacial&f sejam capturadas dentro de uma célula de armazenamento especialmente projetada, ativada por um sinal de redstone."
				""
				"Se um mob ou jogador estiver dentro da &6ECE&r enquanto o espaço está sendo capturado, eles também serão transportados para onde o resto do espaço vai, ou seja, para uma dimensão dedicada. Apenas certifique-se de ter uma maneira de voltar e entrar se for você quem está sendo capturado."
			]
		}
		quest.25DBA00422301EDC.quest_desc: {
			new: ["O segundo Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e4194304&r (4096k) bytes de armazenamento."]
			old: ["O segundo Tier &5MEGA&r de Componente de Armazenamento, fornecendo &e4194304&f (4096k) bytes de armazenamento."]
		}
		quest.0F03E75CF79BADD7.quest_desc: {
			new: ["MEGA Cells&r oferece a &bCélula de Armazenamento para Itens em Massa&r personalizada, que é limitada a no máximo &oum&r tipo de item armazenável por célula, mas pode armazenar um número praticamente &6&lINFINITO&e*&r daquele tipo de item. Antes que possa aceitar um tipo de item, deve ser filtrada antecipadamente usando uma Bancada de Células.\\n\\n*&oTecnicamente \"comprimento máximo\". Se você sabe, você sabe.&r"]
			old: ["MEGA Cells&f oferece a &bCélula de Armazenamento de Itens em Massa&f personalizada, que é limitada a no máximo &oum&r tipo de item armazenável por célula, mas pode armazenar um número praticamente &6&lINFINITO&e*&r daquele tipo de item. Antes que possa aceitar um tipo de item, deve ser filtrada antecipadamente usando uma Bancada de Células.\\n\\n*&oTecnicamente \"comprimento máximo\". Se você sabe, você sabe.&r"]
		}
		quest.6431A384DDFBF439.quest_desc: {
			new: [
				"A &bFerramenta de Rede&r é uma ferramenta importante em todo o AE2, usada para exibir vários detalhes de uma rede na tela, como o consumo geral de energia e o armazenamento."
				""
				"Como um bônus adicional, ela também fornece seu próprio pequeno inventário usado para guardar &ecartões de upgrade&r, que pode ser acessado ao olhar para a tela de qualquer dispositivo atualizável para fácil substituição. No entanto, ela não pode girar blocos anexados à Rede ME como uma chave inglesa normal, apenas desmontá-los quando agachado."
			]
			old: [
				"A &bFerramenta de Rede&f é uma ferramenta importante em todo o AE2, usada para exibir vários detalhes de uma rede na tela, como o consumo geral de energia e o armazenamento."
				""
				"Como um bônus adicional, ela também fornece seu próprio pequeno inventário usado para guardar &ecartões de upgrade&f, que pode ser acessado ao olhar para a tela de qualquer dispositivo atualizável para fácil substituição. No entanto, ela não pode girar blocos anexados à Rede ME como uma chave inglesa normal, apenas desmontá-los quando agachado."
			]
		}
		task.64EAD3DE84E94F02.title: {
			new: "Cabo ME Coberto"
			old: "ME Covered Cables"
		}
		quest.30E853CE699E669B.quest_desc: {
			new: ["Antes de poder realizar um trabalho de auto-fabricação, você precisa de um dispositivo para armazenar a solicitação em si, juntamente com quaisquer itens intermediários para fabricações de múltiplos passos. Este dispositivo é conhecido como uma &eCPU de fabricação&r.\\n\\nUma CPU de fabricação é uma estrutura multibloco que requer pelo menos um &bBloco de Armazenamento de Fabricação&r, opcionalmente junto com qualquer outra &9Unidade de Fabricação&r. O multibloco pode ser feito em qualquer tamanho, mas deve ser um cubo sólido para se formar e funcionar adequadamente."]
			old: ["Antes de poder realizar um trabalho de auto-criação, você precisa de um dispositivo para armazenar a solicitação em si, juntamente com quaisquer itens intermediários para criações de múltiplos passos. Este dispositivo é conhecido como uma &eCPU de criação&f.\\n\\nUma CPU de criação é uma estrutura multibloco que requer pelo menos um bloco de &bArmazenamento de Criação&f, opcionalmente junto com qualquer outra Unidade de Criação. O multibloco pode ser feito em qualquer tamanho, mas deve ser um cubo sólido para se formar e funcionar adequadamente."]
		}
		quest.00611844AFD5C31E.quest_desc: {
			new: ["Embora o &eInscritor&r e o &eCarregador&r aceitem nativamente &eRF/FE&r, a grande maioria de uma &eRede ME&r usa seu próprio sistema de energia dedicado chamado AE.\\n\\n&eRF/FE&r pode ser convertido para o &bAE&r nativo na proporção de 2:1 RF:AE, seja diretamente através de um &bControlador ME&r, ou através do &bAceitador de Energia&r, que pode ser conectado a qualquer parte da rede."]
			old: ["Embora o &eInscritor&r e o &eCarregador&r aceitem nativamente &eRF/FE&r, a grande maioria de uma &eRede ME&r usa seu próprio sistema de energia dedicado chamado AE.\\n\\n&eRF/FE&r pode ser convertido para o &bAE&r nativo na proporção de 2:1 RF:AE, seja diretamente através de um &bControlador ME&r, ou através do &bAceitador de Energia&f, que pode ser conectado a qualquer parte da rede."]
		}
		quest.4E8A05C3BFA80540.quest_desc: {
			new: ["Indiscutivelmente o aspecto mais importante do Applied Energistics 2 é seu sistema de armazenamento, fazendo uso de &eCélulas de Armazenamento&r digitais. Essas células são acessíveis através de um &eBaú ME&r para células únicas, ou um &eGabinete ME&r para múltiplas células.\\n\\nO &bBaú ME&r comporta uma única Célula por vez, que pode então ser lida e escrita de qualquer outro terminal na mesma rede. O próprio Baú ME também fornece sua própria tela de terminal no topo com acesso específico apenas à célula que contém.\\n\\nO &bGabinete ME&r pode comportar até 10 Células de Armazenamento variadas no espaço de um único bloco e um único canal ME. No entanto, ele não fornece sua própria tela de terminal, exigindo algum terminal externo em outro lugar da rede para acesso ao armazenamento."]
			old: ["Indiscutivelmente o aspecto mais importante do Applied Energistics 2 é seu sistema de armazenamento, fazendo uso de &eCélulas de Armazenamento&f digitais. Essas células são acessíveis através de um &eBaú ME&r para células únicas, ou um &eGabinete ME&r para múltiplas células.\\n\\nO &bBaú ME&f comporta uma única Célula por vez, que pode então ser lida e escrita de qualquer outro terminal na mesma rede. O próprio Baú ME também fornece sua própria tela de terminal no topo com acesso específico apenas à célula que contém.\\n\\nO &bGabinete ME&f pode comportar até 10 Células de Armazenamento variadas no espaço de um único bloco e um único canal ME. No entanto, ele não fornece sua própria tela de terminal, exigindo algum terminal externo em outro lugar da rede para acesso ao armazenamento."]
		}
		quest.2077D64428E9C067.quest_subtitle: {
			new: "Isso tem um uso além de fabricar cabos."
			old: "Isso tem um uso além de criar cabos."
		}
		quest.6144202A97C6CD1C.quest_desc: {
			new: ["A &bFacas de Corte de Quartzo&r, como a chave inglesa, vem nas versões de quartzo do nether e certus e é uma ferramenta de fabricação útil para se ter à mão.\\n\\nCabos também podem ser separados sem a necessidade de serem coloridos, anexando uma &bÂncora para Cabos ME&r entre eles, criada com esta faca e fabricável até 50 vezes com a mesma faca antes que ela quebre.\\n\\nÂncora para Cabos ME também podem ser usadas para fabricar &bFachada de Cabos&r, permitindo que você disfarce cabos dentro de paredes, cobrindo-os com a face de um bloco arbitrário. Embora as receitas de fachada estejam ocultas no JEI, você ainda pode fabricar pegando qualquer bloco regular e cercando-o com 4 âncoras de cabo na grade de fabricação.\\n\\nAlém de fabricar âncoras, a faca de corte também tem outro uso: clicar com o botão direito com a faca abrirá uma pequena INTERFACE que permite fabricar &bPrensas de Nome para Gravador&r. Quando recebem um nome, essas prensas podem ser usadas dentro de um Gravador para renomear qualquer item de entrada com o nome da prensa. Duas dessas prensas podem ser concatenadas no gravador para renomear o item para o nome da prensa de cima, seguido pela de baixo."]
			old: ["A &bFacas de Corte de Quartzo&f, como a chave inglesa, vem nas versões de quartzo do nether e certus e é uma ferramenta de criação útil para se ter à mão.\\n\\nCabos também podem ser separados sem a necessidade de serem coloridos, anexando uma &bCable Anchor&f entre eles, criada com esta faca e fabricável até 50 vezes com a mesma faca antes que ela quebre.\\n\\nÂncoras de Cabo também podem ser usadas para criar &bCable Facades&f, permitindo que você disfarce cabos dentro de paredes, cobrindo-os com a face de um bloco arbitrário. Embora as receitas de fachada estejam ocultas no JEI, você ainda pode criá-las pegando qualquer bloco regular e cercando-o com 4 âncoras de cabo na grade de criação.\\n\\nAlém de criar âncoras, a faca de corte também tem outro uso: clicar com o botão direito com a faca abrirá uma pequena INTERFACE que permite criar &bPrensas de Nome para Gravador&f. Quando recebem um nome, essas prensas podem ser usadas dentro de um Gravador para renomear qualquer item de entrada com o nome da prensa. Duas dessas prensas podem ser concatenadas no gravador para renomear o item para o nome da prensa de cima, seguido pela de baixo."]
		}
		quest.6D54B45CDA70FEAB.quest_desc: {
			new: ["O &bCartão de Energia&r pode ser aplicado à maioria dos dispositivos recarregáveis, como Célula Portátil e Terminais Sem Fio (abordados mais tarde), para também aumentar &oseu&r buffer de energia."]
			old: ["O &bCartão de Energia&f pode ser aplicado à maioria dos dispositivos recarregáveis, como Célula Portátil e Terminais Sem Fio (abordados mais tarde), para também aumentar &oseu&r buffer de energia."]
		}
		quest.5F56892CD904C40F.quest_desc: {
			new: ["O quinto e último Tier padrão de Componente de Armazenamento do AE2, fornecendo &e262144&r bytes de armazenamento."]
			old: ["O quinto e último Tier padrão de Componente de Armazenamento do AE2, fornecendo &e262144&f bytes de armazenamento."]
		}
		quest.4BF0BB763BFFACF0.quest_desc: {
			new: [
				"Indiscutivelmente, o recurso mais importante que você precisará a seguir é o &5Fluix&r, usado na grande maioria dos dispositivos &bAE2&r e servindo como base para a Fabricação de toda a fiação dentro de uma Rede ME."
				""
				"Você normalmente vai querer produzir isso em massa, e a maneira de fazer isso é fazer um &dCristal de Fluix&r jogando &eQuartzo do Nether&r, &bQuartzo de Certus &oCarregado&r e &cRedstone&r juntos em uma poça de água. Isso lhe dará um &5Cristal de Fluix&r que você pode transformar em pó em um &eInscritor&r."
			]
			old: [
				"Indiscutivelmente, o recurso mais importante que você precisará a seguir é o &5Fluix&f, usado na grande maioria dos dispositivos &bAE2&r e servindo como base para a criação de toda a fiação dentro de uma Rede ME."
				""
				"Você normalmente vai querer produzir isso em massa, e a maneira de fazer isso é fazer um &dCristal de Fluix&f jogando &eQuartzo do Nether&f, &bQuartzo de Certus &oCarregado&r e &cRedstone&f juntos em uma poça de água. Isso lhe dará um &5Cristal de Fluix&r que você pode transformar em pó em um &eInscritor&r."
			]
		}
		quest.2F16B6A173525277.quest_desc: {
			new: [
				"A última peça do quebra-cabeça para qualquer grande Rede ME é o &bControlador ME&r. "
				""
				"Um controlador fornece a uma Rede ME um número muito maior de canais do que os 8 canais padrão para redes ad-hoc, fornecendo &b32 canais&r de cada face do bloco para um total de &b216 canais&r. "
				""
				"Isso é apenas para um controlador de um único bloco, no entanto, já que o Controlador ME é, na verdade, uma estrutura multi-bloco. O controlador pode ter até &e7x7x7 blocos&r de tamanho e pode vir em qualquer arranjo de forma livre dentro desse tamanho máximo. Cada bloco individual pode então fornecer seu próprio conjunto separado de canais, desde que nenhum bloco de controlador único esteja cercado por 4 outros blocos no mesmo plano. "
				""
				"Uma Rede ME pode conter apenas um controlador multi-bloco a qualquer momento. Tentar conectar mais de um controlador em partes separadas da rede causará um conflito, desligando toda a rede."
			]
			old: [
				"A última peça do quebra-cabeça para qualquer grande Rede ME é o &bControlador ME&f. "
				""
				"Um controlador fornece a uma Rede ME um número muito maior de canais do que os 8 canais padrão para redes ad-hoc, fornecendo &b32 canais&r de cada face do bloco para um total de &b216 canais&r. "
				""
				"Isso é apenas para um controlador de um único bloco, no entanto, já que o Controlador ME é, na verdade, uma estrutura multi-bloco. O controlador pode ter até &e7x7x7 blocos&r de tamanho e pode vir em qualquer arranjo de forma livre dentro desse tamanho máximo. Cada bloco individual pode então fornecer seu próprio conjunto separado de canais, desde que nenhum bloco de controlador único esteja cercado por 4 outros blocos no mesmo plano. "
				""
				"Uma Rede ME pode conter apenas um controlador multi-bloco a qualquer momento. Tentar conectar mais de um controlador em partes separadas da rede causará um conflito, desligando toda a rede."
			]
		}
		quest.5E7E35CCAF1C88EE.quest_desc: {
			new: ["O &bPonto de Importação&r suga itens periodicamente de qualquer armazenamento externo para o qual o bus esteja voltado. Opcionalmente, pode ser filtrado para receber apenas certos itens do referido inventário."]
			old: ["O &bPonto de Importação ME&f suga itens periodicamente de qualquer armazenamento externo para o qual o bus esteja voltado. Opcionalmente, pode ser filtrado para receber apenas certos itens do referido inventário."]
		}
	}
	"chapters/content_creators.snbt": {
		quest.7AB52F600829F468.quest_desc: {
			new: ["De um dos streamers de &2&lMinecraft&r mais conhecidos para outro, agora é hora de enfrentar o &b&lChosen Architect&r. \\n\\nEle tem sua própria torre, a &bTorre do Chosen&r, onde aparecerá. \\n\\nNão deixe que os sentimentos de amor e nostalgia por seus vídeos e Modpacks te impeçam de derrotá-lo. \\n\\n&cPokémon&r vem antes do amor, você já deveria saber disso!"]
			old: ["De um dos streamers de &2&lMinecraft&r mais conhecidos para outro, agora é hora de enfrentar o &b&lChosen Architect&r. \\n\\nNão deixe que todos esses sentimentos de amor e nostalgia por seus vídeos e Modpacks o impeçam de derrotá-lo. \\n\\n&cPokémon&r vem antes do amor, você já deveria saber disso a esta altura!"]
		}
		quest.31749B21AD674C5F.quest_desc: {
			new: ["O próximo é o &6&lVirtuositas&r! \\n\\nEle é conhecido por usar o mod &6&lCreate&r e o &c&lCobble&fmon&r! Temos ambos em &c&lAll&7The&fMons&r, mas limite-se a derrotá-lo com &c&lCobble&fmon&r. \\n\\nAcho que você perderia em uma batalha de &6&lCreate&r... seja lá o que isso signifique."]
			old: ["O próximo é &6&lVirtuositas&r! \\n\\nEle é conhecido por usar o mod &6&lCreate&r e &c&lCobble&fmon&r! Temos ambos no &c&lAll&7The&fMons&r, mas limite-se a derrotá-lo com &c&lCobble&fmon&r. \\n\\nAcho que você perderia em uma batalha de &6&lCreate&r... seja lá o que isso signifique."]
		}
		quest.4E921DD32E1C4ABA.quest_desc: {
			new: ["O próximo da lista é o &7&lJoeychin01&r! \\n\\n&7&lJoey&r não tem um canal, mas ajuda muito com nossos Modpacks! \\n\\nQuer dizer, ei, isso ainda é conteúdo e ele está criando. Então o considero um Criador de Conteúdo."]
			old: ["O próximo na lista é o &7&lJoeychin01&r! \\n\\n&7&lJoey&r não tem um Canal, mas ele ajuda muito com nossos Modpacks! \\n\\nDigo, ei, isso ainda é Conteúdo e ele o está produzindo. Então eu o considero um Criador de Conteúdo."]
		}
		quest.13EB9A996928ED60.quest_desc: {
			new: ["Por último, mas certamente não menos importante, é o &5&lNofaxu&r! \\nEle aparece com &c&lDanrique&r na Estrutura &5Siderúrgica &cFuturista&r. \\n\\nSe o derrotar, 1. dê um tapinha nas costas, pois você acabou de vencer alguém com mais de um milhão de inscritos no Youtube! E 2. você terá terminado a &4&oSérie&r. \\n\\nMas ei, se começar a sentir remorso e culpa por destruir impiedosamente seus Criadores favoritos em &l&cAll&7The&fMons&r, sabe, aqueles que passaram a carreira inteira te ajudando a entender e aproveitar melhor os jogos que você tanto ama... pode compensar conferindo os canais deles!"]
			old: ["Por último, mas certamente não menos importante, está o &5&lNofaxu&r! \\nSe você o derrotar, 1. dê um tapinha nas suas próprias costas porque você acabou de vencer um cara com mais de um Milhão de Inscritos no Youtube! E 2. você terá terminado a &4&oSérie&r. \\n\\nMas ei, se você começar a sentir arrependimento e culpa por destruir impiedosamente seus Criadores favoritos no &l&cAll&7The&fMons&r, sabe, aqueles que passaram suas carreiras inteiras ajudando você a entender melhor e aproveitar os jogos que você tanto ama... você pode compensar isso conferindo os canais deles!"]
		}
		quest.0709CE22181A74BB.quest_desc: {
			new: ["O terceiro a ser derrotado é o &a&lMitinho Player&r. \\nÉ só procurar por uma &aEsmeralda&r nas costas da skin dele, isso te ajudará a encontrá-lo. \\n\\nAliás, nem todos os Criadores de Conteúdo têm o inglês como idioma principal! É verdade, o &6&lATM&r ultrapassa a barreira do idioma!"]
			old: ["A 3ª pessoa a derrotar é o &a&lMitinho Player&r. \\nBasta procurar por uma &aEsmeralda&r nas costas da skin dele, isso ajudará você a encontrá-lo. \\n\\nAlém disso, nem todos os Criadores de Conteúdo têm o inglês como língua primária! É verdade, o &6&lATM&r se espalha além da barreira linguística!"]
		}
		quest.349E8C0C3F9CC99B.quest_desc: {
			new: ["Primeiro as damas, eu suponho! \\n\\nA primeira streamer que você precisa derrotar é a &d&lPrincessStellar&r! \\n\\nEla ajuda muito no &6&lATM&r, inclusive nas Missões! Se você está lendo isto em português do Brasil, agradeça a ela por isso! "]
			old: ["Damas primeiro, eu suponho! \\n\\nA primeira streamer que você precisará derrotar é a &d&lPrincessStellar&r! \\n\\nEla ajuda muito no &6&lATM&r, incluindo nas Missões! Se você está lendo isso em Português Brasileiro, agradeça a ela por isso! "]
		}
		quest.5AF01BC5631ED1BD.quest_desc: {
			new: ["Esta Missão foi criada pela &6Equipe AllTheMods&r, ou por um &2contribuidor da Comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta. Se você está vendo isto, você está no modo de edição."]
			old: ["Esta Missão foi escrita pela &6Equipe AllTheMods&r, ou por um &2colaborador da comunidade&r para uso nos Modpacks AllTheMods.\\n\\nComo todos os pacotes &6AllTheMods&r são licenciados sob &eTodos os Direitos Reservados&r, esta Missão não pode ser usada em nenhum pacote público não lançado pela &6Equipe AllTheMods&r sem permissão explícita.\\n\\nEsta missão está intencionalmente oculta; se você está vendo isso, você está no modo de edição."]
		}
		quest.261E8EE0C7E7E2F0.quest_desc: {
			new: ["&c&lDanrique&r! O único que veio com uma skin que combina com o tema! \\n\\nVocê pode encontrá-lo na Estrutura &5Siderúrgica &cFuturista&r! \\n\\nProcure pelo Criador de Conteúdo com estilo de quem te derrotaria em uma Batalha &cPokémon&r... e então derrote-o!"]
			old: ["&c&lDanrique&r! O único que veio com uma Skin que combina com o tema! \\n\\nProcure pelo Criador de Conteúdo que está no estilo de alguém que te derrotaria em uma Batalha &cPokémon&r... então derrote-o no lugar dele!"]
		}
		quest.507635FE52E22D7D.quest_desc: {
			new: ["Saindo de uma skin com tema de &cPokémon&r para alguém com a skin do Steve, temos o &3&lDirewolf20&r! \\n\\nVocê pode encontrá-lo na &3Casa do DW&r, também conhecida como &3Casa do DireWolf&r! \\n\\nConhecido por criar e jogar mods há anos. Agora ele também será conhecido por perder para você! \\n\\n&3&lJust Dire Things&r não vai te ajudar aqui, &3&lDirewolf&r!"]
			old: ["Passando de uma Skin com tema &cPokémon&r para alguém usando a Skin do Steve, é o &3&lDirewolf20&r! \\n\\nConhecido por criar e jogar Mods por anos. Agora ele será conhecido por perder para você também! \\n\\n&3&lJust Dire Things&r não vai te ajudar aqui, &3&lDirewolf&r!"]
		}
		quest.273605A191309522.quest_desc: {
			new: ["Depois de &9&lBucketST&r, vem o &lPilpoh&r. \\n\\nEm vez de usar um &6Lingote de Allthemodium&r, ele na verdade usa Concreto Branco para invocá-lo com um &4Gerador de Treinador&r. \\n\\nConhecendo-o, ele fará uma série jogando &l&cAll&7The&fMons&r... isso significa que ele acabará lutando contra si mesmo? Que... estranho."]
			old: ["Depois do &a&lMinitho Player&r vem o &lPilpoh&r. \\n\\nEm vez de usar um &6Lingote de Allthemodium&r ele na verdade usa Concreto Branco para invocá-lo com um &4Gerador de Treinadores&r. \\n\\nConhecendo-o, ele fará uma série dele jogando &l&cAll&7The&fMons&r... isso significa que ele acabará lutando contra si mesmo? Isso parece... estranho."]
		}
	}
	"chapters/chapter_2_the_star.snbt": {
		quest.0923C941A9696122.title: {
			new: "Célula de Item Portátil de 256M"
			old: "256M Portable Item Cell"
		}
		quest.792990DC06DB98F9.quest_desc: {
			new: ["Pela &2&lSuperfície&r você pode encontrar Ruínas do Portal de &5&lEternal Starlight&r. Lá você pode desafiar o Guardião do Portal para uma luta! \\n\\nSe você vencer, ele lhe dará alguns Itens e com eles você poderá entrar no Portal para um mundo totalmente novo para explorar!"]
			old: ["Pelo &2&lMundo Superior&r você pode encontrar Ruínas do Portal de &5&lEternal Starlight&r. Lá você pode desafiar o Guardião do Portal para uma luta! \\n\\nSe você vencer, ele lhe dará alguns Itens e com eles você poderá entrar no Portal para um mundo totalmente novo para explorar!"]
		}
		quest.2A444F4CCC72545D.quest_desc: {
			new: ["O Item mais fácil que precisaremos para a &6&lEstrela ATM&r do &4&lCataclysm&r é o &5Sacrifício Abissal&r. \\n\\nOs Itens mais básicos necessários são os Blocos de Barras e Ametista, que são apenas Itens &2&lVanilla&r. \\n\\nEntão, você precisará de uma Concha de Náutilo e um Coração do Mar. Estes são Itens &2&lVanilla&r que são raros de obter... a menos que você mate &5Deeplings&r que pode dropar Concha de Náutilo! \\n\\nVocê também precisará de um Athame, que é uma arma usada por &5Feiticeiros Deepling&r e &5Sacerdotes&r e dropada por eles na morte. \\nA última parte nos dá uma escolha, ou Coral Cristalizado ou Pedaço de Coral. Ambos são drops do &5Golem de Coral&r e do &5Coralssus&r."]
			old: ["O Item mais fácil que precisaremos para a &6&lEstrela ATM&r do &4&lCataclysm&r é o &5Sacrifício Abissal (Abyssal Sacrifice)&r. \\n\\nOs Itens mais básicos necessários são os Blocos de Barras e Ametista, que são apenas Itens &2&lVanilla&r. \\n\\nEntão, você precisará de uma Concha de Náutilo e um Coração do Mar. Estes são Itens &2&lVanilla&r que são raros de obter... a menos que você mate &5Deeplings&r que podem dropá-los! \\n\\nVocê também precisará de um Athame, que é uma arma usada por &5Feiticeiros Deepling &f e &5Sacerdotes&r e dropada por eles na morte. \\nA última parte nos dá uma escolha, ou Coral Cristalizado ou Pedaço de Coral. Ambos são drops do &5Golem de Coral&r e do &5Coralssus&r."]
		}
		quest.268EA2DEC8840D13.quest_desc: {
			new: ["Ao trabalhar com &4Computadores&r, especialmente os Quânticos, os Martelos e Alicates na Bancada de Trabalho não conseguirão fabricar o que precisamos, precisaremos de um &bMontador de Cristal&r. \\n\\nPara este, precisaremos de um monte de &9Singularidades&r!"]
			old: ["Ao trabalhar com &4Computadores&r, especialmente os Quânticos, os Martelos e Alicates na Bancada de Trabalho não conseguirão fabricar o que precisamos, precisaremos de um &bMontador de Cristal (Crystal Assembler)&r. \\n\\nPara este, precisaremos de um monte de &9Singularidades&r!"]
		}
		quest.4195800B4D7631E2.quest_desc: {
			new: ["Através do ritual da &6Compulsão Espectral de Eziveus&r, podemos combinar uma &7Estrutura de Buraco de Minhoca&r, 2 Quartzos e uma &3Pérola do End&r para obter nosso Buraco de Minhoca!"]
			old: ["Através do ritual da &6Compulsão Espectral de Eziveus&r, podemos combinar uma &7Estrutura de Buraco de Minhoca&r, 2 Quartzos e uma &3Enderpearl&r para obter nosso Buraco de Minhoca!"]
		}
		quest.4E8C32CD6057A1AB.quest_desc: {
			new: ["O &cQueimadores de Blaze&r é na verdade provavelmente um dos Ingredientes da &6&lEstrela&r mais fáceis! \\n\\nPrimeiro, precisaremos de um &cQueimadores de Blaze Vazio&r. Estes são apenas 4 &7Chapas de Ferro&r e uma única &cNetherrack&r. \\n\\nEntão, pegue seu &cQueimadores de Blaze Vazio&r e encontre um &cBlaze&r. Você deve saber onde eles surgem, mas caso não saiba: &cBlazes&r surgem em Estruturas no &c&lNether&r. Apenas segure o &cQueimadores de Blaze Vazio&r na mão principal e Clique Direito no &cBlaze&r para capturá-lo! \\n\\nUma vez capturado, ele pode ser usado para fazer o &c&lCombustível do Filósofo&r."]
			old: ["Para fazer o &c&lCombustível do Filósofo&r, você precisa fabricar o &cQueimador de Blaze&r. \\n\\nEste &ccomponente&r é essencial para a fabricação desse combustível poderoso (&n&lou quase&r&r), então não tem como pular essa etapa! \\n\\nCertifique-se de reunir tudo o que você precisa para fabricar o seu &cQueimador de Blaze&r antes de avançar."]
		}
		quest.5869E198DA416346.quest_desc: {
			new: ["O fim de jogo do &5&lMekanism&r é simplesmente insano. Para 1 &5Pellet de Antimatéria&r, você precisa cristalizar 1.000mb de &5Antimatéria&r. \\n\\nPara 1mb de &5Antimatéria&r, você precisa energizar 1.000mb de &3Polônio&r através do AFS. \\n\\nPara obter 1mb de &3Polônio&r, você precisará ativar os Nêutrons de 5mb de &2Lixo Nuclear&r. \\n\\nE &2Lixo Nuclear&r você obtém processando &9Combustível Fóssil&r através de um Reator de Fissão!"]
			old: ["O Fim de Jogo do &5&lMekanism&r é simplesmente insano. Para 1 &5Pellet de Antimatéria&r, você precisa cristalizar 1.000mb de &5Antimatéria&r. \\n\\nPara 1mb de &5Antimatéria&r, você precisa energizar 1.000mb de &3Polônio&r através do AFS. \\n\\nPara obter 1mb de &3Polônio&r, você precisará ativar os Nêutrons de 5mb de &2Lixo Nuclear&r. \\n\\nE &2Lixo Nuclear&r você obtém processando &9Combustível Fóssil&r através de um Reator de Fissão!"]
		}
		quest.0923C941A9696122.quest_desc: {
			new: ["Caso você precise levar 256 Milhões de Itens em uma Aventura com você! \\n\\nVocê precisará de alguns Itens simples como &8Cápsula de Célula de Item MEGA&r, &5Baú ME&r e uma &5Célula de Energia Densa&r. \\n\\nE então precisaremos do &dComponente de Armazenamento MEGA de 256M&r... este é muito mais difícil de fabricar."]
			old: ["Caso você precise levar 256 Milhões de Itens em uma Aventura com você!\\n\\nVocê precisará de alguns Itens simples como &8MEGA Item Cell Housing&r, &5Baú ME&r e uma &5Dense Energy Cell&r.\\n\\nE então precisaremos do &d256M MEGA Storage Component&r... este é muito mais difícil de fazer.\\n\\nSe a Criação repetitiva te faz odiar o &2&lMinecraft&r, então você pode querer Criar a &2Carcaça à Prova de Explosão&r!\\n\\nPrecisaremos de 2 Células de Item Portátil de 256M, 2 &2Carcaças à Prova de Explosão&r, ou uma mistura de ambos para Criar o &3&lDispositivo de Probabilidade Improvável&r."]
		}
		quest.263C9A0FC04472AB.quest_desc: {
			new: ["Este pode tanto consumir &cLava&r como nenhum outro, ou ser usado para a &6&lEstrela&r. \\n\\nEste é difícil, eu gosto de ver a &cLava&r desaparecer em vez das minhas coisas desaparecerem na &cLava&r."]
			old: ["Este pode tanto consumir &cLava&r como nenhum outro, ou ser usado para a &6&lEstrela (Star)&r. \\n\\nEste é difícil, eu gosto de ver a &cLava&r desaparecer em vez das minhas coisas desaparecerem na &cLava&r."]
		}
		quest.5A955C0F53AED3ED.quest_desc: {
			new: ["A &bCorrente de Ligação da Alma&r funciona de forma semelhante a um Gancho. \\n\\nVocê pode usar o Clique Direito para ela lançar uma &bCorrente&r que o arrastará em direção ao Bloco em que você atirou. Você pode usar o Clique Direito novamente para soltá-la. Além disso, ela tem um Alcance de 90 Blocos, mais ou menos. \\n\\nPara fazê-la, você precisará de uma &bAlma Aprisionada&r, 2 &5Trepadeiras Tenazes&r e uma &9Pétala Tenaz&r. \\n\\nEstes são itens deixados pela &9Monstruosidade Lunar&r. "]
			old: ["A &bCorrente de Almas&r funciona de forma semelhante a um Gancho de Arpão. \\n\\nVocê pode Clicar com o Botão Direito para que ela envie uma &bCorrente&r que o arrastará em direção ao Bloco em que você atirou. Você pode Clicar com o Botão Direito novamente para soltá-la. Além disso, tem um Alcance de 90 Blocos, mais ou menos alguns. \\n\\nPara fazê-la, você precisará de uma &bAlma Aprisionada&r, 2 &5Cipós Tenazes&r e uma &9Pétala Tenaz&r. \\n\\nOs dois primeiros você pode obter como drops de um &5Ódio Emaranhado&r, enquanto o último você precisará matar uma &9Monstruosidade Lunar&r."]
		}
		quest.7D359283625C1869.quest_desc: {
			new: ["&4&lCataclysm&r é um Mod de aventura que se concentra em adicionar novos Chefes! E tudo que vem deles e ao redor deles! \\n\\nVocê encontrará as Estruturas por toda a &2&lSuperfícier&r, &4&lO Nether&r e &5&lO End&r. \\n\\nDentro haverá novos Mobs, Minichefes e Chefes muito difíceis. Você pode matá-los todos para obter novas Armas, Armaduras e Itens!"]
			old: ["&4&lCataclysm&r é um Mod de aventura que se concentra em adicionar novos Chefes! E tudo que vem deles e ao redor deles! \\n\\nVocê encontrará as Estruturas por todo o &2&lMundo Superior&r, &4&lO Nether&r e &5&lO End&r. \\n\\nDentro haverá novos Mobs, Minichefes e Chefes muito difíceis. Você pode matá-los todos para obter novas Armas, Armaduras e Itens!"]
		}
		quest.4BD203AD481DDE8F.quest_desc: {
			new: ["O &4Triturador&r é feito de &4Witherita&r, que é um Drop do &4&lWither Robô-Mecânico, A Máquina das Cavernas&r. \\n\\nVocê precisará encontrar a &4Fábrica Ancestral&r que fica no subsolo profundo da &2&lSuperfície&r. \\n\\nEntão você encontrará o &4&lWither Robô-Mecânico, A Máquina das Cavernas&r desligado, para ligá-lo, precisaremos alimentá-lo com uma Estrela do Nether! \\n\\nEntão, após uma luta de chefe muito difícil e longa, você pode Criar o &4Meat Shredder&r!"]
			old: ["O &4Meat Shredder&r é feito de &4Witherite&r, que é um Drop do &4&lArauto&r. \\n\\nVocê precisará encontrar a &4Fábrica Ancestral&r que fica no subsolo profundo do &2&lMundo Superior&r. \\n\\nEntão você encontrará o &4&lArauto&r desligado, para ligá-lo, precisaremos alimentá-lo com uma Estrela do Nether! \\n\\nEntão, após uma luta de chefe muito difícil e longa, você pode Criar o &4Meat Shredder&r!"]
		}
		quest.7D1A27CBF1508712.title: {
			new: "&aCubo Zygarde"
			old: "&3Cubo Zygarde"
		}
		quest.2D64EF8D803AF9DA.quest_desc: {
			new: ["O Portal mais caro que podemos fazer. Primeiro, para os &dOvos de Dragão&r, você não precisa continuar ordenhando o &dDragão&r, você pode usar &l&bHNN&r ou &l&2MA&r para obtê-los ou um Extrator para fazer mais! \\n\\nEntão, você precisará do &dInfused Dragon's Breath&r do Encantamento. \\n\\nLá você precisará de &9Soul-Touched Sculkshelves&r para Encantá-lo e para fazer o Portal. \\n\\nSe você está se perguntando por que o Portal não funciona, é porque você já está na &2&lSuperfície&r! Brincadeira, você não pode usá-lo!"]
			old: ["O Portal mais caro que podemos fazer. Primeiro, para os &dOvos de Dragão&r, você não precisa continuar ordenhando o &dDragão&r, você pode usar &l&bHNN&r ou &l&2MA&r para obtê-los ou um Extrator para fazer mais! \\n\\nEntão, você precisará do &dInfused Dragon's Breath&r do Encantamento. \\n\\nLá você precisará de &9Soul-Touched Sculkshelves&r para Encantá-lo e para fazer o Portal. \\n\\nSe você está se perguntando por que o Portal não funciona, é porque você já está no &2&lMundo Superior&r! Brincadeira, você não pode usá-lo!"]
		}
		quest.5B2FD54E425D5C9D.quest_desc: {
			new: ["Agora este é difícil de conseguir... precisaremos matar 2 Chefes e um Minichefe para obter tudo para a &dForja do &cVazio&r. \\n\\nPrimeiro, precisaremos de uma &4Bigorna de Fusão Mecânica&r. Para obtê-la, visite a &4Fábrica Ancestral&r que fica sob a &2&lSuperfície&r. \\n\\nEntão, alimente &4&lO Mensageiro&r com uma Estrela do Nether para fortalecê-lo e matá-lo! &4&lO Mensageiro&r dropará &4Witherite&r, que pode ser usada para Criar a &4Bigorna de Fusão Mecânica&r. \\n\\nEm seguida, precisaremos da &cForja Infernal&r. Isso é um Drop da &c&lMonstruosidade de Netherita&r. \\n\\nVá para o &c&lNether&r para encontrar a estrutura do &cFerreiro de Almas&r. Então, lute e mate a &c&lMonstruosidade de Netherita&r para obter sua &cForja Infernal&r! \\n\\nPor último e provavelmente o mais fácil é o &dNúcleo do Vazio&r. Felizmente, não é dropado por um Chefe, mas sim por um Minichefe! \\n\\nVisite o &5&lEnd&r para encontrar uma &dCidadela em Ruínas&r, dentro dela você encontrará o &dGolem do End&r. Este nos dropará nosso &dNúcleo do Vazio&r. \\n\\nQuando tiver tudo, use a &4Bigorna de Fusão Mecânica&r para combinar a &cForja Infernal&r e o &dNúcleo do Vazio&r para criar a &dForja do &cVazio&r."]
			old: ["Agora este é difícil de conseguir... precisaremos matar 2 Chefes e um Minichefe para obter tudo para a &dForja do &cVazio&r. \\n\\nPrimeiro, precisaremos de uma &4Bigorna de Fusão Mecânica&r. Para obtê-la, visite a &4Fábrica Ancestral&r que fica sob o &2&lMundo Superior&r. \\n\\nEntão, alimente &4&lO Mensageiro&r com uma Estrela do Nether para fortalecê-lo e matá-lo! &4&lO Mensageiro&r dropará &4Witherite&r, que pode ser usada para Criar a &4Bigorna de Fusão Mecânica&r. \\n\\nEm seguida, precisaremos da &cForja Infernal&r. Isso é um Drop da &c&lMonstruosidade de Netherita&r. \\n\\nVá para o &c&lNether&r para encontrar a estrutura do &cFerreiro de Almas&r. Então, lute e mate a &c&lMonstruosidade de Netherita&r para obter sua &cForja Infernal&r! \\n\\nPor último e provavelmente o mais fácil é o &dNúcleo do Vazio&r. Felizmente, não é dropado por um Chefe, mas sim por um Minichefe! \\n\\nVisite o &5&lEnd&r para encontrar uma &dCidadela em Ruínas&r, dentro dela você encontrará o &dGolem do End&r. Este nos dropará nosso &dNúcleo do Vazio&r. \\n\\nQuando tiver tudo, use a &4Bigorna de Fusão Mecânica&r para combinar a &cForja Infernal&r e o &dNúcleo do Vazio&r para criar a &dForja do &cVazio&r."]
		}
		quest.4BD203AD481DDE8F.title: {
			new: "&4Triturador"
			old: "&4Meat Shredder"
		}
		quest.7D1A27CBF1508712.quest_desc: {
			new: ["Eu não sei como o mod quer que você o obtenha, mas você pode obter com um &c&lMontador&r do &6&lOritech&r combinando 2 &aCristais Vibrante&f e 2 &aCristais do Tempo&r. \\n\\nO &aCristal Vibrante&r é do &c&lPowah&r. Você pega uma &aEsmeralda&r, coloca-a em um Orbe Energizante, então usa Varas Energizante para disparar energia nela. \\n\\nVaras Energizante, quando apontadas para um Orb, retirarão automaticamente energia dele para o item dentro do Orb. Cada &aEsmeralda&r precisará de 1MFe para se tornar um &aCristal Vibrante&r. \\n\\nO outro item são os &aCristais do Tempo&r do &3&lJust Dire Things&r. &aCristais do Tempo&r crescem como &5Ametista&r a partir de &aDrusas de Cristais do Tempo&r. \\n\\nPara fazer uma &aDrusa de Cristal do Tempo&r, precisaremos ter um &5Bloco de Drusa de Ametista&r próximo a &9Gosma de Shadowpulse&r. Então, alimente a Gosma! \\n\\nHá muito mais para manter nossos &aCristais do Tempo&r vindo... felizmente isso é explicado com mais detalhes na linha de missões do &3&lJust Dire Things&r!"]
			old: ["É um cubo, como todas as coisas devem ser."]
		}
		quest.486B5A605D79EA10.quest_desc: {
			new: ["O &cMódulo &aManhattan&r é uma Receita complicada. Ele precisa de &cTNT&r, &dPastilha de Plutônio&r e &5Compensador de Heisenberg&r. Ok, talvez 2/3 dela seja complicada. \\n\\nPara fazer &dPastilhas de Plutônio&r, comece Energizando &5Fragmentos de Ametista&r. Isso fará &5Fluxita&r, que pode ser usada com &aPó de Urânio&r em um &l&5Acelerador de Partículas&r para fazer &dPó de Plutônio&r. \\n\\nO &dPó de Plutônio&r pode ser fabricado com Folha de Plástico e um Lingote para fazer nossas &dPastilha&r. \\n\\nO &5Compensador de Heisenberg&r tem 2 Receitas que podemos usar. Cada uma precisará da &c&lForja Atômica&r para &cGravá-los&r com &bLingotes de Adamante&r. \\n\\n1. É com a &bInteligência Profana&r. Que é criada enchendo um &2Recipiente Duvidoso&r com &5Matéria Estranha&r. A &5Matéria Estranha&r é encontrada passando &cLava&r e um &3Composto Endérico&r por uma &d&lRefinaria de Fluidos&r com 2 Câmaras Extras anexadas a ela. \\n\\n2. É com o &eSuper Chip de IA&r. IA no &2&lMinecraft&r? Sim, e requer uma Árvore de Receitas de &cGravação&r, com a &c&lForja Atômica&r, para Fabricar. Muito &8Silício&r com certeza."]
			old: [""]
		}
		quest.4E8C32CD6057A1AB.quest_subtitle: {
			new: "Combustível que nunca se apaga… será? 🔥"
			old: "Combustível que nunca se apaga… ou será? 🔥"
		}
		quest.03564837ECB5CC79.quest_desc: {
			new: ["Outro Ritual, claro, sendo este o &2Encantamento de Ihagan&r. (A propósito, para sacrificar um Cavalo, você precisa que ele esteja por perto durante o ritual) \\n\\nUma vez concluído, você receberá um &2Familiar Dragão&r. Você terá que jogar um Capturador de Criaturas nele para usá-lo para a &6&lEstrela ATM&r.\\n\\nEste aqui seguirá você por toda parte e pode ser acariciado usando Shift + Clique Direito nele."]
			old: ["Outro Ritual, claro, este sendo o &2Encantamento de Ihagan&r. (A propósito, para sacrificar um Cavalo, você precisa dele por perto enquanto faz o ritual)\\n\\nUma vez feito, você receberá um Ovo de Invocação para um &2Familiar Dragão&r. Estes podem ser usados na criação para obter a &6&lEstrela ATM&r, ou você pode invocar o &2Familiar&r.\\n\\nEste irá segui-lo e pode ser acariciado usando Shift + Clique Direito nele."]
		}
		quest.4B7D387CEFF9667E.quest_desc: {
			new: ["Finalmente! O &6&lCreate&r foi atualizado e definitivamente valeu a pena esperar! \\n\\nO &6&lCreate&r é todo sobre girar e usar Energia Rotacional... bem, para praticamente tudo! Fabricação, trituração, mistura, fermentação, etc."]
			old: ["Finalmente! O &6&lCreate&r foi atualizado e definitivamente valeu a pena esperar! \\n\\nO &6&lCreate&r é todo sobre girar e usar a Energia Rotacional... bem, para praticamente tudo! Criação, trituração, mistura, fermentação, ETC. \\n\\nSe já faz tanto tempo que você не lembra como usar o &6&lCreate&r, você pode usar a &7&lIndustrialização Moderna&r para Criar a &6&lEstrela ATM&r."]
		}
		quest.1EB04FE105ACA4BE.quest_desc: {
			new: ["Quando um &9Defensor&r morre, ele tem a chance de dropar um &9Coração das Profundezas&r. \\n\\nIsso pode ser usado para a &6&lEstrela ATM&r, ou para ativar o Portal na Cidade Ancestral! \\n\\nNão pode haver nada no Portal para ativá-lo, isso inclui &9Sculk&r!"]
			old: ["Quando um &9Warden&r morre, ele tem a chance de dropar um &9Coração das Profundezas&r. \\n\\nIsso pode ser usado para a &6&lEstrela ATM&r, ou para ativar o Portal na Cidade Ancestral! \\n\\nNão pode haver nada no Portal para ativá-lo, isso inclui &9Sculk&r!"]
		}
		quest.5608C74936CA9E81.quest_desc: {
			new: ["O &6Braço Mecânico&r é uma Máquina muito confusa, mas também muito útil do &6&lCreate&r. Graças a Deus, não preciso explicar como usá-los, apenas como Fabrica-los! \\n\\nPrimeiro, e mais simples, é a &8Liga de Andesito&r. Isso é apenas 2 &8Blocos de Andesito&r e 2 &7Pepitas de Zinco/Ferro&r. \\n\\nEm seguida, são as &eChapas de Latão&r e o &eRevestimento&r. Ambos obviamente requerem &eLatão&r, que é uma Liga feita de &6Cobre&r e &7Zinco&r! \\n\\nPor último, é definitivamente o mais difícil destes, o &eMecanismo de Precisão&r. Você precisará de toda uma configuração de &6Ejetores&r e &eEsteiras&r para continuar movendo nossa &eChapa de Ouro&r para adicionar mais Itens a ela. \\n\\n1º passo: é usar o &6Ejetor&r para adicionar uma &dEngrenagem&r à nossa &eChapa de Ouro&r. 2º: é usar um semelhante para adicionar uma &dEngrenagem Grande&r a ela. 3º passo: nos faz adicionar uma &7Pepita de Ferro&r com o &6Ejetor&r. \\n\\nPrecisaremos repetir isso 5 vezes para, com sorte, obter nosso &eMecanismo de Precisão&r! Sim, há 20% de chance de você não obter o Item no final!"]
			old: ["O &6Braço Mecânico&r é uma Máquina muito confusa, mas também muito útil do &6&lCreate&r. Graças a Deus, não preciso explicar como usá-los, apenas como Criá-los! \\n\\nPrimeiro, e mais simples, é a &8Liga de Andesito&r. São apenas 2 &8Blocos de Andesito&r e 2 &7Pepitas de Zinco/Ferro&r. \\n\\nEm seguida, temos as &eChapas de Latão&r e &eInvólucro&r. Ambos obviamente requerem &eLatão&r, que é uma Liga feita de &6Cobre&r e &7Zinco&r! \\n\\nPor último, é definitivamente o mais difícil deles, o &eMecanismo de Precisão&r. Você precisará de toda uma configuração de &6Posicionadores&r e &eCorreias&r para continuar movendo nossa &eChapa de Ouro&r para adicionar mais Itens a ela. \\n\\n1º passo: é usar o &6Posicionador&r para adicionar uma &dRoda Dentada&r à nossa &eChapa de Ouro&r. 2º: é usar algo semelhante para adicionar uma &dRoda Dentada Grande&r a ela. 3º passo: temos que adicionar uma &7Pepita de Ferro&r com o &6Posicionador&r. \\n\\nPrecisaremos repetir isso 5 vezes para, com sorte, obter nosso &eMecanismo de Precisão&r! Sim, há uma chance de 20% de você não conseguir o Item no final! \\n\\nEi, se você não gosta de todo esse trabalho, sempre pode Criar o &6Grande Motor Avançado&r."]
		}
		quest.2A444F4CCC72545D.title: {
			new: "&5Sacrifício Abissal"
			old: "&5Sacrifício Abissal (Abyssal Sacrifice)"
		}
